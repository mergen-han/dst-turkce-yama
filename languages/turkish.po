msgstr "Bilimin gücü zorladı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUSHROOM_FARM.EMPTY
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUSHROOM_FARM.EMPTY"
