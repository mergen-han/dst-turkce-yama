#. STRINGS.NIGHTMARE_OVERGROWTH.LINE_1
msgctxt "STRINGS.NIGHTMARE_OVERGROWTH.LINE_1"
msgid "\"Forsaken wretches of the one who turned away.\""
msgstr "\"Yüzünü çevirenin terk ettiği zavallılar.\""

#. STRINGS.NIGHTMARE_OVERGROWTH.LINE_2
msgctxt "STRINGS.NIGHTMARE_OVERGROWTH.LINE_2"
msgid "\"Orphans cast upon the barren expanse. Lost in the wake of neglect.\""
msgstr "\"Çorak enginliğe atılmış öksüzler. İhmalin uyandırdığı dalgada kayıp.\""

#. STRINGS.NIGHTMARE_OVERGROWTH.LINE_3
msgctxt "STRINGS.NIGHTMARE_OVERGROWTH.LINE_3"
msgid "\"From desolation were we drawn. Into the veiled embrace of Them.\""
msgstr "\"Issızlıktan çekildik. Onların perdeli kucağına.\""

#. STRINGS.NIGHTMARE_OVERGROWTH.LINE_4
msgctxt "STRINGS.NIGHTMARE_OVERGROWTH.LINE_4"
msgid "\"No longer doth the shadow stir terror within our hearts.\""
msgstr "\"Artık gölge yüreklerimizde dehşet uyandırmaz.\""

#. STRINGS.NIGHTMARE_OVERGROWTH.LINE_5
msgctxt "STRINGS.NIGHTMARE_OVERGROWTH.LINE_5"
msgid "\"For dark is become our shield. Our sustenance. Our solace.\""
msgstr "\"Zira karanlık kalkanımız oldu. Geçimimiz. Tesellimiz.\""

