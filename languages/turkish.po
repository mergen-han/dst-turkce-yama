#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTB_LEARN_NEW_PATTERN
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTB_LEARN_NEW_PATTERN"
msgid "Hey, I think I can make a new beefalo costume!"
msgstr "Hey, yeni bir bızonsığır kostümü yapabilirim sanırım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTD_NOBOATS
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTD_NOBOATS"
msgid "We've got to get closer to the Start Tower, Woby!"
msgstr "Başlangıç Kulesi'ne yaklaşmamız gerek, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTD_NOCHECKPOINTS
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTD_NOCHECKPOINTS"
msgid "Whoops, I might've forgot to set up the checkpoints..."
msgstr "Tüh, kontrol noktalarını kurmayı unutmuş olabilirim..."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTD_NOTENOUGHBOATS
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTD_NOTENOUGHBOATS"
msgid "We need to make some room for other racers, Woby!"
msgstr "Diğer yarışçılar için biraz yer açmamız gerek, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTH_ONCOOLDOWN
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_YOTH_ONCOOLDOWN"
msgid "They must be too busy to come now, Woby girl."
msgstr "Şimdi gelmek için çok meşguller olmalı, Woby kızım."

#. STRINGS.CHARACTERS.WALTER.ANOUNCE_MUTATED_BIRD_ATTACK
msgctxt "STRINGS.CHARACTERS.WALTER.ANOUNCE_MUTATED_BIRD_ATTACK"
msgid "Incoming!"
msgstr "Geliyor!"

#. STRINGS.CHARACTERS.WALTER.BATTLECRY.DEER
msgctxt "STRINGS.CHARACTERS.WALTER.BATTLECRY.DEER"
msgid "Sorry deer!"
msgstr "Üzgünüm geyik!"

#. STRINGS.CHARACTERS.WALTER.BATTLECRY.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.BATTLECRY.GENERIC"
msgid "Sorry!!"
msgstr "Üzgünüm!!"

#. STRINGS.CHARACTERS.WALTER.BATTLECRY.PIG
msgctxt "STRINGS.CHARACTERS.WALTER.BATTLECRY.PIG"
msgid "It didn't have to be like this!"
msgstr "Böyle olmak zorunda değildi!"

#. STRINGS.CHARACTERS.WALTER.BATTLECRY.PREY
msgctxt "STRINGS.CHARACTERS.WALTER.BATTLECRY.PREY"
msgid "Sorry, you're going to be dinner for me and Woby!"
msgstr "Üzgünüm, sen Woby ve bana akşam yemeği olacaksın!"

#. STRINGS.CHARACTERS.WALTER.BATTLECRY.SPIDER
msgctxt "STRINGS.CHARACTERS.WALTER.BATTLECRY.SPIDER"
msgid "This wouldn't be happening if you didn't try to eat me!"
msgstr "Beni yemeye çalışmasaydın bu olmuyordu!"

#. STRINGS.CHARACTERS.WALTER.BATTLECRY.SPIDER_WARRIOR
msgctxt "STRINGS.CHARACTERS.WALTER.BATTLECRY.SPIDER_WARRIOR"
msgid "Take that! And that!"
msgstr "Al şunu! Bir de şunu!"

#. STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.GENERIC"
msgid "Y-yeah! You better run!"
msgstr "E-evet! Kaçsan iyi olur!"

#. STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.PIG
msgctxt "STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.PIG"
msgid "Let's just take a minute to cool our heads."
msgstr "Biraz kafamızı toparlamak için duralım."

#. STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.PREY
msgctxt "STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.PREY"
msgid "Darnit! They got away."
msgstr "Lanet olsun! Kaçtılar."

#. STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.SPIDER
msgctxt "STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.SPIDER"
msgid "I didn't really want to fight them anyway."
msgstr "Zaten onlarla pek savaşmak istemiyordum."

#. STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.SPIDER_WARRIOR
msgctxt "STRINGS.CHARACTERS.WALTER.COMBAT_QUIT.SPIDER_WARRIOR"
msgid "Nobody likes a bully."
msgstr "Kimse zorbayı sevmez."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL1.1
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL1.1"
msgid "Your sister kind of creeps me out, but you're alright!"
msgstr "Kardeşin beni biraz ürkütüyor ama sen iyisin!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL1.2
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL1.2"
