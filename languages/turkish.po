#. STRINGS.UI.SERVERLISTINGSCREEN.INTENTION_DESC.ANY
msgctxt "STRINGS.UI.SERVERLISTINGSCREEN.INTENTION_DESC.ANY"
msgid "You're, like, laidback and flexible, man. Any world is good with you."
msgstr "Sen şöyle rahat ve esnek bir tipsin yani. Sana her dünya uyar."

#. STRINGS.UI.SERVERLISTINGSCREEN.INTENTION_DESC.COMPETITIVE
msgctxt "STRINGS.UI.SERVERLISTINGSCREEN.INTENTION_DESC.COMPETITIVE"
msgid "You'll show your opponents exactly what you're made of by playing smarter, harder, faster and coming out on top!"
msgstr "Daha akıllı, daha sert, daha hızlı oynayıp tepede biterek rakiplerine ne mal olduğunu göstereceksin!"

#. STRINGS.UI.SERVERLISTINGSCREEN.INTENTION_DESC.COOPERATIVE
msgctxt "STRINGS.UI.SERVERLISTINGSCREEN.INTENTION_DESC.COOPERATIVE"
msgid "Teamwork is your guiding principal. It's not enough to just not starve, you have to not starve... Together!"
