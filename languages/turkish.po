msgid "It's sleeping."
msgstr "Uyuyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BLUE_MUSHROOM.PICKED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BLUE_MUSHROOM.PICKED"
msgid "I wonder if it will come back?"
msgstr "Geri gelecek mi acaba?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOARDS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOARDS"
msgid "Boards."
msgstr "Tahtalar."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOARON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOARON"
msgid "I can take him!"
msgstr "Onu alt edebilirim!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOARRIOR
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOARRIOR"
msgid "You sure are big!"
msgstr "Cidden büyüksün!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATFRAGMENT03
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATFRAGMENT03"
msgid "Not much left of it."
msgstr "Geriye fazla bir şey kalmamış."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATFRAGMENT04
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATFRAGMENT04"
msgid "Not much left of it."
msgstr "Geriye fazla bir şey kalmamış."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATFRAGMENT05
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATFRAGMENT05"
msgid "Not much left of it."
msgstr "Geriye fazla bir şey kalmamış."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATPATCH
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATPATCH"
msgid "Just in case of disaster."
msgstr "Felaket olur diye."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATPATCH_KELP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATPATCH_KELP"
msgid "It'll have to do for now."
msgstr "Şimdilik bunu idare etmek gerek."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_CHECKPOINT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_CHECKPOINT"
msgid "There's the checkpoint!"
msgstr "İşte kontrol noktası!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_CHECKPOINT_THROWABLE_DEPLOYKIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_CHECKPOINT_THROWABLE_DEPLOYKIT"
msgid "One more thing to check off my list."
msgstr "Listemden çıkaracak bir şey daha."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_PRIMEMATE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_PRIMEMATE"
msgid "Someone's shadowing me!"
msgstr "Birisi beni gölgeliyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SEASTACK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SEASTACK"
msgid "Buoy oh buoy!"
msgstr "Şamandı-vay vay!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SEASTACK_MONKEY
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SEASTACK_MONKEY"
msgid "Buoy oh buoy!"
msgstr "Şamandı-vay vay!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SEASTACK_MONKEY_THROWABLE_DEPLOYKIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SEASTACK_MONKEY_THROWABLE_DEPLOYKIT"
msgid "Buoy oh buoy!"
msgstr "Şamandı-vay vay!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SEASTACK_THROWABLE_DEPLOYKIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SEASTACK_THROWABLE_DEPLOYKIT"
msgid "Buoy oh buoy!"
msgstr "Şamandı-vay vay!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SPECTATOR_DRAGONLING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_SPECTATOR_DRAGONLING"
msgid "Its support is getting me all fired up!"
msgstr "Desteği beni alev alev heyecanlandırıyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_START
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_START"
msgid "You have to start somewhere."
msgstr "Bir yerden başlamak zorundasın."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_START_THROWABLE_DEPLOYKIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOATRACE_START_THROWABLE_DEPLOYKIT"
msgid "Where to start?"
msgstr "Nereden başlamalı?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ANCIENT_CONTAINER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ANCIENT_CONTAINER"
msgid "\"Cargo\" is sailor-lingo for \"stuff\"."
msgstr "\"Kargo\", denizcilerin \"şey\" demesidir."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ANCIENT_ITEM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ANCIENT_ITEM"
msgid "I guess I'm doing this the old-fashioned way."
msgstr "Sanırım bunu eski usulle yapıyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_CRABKING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_CRABKING"
msgid "It's my boat's crowning glory."
msgstr "Teknemin tac iftiharı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_CRABKING_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_CRABKING_KIT"
msgid "A soon-to-be boat bumper."
msgstr "Birazdan tekne tamponu olacak."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_KELP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_KELP"
msgid "It won't save the boat from everything, but it sure kelps."
msgstr "Tekneyi her şeyden kurtarmaz, ama yosunca yardım eder."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_KELP_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_KELP_KIT"
msgid "A soon-to-be boat bumper."
msgstr "Birazdan tekne tamponu olacak."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_SHELL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_SHELL"
msgid "It gives the boat a little shellf defense."
msgstr "Tekneye biraz kabuk-savunma sağlıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_SHELL_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_SHELL_KIT"
msgid "A soon-to-be boat bumper."
msgstr "Birazdan tekne tamponu olacak."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_YOTD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_YOTD"
msgid "When you mess with a dragon boat, you get the horns!"
msgstr "Bir ejder-tekneye bulaşırsan, boynuzları yersin!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_YOTD_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_BUMPER_YOTD_KIT"
msgid "A soon-to-be boat bumper."
msgstr "Birazdan tekne tamponu olacak."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_CANNON.AMMOLOADED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_CANNON.AMMOLOADED"
msgid "The cannon is ready to fire!"
msgstr "Top ateşlemeye hazır!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_CANNON.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_CANNON.GENERIC"
msgid "I should load it with something."
msgstr "İçine bir şey yüklemeliyim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_CANNON.NOAMMO
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_CANNON.NOAMMO"
msgid "I didn't forget the cannonballs, I'm just letting the anticipation build."
msgstr "Top güllelerini unutmadım, sadece beklentinin yükselmesine izin veriyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_CANNON_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_CANNON_KIT"
msgid "It's not a cannon yet, but it will be."
msgstr "Henüz top değil, ama olacak."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_GRASS_ITEM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_GRASS_ITEM"
msgid "It's technically a boat."
msgstr "Teknik olarak bir tekne."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ITEM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ITEM"
msgid "It would be nice to do some experiments on the water."
msgstr "Suda biraz deney yapmak güzel olurdu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_LEAK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_LEAK"
msgid "I should patch that up before we sink."
msgstr "Batmadan önce şunu yamamalıyım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET.ACTIVATED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET.ACTIVATED"
msgid "It's working!! Er, I knew it would work, of course."
msgstr "Çalışıyor!! Şey, çalışacağını biliyordum, tabii ki."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET.GENERIC"
msgid "I'm always drawn to physics, like a... ah, can't think of the word."
msgstr "Fiziğe her zaman çekilirim, sanki bir... ah, kelime aklıma gelmiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET_BEACON.ACTIVATED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET_BEACON.ACTIVATED"
msgid "Magnetism!"
msgstr "Manyetizma!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET_BEACON.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET_BEACON.GENERIC"
msgid "This will attract any strong magnets nearby."
msgstr "Yakındaki güçlü mıknatısları çekecek."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_MAGNET_KIT"
msgid "One of my more genius ideas, if I do say so myself."
msgstr "Daha dahice fikirlerimden biri, kendim söylüyorum ama."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ROTATOR
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ROTATOR"
msgid "Things are going in the right direction. Or maybe the left."
msgstr "İşler doğru yöne gidiyor. Veya belki sola."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ROTATOR_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOAT_ROTATOR_KIT"
msgid "I think I'll take it out for a spin."
msgstr "Sanırım bir tur attıracağım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BODYPILLOW_BEEFALOWOOL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BODYPILLOW_BEEFALOWOOL"
msgid "If only it didn't also smell like a beefalo."
msgstr "Keşke aynı zamanda bızonsığır gibi kokmasaydı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BODYPILLOW_KELP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BODYPILLOW_KELP"
msgid "It's soggier than I would like."
msgstr "İstediğimden daha sırılsıklam."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BODYPILLOW_PETALS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BODYPILLOW_PETALS"
msgid "At least it smells nicer than the beefalo pillow."
msgstr "En azından bızonsığır yastığından daha güzel kokuyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BODYPILLOW_STEELWOOL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BODYPILLOW_STEELWOOL"
msgid "Who would sleep on this?"
msgstr "Bunun üzerinde kim uyur?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOMB_LUNARPLANT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOMB_LUNARPLANT"
msgid "Botany and chemistry, working together."
msgstr "Botanik ve kimya, beraber çalışıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOMB_LUNARPLANT_WORMWOOD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOMB_LUNARPLANT_WORMWOOD"
msgid "Our friend seems to be getting more in touch with his lunar roots."
msgstr "Arkadaşımız ay köküyle giderek daha çok bağ kuruyor gibi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BONESHARD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BONESHARD"
msgid "Bits of bone."
msgstr "Kemik parçaları."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BONESOUP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BONESOUP"
msgid "No bones about it, Warly can cook."
msgstr "Hiç kemik şüphesi yok, Warly yemek yapabiliyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BONESTEW
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BONESTEW"
msgid "A stew to put some meat on your bones."
msgstr "Kemiklerine et koyacak bir yahni."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOKSTATION.BURNT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOKSTATION.BURNT"
msgid "I think the library's closed."
msgstr "Sanırım kütüphane kapandı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOKSTATION.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOKSTATION.GENERIC"
msgid "Why study when I can experiment?"
msgstr "Deney yapabilirken neden çalışayım?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_BEES
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_BEES"
msgid "I don't get all the buzz around this one."
msgstr "Bunun etrafındaki vızıltıyı pek anlamıyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_BIRDS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_BIRDS"
msgid "No point studying when I can just wing it."
msgstr "Kanat çırparak idare edebilecekken çalışmak anlamsız."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_BRIMSTONE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_BRIMSTONE"
msgid "The beginning was dull, but got better near the end."
msgstr "Başlangıcı sıkıcıydı, ama sonuna doğru iyiye gitti."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_ELEMENTAL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_ELEMENTAL"
msgid "I can't make out the text."
msgstr "Metni seçemiyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_FIRE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_FIRE"
msgid "I don't feel a burning need to read it."
msgstr "Onu okumak için yanan bir ihtiyaç hissetmiyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_FISH
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_FISH"
msgid "It didn't really hook me."
msgstr "Beni gerçekten oltaya takmadı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_FOSSIL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_FOSSIL"
msgid "This'll keep those monsters held for a little while."
msgstr "Bu o canavarları bir süre tutar."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_GARDENING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_GARDENING"
msgid "I see no farm in reading that."
msgstr "Bunu okumakta hiç tarla göremiyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_HORTICULTURE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_HORTICULTURE"
msgid "I see no farm in reading that."
msgstr "Bunu okumakta hiç tarla göremiyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_HORTICULTURE_UPGRADED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_HORTICULTURE_UPGRADED"
msgid "It's about as exciting as watching grass grow."
msgstr "Çimen büyümesini izlemek kadar heyecan verici."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_LIGHT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_LIGHT"
msgid "Whoever wrote this must've been pretty bright."
msgstr "Bunu kim yazdıysa epey parlak biri olmalı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_LIGHT_UPGRADED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_LIGHT_UPGRADED"
msgid "Brilliant!"
msgstr "Parlak!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_MOON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_MOON"
msgid "All this interest in the moon is probably just a phase."
msgstr "Tüm bu ay merakı muhtemelen sadece geçici bir evre."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_RAIN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_RAIN"
msgid "That doesn't sound very scientific."
msgstr "Bu pek bilimsel gelmiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_RESEARCH_STATION
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_RESEARCH_STATION"
msgid "Wickerbottom likes to do everything by the book."
msgstr "Wickerbottom her şeyi kitabına göre yapmayı sever."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_SILVICULTURE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_SILVICULTURE"
msgid "I'll stick to my own experiments."
msgstr "Kendi deneylerime sadık kalacağım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_SLEEP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_SLEEP"
msgid "Strange, it's just 500 pages of telegraph codes."
msgstr "Tuhaf, sadece 500 sayfalık telgraf kodları."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_TEMPERATURE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_TEMPERATURE"
msgid "My thoughts on it are only lukewarm."
msgstr "Hakkındaki düşüncelerim sadece ılık."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_TENTACLES
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_TENTACLES"
msgid "Someone'll get suckered into reading this."
msgstr "Birisi bunu okumaya vantuzca çekilecek."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_WEB
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOK_WEB"
msgid "I'm not scared of spiders! I'm not!"
msgstr "Örümceklerden korkmuyorum! Korkmuyorum!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOMERANG
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOMERANG"
msgid "Aerodynamical!"
msgstr "Aerodinamiksel!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOTLEG
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BOOTLEG"
msgid "Somewhere out there, a pirate is missing their bootie."
msgstr "Bir yerlerde bir korsan, çizme-ganimetini özlüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BROKEN_FORGEDITEM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BROKEN_FORGEDITEM"
msgid "It's broken, but I think I could repair it."
msgstr "Bozuk, ama tamir edebilirim sanırım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BRUSH
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BRUSH"
msgid "I bet the beefalo really like this."
msgstr "Bahse girerim bızonsığırlar bunu gerçekten seviyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUGNET
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUGNET"
msgid "For catching bugs."
msgstr "Böcek yakalamak için."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BULLKELP_PLANT.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BULLKELP_PLANT.GENERIC"
msgid "Welp. It's kelp."
msgstr "Eh işte. Yosun."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BULLKELP_PLANT.PICKED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BULLKELP_PLANT.PICKED"
msgid "I just couldn't kelp myself."
msgstr "Kendime yosunca engel olamadım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BULLKELP_ROOT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BULLKELP_ROOT"
msgid "I can plant it in deep water."
msgstr "Onu derin suya ekebilirim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUNDLE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUNDLE"
msgid "Our supplies are in there!"
msgstr "Erzakımız orada!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUNDLEWRAP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUNDLEWRAP"
msgid "Wrapping things up should make them easier to carry."
msgstr "Şeyleri sarmak, taşınmasını kolaylaştırır."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUNNYMAN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUNNYMAN"
msgid "I am filled with an irresistible urge to do science."
msgstr "Bilim yapmak için karşı konulmaz bir dürtüyle doluyum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUNNYSTEW
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUNNYSTEW"
msgid "This one's luck has run out."
msgstr "Bunun şansı tükenmiş."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BURNT_MARSH_BUSH
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BURNT_MARSH_BUSH"
msgid "It's all burnt up."
msgstr "Hepsi yanmış."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUSHHAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUSHHAT"
msgid "It's kind of scratchy."
msgstr "Biraz tahriş edici."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTER"
msgid "I can't believe it's butter!"
msgstr "Bunun tereyağı olduğuna inanamıyorum!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTERFLY.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTERFLY.GENERIC"
msgid "Butterfly, flutter by."
msgstr "Kelebek, kanatla geçeyver."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTERFLY.HELD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTERFLY.HELD"
msgid "Now I have you!"
msgstr "Şimdi yakaladım seni!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTERFLYMUFFIN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTERFLYMUFFIN"
msgid "We threw the recipe away and just kind of winged it."
msgstr "Tarifi attık ve kanat çırparak idare ettik."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTERFLYWINGS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUTTERFLYWINGS"
msgid "Without these, it's just a butter."
msgstr "Bunlar olmadan, sadece bir tereyağı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUZZARD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUZZARD"
msgid "What a bizarre buzzard!"
msgstr "Ne acayip bir akbaba!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUZZARDCORPSE.BURNING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUZZARDCORPSE.BURNING"
msgid "That's what I call a firebird."
msgstr "İşte buna ateşkuşu derim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUZZARDCORPSE.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUZZARDCORPSE.GENERIC"
msgid "I call fowl."
msgstr "Bu kuşkulu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUZZARDCORPSE.REVIVING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BUZZARDCORPSE.REVIVING"
msgid "It's becoming a new species!"
msgstr "Yeni bir tür oluyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CABBAGEROLLS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CABBAGEROLLS"
msgid "The meat hides inside the cabbage to avoid predators."
msgstr "Et, avcılardan kaçmak için lahananın içine saklanmış."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS.GENERIC"
msgid "Sharp but delicious."
msgstr "Keskin ama lezzetli."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS.PICKED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS.PICKED"
msgid "Deflated, but still spiny."
msgstr "Sönmüş, ama hâlâ dikenli."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS_FLOWER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS_FLOWER"
msgid "A pretty flower from a prickly plant."
msgstr "Dikenli bir bitkiden gelen güzel bir çiçek."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS_MEAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS_MEAT"
msgid "There are still some spines between me and a tasty meal."
msgstr "Benimle lezzetli bir yemek arasında hâlâ birkaç diken var."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS_MEAT_COOKED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CACTUS_MEAT_COOKED"
msgid "Grilled fruit of the desert."
msgstr "Çölün ızgara meyvesi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CALIFORNIAROLL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CALIFORNIAROLL"
msgid "But I don't have chopsticks."
msgstr "Ama çubuklarım yok."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.EMBERS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.EMBERS"
msgid "That fire needs more fuel or it's going to go out."
msgstr "Bu ateşin daha çok yakıta ihtiyacı var, yoksa sönecek."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.GENERIC"
msgid "Sure beats darkness."
msgstr "Karanlığa kesinlikle yeğdir."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.HIGH
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.HIGH"
msgid "That fire is getting out of hand!"
msgstr "Bu ateş kontrolden çıkıyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.LOW
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.LOW"
msgid "The fire's getting a bit low."
msgstr "Ateş biraz alçalıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.NORMAL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.NORMAL"
msgid "Nice and comfy."
msgstr "Hoş ve rahat."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.OUT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAMPFIRE.OUT"
msgid "Well, that's over."
msgstr "Eh, bitti."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANARY.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANARY.GENERIC"
msgid "Some sort of yellow creature made of science."
msgstr "Bilimden yapılmış bir tür sarı yaratık."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANARY.HELD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANARY.HELD"
msgid "I'm not squishing you, am I?"
msgstr "Seni ezmiyorum, değil mi?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANARY_POISONED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANARY_POISONED"
msgid "It's probably fine."
msgstr "Muhtemelen iyidir."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANDYBAG
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANDYBAG"
msgid "It's some sort of delicious pocket dimension for sugary treats."
msgstr "Şekerli ikramlar için bir tür lezzetli cep boyutu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANE"
msgid "Technically walking is just controlled falling."
msgstr "Teknik olarak yürümek, kontrollü düşmedir."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANNONBALL_ROCK_ITEM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CANNONBALL_ROCK_ITEM"
msgid "This will fit into a cannon perfectly."
msgstr "Bu bir topa mükemmel sığar."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALCANNON.COOLDOWN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALCANNON.COOLDOWN"
msgid "What a blast!"
msgstr "Ne patlama!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALCANNON.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALCANNON.GENERIC"
msgid "This experiment blows up on purpose!"
msgstr "Bu deney kasten patlıyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALCANNON_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALCANNON_KIT"
msgid "I've got a lot of experience in making things explode."
msgstr "Bir şeyleri patlatma konusunda çok deneyimim var."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_BANNER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_BANNER"
msgid "I think all these shiny decorations reflect well on me."
msgstr "Sanırım tüm bu parlak süslemeler beni iyi yansıtıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_BANNER_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_BANNER_KIT"
msgid "I have to build it myself? I should have known there'd be a catch."
msgstr "Kendim mi yapmam gerek? Bir tuzak olduğunu bilmeliydim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_EGGRIDE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_EGGRIDE"
msgid "I could watch it for hours."
msgstr "Saatlerce izleyebilirim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_EGGRIDE_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_EGGRIDE_KIT"
msgid "I hope this prize is all it's cracked up to be."
msgstr "Umarım bu ödül kırık kabuklarına değecek kadar iyidir."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE.GENERIC"
msgid "I seem to be getting a lot of these..."
msgstr "Bunlardan çok fazla alıyor gibiyim..."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE.RARE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE.RARE"
msgid "See? Proof that trying the exact same thing over and over will eventually lead to success!"
msgstr "Gördün mü? Aynı şeyi tekrar tekrar denemenin sonunda başarıya götüreceğinin kanıtı!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE.UNCOMMON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE.UNCOMMON"
msgid "You don't see this kind of design too often."
msgstr "Bu tür bir tasarımı pek sık görmezsin."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE_KIT"
msgid "The thrill of discovery!"
msgstr "Keşfin heyecanı!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE_KIT_SEASON2
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_FIGURE_KIT_SEASON2"
msgid "The thrill of discovery!"
msgstr "Keşfin heyecanı!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_LAMP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_LAMP"
msgid "It's powered by whimsy."
msgstr "Hayal gücüyle çalışıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_LAMP_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_LAMP_KIT"
msgid "Only some light work left to do."
msgstr "Geriye sadece biraz aydın iş kaldı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_PLANT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_PLANT"
msgid "Either it's small, or I'm gigantic."
msgstr "Ya o küçük, ya da ben dev."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_PLANT_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALDECOR_PLANT_KIT"
msgid "Maybe it's a boxwood?"
msgstr "Belki bir şimşir bitkisidir?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALFOOD_CORNTEA
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALFOOD_CORNTEA"
msgid "Is this drink supposed to be crunchy?"
msgstr "Bu içeceğin çıtır olması mı gerekiyor?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_FOOD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_FOOD"
msgid "I don't need to chew them up first, do I?"
msgstr "Önce çiğnemem gerekmiyor, değil mi?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_KIT"
msgid "This really is a pop-up carnival."
msgstr "Bu gerçekten bir fırlamalı karganaval."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_NEST
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_NEST"
msgid "It's a little trapdoor."
msgstr "Küçük bir kapan kapağı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_STATION.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_STATION.GENERIC"
msgid "It won't let me play until I give it something shiny."
msgstr "Ona parlak bir şey verene kadar oynamama izin vermiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_STATION.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_FEEDCHICKS_STATION.PLAYING"
msgid "This looks like fun!"
msgstr "Eğlenceli görünüyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_HERDING_CHICK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_HERDING_CHICK"
msgid "Come back here!"
msgstr "Geri gel buraya!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_HERDING_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_HERDING_KIT"
msgid "This really is a pop-up carnival."
msgstr "Bu gerçekten bir fırlamalı karganaval."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_HERDING_STATION.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_HERDING_STATION.GENERIC"
msgid "It won't let me play until I give it something shiny."
msgstr "Ona parlak bir şey verene kadar oynamama izin vermiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_HERDING_STATION.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_HERDING_STATION.PLAYING"
msgid "Those eggs are looking a little runny."
msgstr "O yumurtalar biraz koşar/akar görünüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_CARD.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_CARD.GENERIC"
msgid "It's a little trapdoor."
msgstr "Küçük bir kapan kapağı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_CARD.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_CARD.PLAYING"
msgid "Is this the right one?"
msgstr "Doğru olan bu mu?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_KIT"
msgid "This really is a pop-up carnival."
msgstr "Bu gerçekten bir fırlamalı karganaval."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_STATION.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_STATION.GENERIC"
msgid "It won't let me play until I give it something shiny."
msgstr "Ona parlak bir şey verene kadar oynamama izin vermiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_STATION.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_MEMORY_STATION.PLAYING"
msgid "Not to brag, but I've been called a bit of an egghead in the past."
msgstr "Övünmek gibi olmasın, ama geçmişte bana yumurta-kafa demişlerdi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_PUCKDROP_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_PUCKDROP_KIT"
msgid "This really is a pop-up carnival."
msgstr "Bu gerçekten bir fırlamalı karganaval."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_PUCKDROP_STATION.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_PUCKDROP_STATION.GENERIC"
msgid "It won't let me play until I give it something shiny."
msgstr "Ona parlak bir şey verene kadar oynamama izin vermiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_PUCKDROP_STATION.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_PUCKDROP_STATION.PLAYING"
msgid "Physics don't always work the same way twice."
msgstr "Fizik her zaman aynı şekilde iki kez çalışmaz."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_BUTTON.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_BUTTON.GENERIC"
msgid "It won't let me play until I give it something shiny."
msgstr "Ona parlak bir şey verene kadar oynamama izin vermiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_BUTTON.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_BUTTON.PLAYING"
msgid "Science compels me to press that big shiny button!"
msgstr "Bilim beni o büyük parlak düğmeye basmaya zorluyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_KIT"
msgid "This really is a pop-up carnival."
msgstr "Bu gerçekten bir fırlamalı karganaval."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_STATION.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_STATION.GENERIC"
msgid "It won't let me play until I give it something shiny."
msgstr "Ona parlak bir şey verene kadar oynamama izin vermiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_STATION.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_STATION.PLAYING"
msgid "I could calculate the trajectory, but it involves a lot of complicated numbers and squiggles."
msgstr "Yörüngeyi hesaplayabilirim, ama bir sürü karmaşık sayı ve kıvrım içeriyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_TARGET.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_TARGET.GENERIC"
msgid "It's a little trapdoor."
msgstr "Küçük bir kapan kapağı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_TARGET.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_SHOOTING_TARGET.PLAYING"
msgid "That target's really starting to bug me."
msgstr "O hedef beni böcek gibi sinirlendirmeye başladı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_WHEELSPIN_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_WHEELSPIN_KIT"
msgid "This really is a pop-up carnival."
msgstr "Bu gerçekten bir fırlamalı karganaval."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_WHEELSPIN_STATION.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_WHEELSPIN_STATION.GENERIC"
msgid "It won't let me play until I give it something shiny."
msgstr "Ona parlak bir şey verene kadar oynamama izin vermiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_WHEELSPIN_STATION.PLAYING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVALGAME_WHEELSPIN_STATION.PLAYING"
msgid "It turns out that spinning your wheels is actually very productive."
msgstr "Tekerlekleri boşa çevirmek aslında çok verimliymiş."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_BALL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_BALL"
msgid "It's genius in its simplicity."
msgstr "Sadeliğinde dahiyane."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_CROWKID
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_CROWKID"
msgid "Good day to you, small bird person."
msgstr "Sana iyi günler, küçük kuş kişi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_GAMETOKEN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_GAMETOKEN"
msgid "One shiny token."
msgstr "Bir parlak jeton."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_HOST
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_HOST"
msgid "What an odd fellow."
msgstr "Ne tuhaf bir adam."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PLAZA.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PLAZA.GENERIC"
msgid "It doesn't really scream \"Cawnival\" yet, does it?"
msgstr "Henüz tam olarak \"Karganaval\" diye bağırmıyor, değil mi?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PLAZA.LEVEL_2
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PLAZA.LEVEL_2"
msgid "A little birdy told me it could use some more decorations around here."
msgstr "Bir kuşum, buraya biraz daha süsleme lazım dedi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PLAZA.LEVEL_3
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PLAZA.LEVEL_3"
msgid "This tree is caws for celebration!"
msgstr "Bu ağaç gak-tutarlı bir kutlama nedeni!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PLAZA_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PLAZA_KIT"
msgid "It's a scientifically proven fact that birds love trees."
msgstr "Kuşların ağaçları sevdiği bilimsel olarak kanıtlanmış bir gerçektir."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZEBOOTH.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZEBOOTH.GENERIC"
msgid "I've got my eyes on the prize. That one, over there!"
msgstr "Gözlerim ödülde. Şu, oradaki!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZEBOOTH_KIT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZEBOOTH_KIT"
msgid "The real prize is the booth we made along the way."
msgstr "Asıl ödül, yolda yaptığımız kulübe."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZETICKET.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZETICKET.GENERIC"
msgid "That's the ticket!"
msgstr "İşte bu o bilet!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZETICKET.GENERIC_LARGESTACK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZETICKET.GENERIC_LARGESTACK"
msgid "That's a lot of tickets!"
msgstr "Bu çok bilet!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZETICKET.GENERIC_SMALLSTACK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_PRIZETICKET.GENERIC_SMALLSTACK"
msgid "That's the tickets!"
msgstr "İşte bu biletler!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_SEEDPACKET
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_SEEDPACKET"
msgid "I was feeling a bit peckish."
msgstr "Biraz aç-gagalı hissediyordum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_VEST_A
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_VEST_A"
msgid "I think it makes me look adventurous."
msgstr "Beni maceracı gösterdiğini düşünüyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_VEST_B
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_VEST_B"
msgid "It's like wearing my own shade tree."
msgstr "Sanki kendi gölge ağacımı giyiyorum gibi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_VEST_C
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARNIVAL_VEST_C"
msgid "I hope there's no bugs in it..."
msgstr "Umarım içinde böcek yoktur..."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARPENTRY_BLADE_MOONGLASS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARPENTRY_BLADE_MOONGLASS"
msgid "Razor-sharp, like my mind!"
msgstr "Jilet gibi keskin, zihnim gibi!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARPENTRY_STATION.BURNT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARPENTRY_STATION.BURNT"
msgid "It doesn't make furniture anymore."
msgstr "Artık mobilya yapmıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARPENTRY_STATION.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARPENTRY_STATION.GENERIC"
msgid "It makes furniture."
msgstr "Mobilya yapıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT.DEAD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT.DEAD"
msgid "That's the end of that."
msgstr "İşte bunun sonu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT.GENERIC"
msgid "Are carrots supposed to have legs?"
msgstr "Havuçların bacakları olması gerekiyor mu?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT.HELD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT.HELD"
msgid "You're kind of ugly up close."
msgstr "Yakından biraz çirkinsin."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT.SLEEPING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT.SLEEPING"
msgid "It's almost cute."
msgstr "Neredeyse şirin."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT_GHOSTRACER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARRAT_GHOSTRACER"
msgid "That's... disconcerting."
msgstr "Bu... rahatsız edici."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT"
msgid "Yuck. This vegetable came out of the dirt."
msgstr "Iyy. Bu sebze topraktan çıkmış."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT_COOKED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT_COOKED"
msgid "Mushy."
msgstr "Lapa."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT_OVERSIZED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT_OVERSIZED"
msgid "That's one big bunch of carrots!"
msgstr "Ne büyük bir havuç demeti!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT_PLANTED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT_PLANTED"
msgid "The earth is making plantbabies."
msgstr "Toprak bitki bebekleri yapıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT_SEEDS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARROT_SEEDS"
msgid "It's a seed."
msgstr "Bir tohum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARTOGRAPHYDESK.BURNING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARTOGRAPHYDESK.BURNING"
msgid "So much for that."
msgstr "İşte buna güvenmiştim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARTOGRAPHYDESK.BURNT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARTOGRAPHYDESK.BURNT"
msgid "Nothing but ash now."
msgstr "Şimdi sadece kül."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARTOGRAPHYDESK.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CARTOGRAPHYDESK.GENERIC"
msgid "Now I can show everyone what I found!"
msgstr "Şimdi herkese bulduğumu gösterebilirim!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATCOON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATCOON"
msgid "A playful little thing."
msgstr "Oynak küçük bir şey."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATCOONDEN.EMPTY
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATCOONDEN.EMPTY"
msgid "Its owner ran out of lives."
msgstr "Sahibinin canları tükenmiş."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATCOONDEN.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATCOONDEN.GENERIC"
msgid "It's a den in a stump."
msgstr "Bir kütükte bir in."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATCOONHAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATCOONHAT"
msgid "Ears hat!"
msgstr "Kulaklı şapka!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATTOY_MOUSE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CATTOY_MOUSE"
msgid "Mice with wheels, what will science think up next?"
msgstr "Tekerlekli fareler, bilim sırada ne düşünecek?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVEIN_BOULDER.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVEIN_BOULDER.GENERIC"
msgid "I think I can lift this one."
msgstr "Sanırım bunu kaldırabilirim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVEIN_BOULDER.RAISED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVEIN_BOULDER.RAISED"
msgid "It's out of reach."
msgstr "Erişimimin dışında."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_BANANA
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_BANANA"
msgid "It's mushy."
msgstr "Lapa lapa."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_BANANA_BURNT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_BANANA_BURNT"
msgid "Not my fault!"
msgstr "Benim suçum değil!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_BANANA_COOKED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_BANANA_COOKED"
msgid "Yum!"
msgstr "Mmm!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_BANANA_TREE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_BANANA_TREE"
msgid "It's dubiously photosynthetical."
msgstr "Şüpheli biçimde fotosentetik."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE"
msgid "I wonder if that rock could be moved."
msgstr "Acaba o taş hareket ettirilebilir mi?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE_OPEN.FULL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE_OPEN.FULL"
msgid "I'll have to wait until someone leaves to enter."
msgstr "Girmek için birinin ayrılmasını beklemem gerekecek."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE_OPEN.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE_OPEN.GENERIC"
msgid "The earth itself rejects me!"
msgstr "Toprağın kendisi beni reddediyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE_OPEN.OPEN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE_OPEN.OPEN"
msgid "I bet there's all sorts of things to discover down there."
msgstr "Bahse girerim aşağıda keşfedilecek bir sürü şey vardır."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE_RUINS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_ENTRANCE_RUINS"
msgid "It's probably hiding something."
msgstr "Muhtemelen bir şey saklıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_EXIT.FULL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_EXIT.FULL"
msgid "The surface is too crowded!"
msgstr "Yüzey çok kalabalık!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_EXIT.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_EXIT.GENERIC"
msgid "I'll just stay down here, I suppose."
msgstr "Sanırım burada aşağıda kalacağım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_EXIT.OPEN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_EXIT.OPEN"
msgid "I've had enough discovery for now."
msgstr "Şimdilik yeterince keşif yaptım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_FERN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_FERN"
msgid "It's a fern."
msgstr "Bir eğreltiotu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_FERN_WITHERED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_FERN_WITHERED"
msgid "It's a withered fern."
msgstr "Solmuş bir eğreltiotu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_MITE.DEAD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_MITE.DEAD"
msgid "Out of gas!"
msgstr "Gazı bitti!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_MITE.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_MITE.GENERIC"
msgid "What mite it be?"
msgstr "Ne aka-bilir bu?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_MITE.SLEEPING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_MITE.SLEEPING"
msgid "Careful, it mite wake up."
msgstr "Dikkat, akabilir uyanır."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_MITE.VENTING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_MITE.VENTING"
msgid "It's fuming mad!"
msgstr "Dumanı tüten kadar kızgın!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_ROCK.GAS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_ROCK.GAS"
msgid "That's exhausting."
msgstr "Bu egzoz-tici."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_ROCK.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_ROCK.GENERIC"
msgid "I'm not sure which way it vent."
msgstr "Hangi yöne havalandı emin değilim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_ROCK.HOT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_ROCK.HOT"
msgid "Things are really heating up."
msgstr "İşler gerçekten ısınıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_ROCK.MIASMA
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CAVE_VENT_ROCK.MIASMA"
msgid "What about miasma?"
msgstr "Peki ya miyazma?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CEVICHE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CEVICHE"
