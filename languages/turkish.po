msgstr "Bu gerçekten kedikoon yüzlü bir şapka mı? Yavrulu yavrulu yutturuyorsun!"

#. STRINGS.SKIN_DESCRIPTIONS.hat_chester_costume
msgctxt "STRINGS.SKIN_DESCRIPTIONS.hat_chester_costume"
msgid "They say that imitation is the sincerest form of flattery."
msgstr "Taklit, övgünün en içten biçimidir derler."

#. STRINGS.SKIN_DESCRIPTIONS.hat_chester_costumep
msgctxt "STRINGS.SKIN_DESCRIPTIONS.hat_chester_costumep"
