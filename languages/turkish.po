msgstr "Karımız bitti, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_SNOWBALL_TOO_BIG
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_SNOWBALL_TOO_BIG"
msgid "It won't get any bigger!"
msgstr "Daha büyük olmayacak!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_SOAKED
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_SOAKED"
msgid "I'm going to get all pruney!"
msgstr "Tamamen kırışık olacağım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_SPOOKED
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_SPOOKED"
msgid "Yikes! That gave me quite the start!"
msgstr "Eyvah! Beni epey ürküttü bu!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_STORYTELLING_ABORT_FIREWENTOUT.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_STORYTELLING_ABORT_FIREWENTOUT.1"
msgid "Darnit, the fire went out right at the best part!"
msgstr "Lanet olsun, ateş tam en iyi yerinde söndü!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_STORYTELLING_ABORT_NOT_NIGHT.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_STORYTELLING_ABORT_NOT_NIGHT.1"
msgid "To be continued..."
msgstr "Devamı gelecek..."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.1"
msgid "Hey! Do you guys want to hear a story?"
msgstr "Hey! Hikâye dinlemek ister misiniz?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.2"
msgid "You're doing great, plants! Keep it up!"
msgstr "Harika gidiyorsunuz, bitkiler! Devam edin!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.3"
msgid "Don't worry, I'll be here to talk to you whenever you get lonely."
msgstr "Merak etmeyin, ne zaman yalnız hissederseniz konuşmak için burada olacağım."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.4
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.4"
msgid "How are you doing today plants? Seen any new bugs lately?"
msgstr "Bugün nasılsınız bitkiler? Son zamanlarda yeni böcekler gördünüz mü?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.5
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TALK_TO_PLANTS.5"
msgid "It's good to have someone to talk to. Thanks plants!"
msgstr "Konuşacak birinin olması güzel. Teşekkürler bitkiler!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_THORNS
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_THORNS"
msgid "Aaah!! Ow!! It hurts! Were those poisonous?!"
msgstr "Aaah!! Of!! Acıyor! Onlar zehirli miydi?!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_THURIBLE_OUT
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_THURIBLE_OUT"
msgid "I think it's out of fuel."
msgstr "Sanırım yakıtı bitti."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_ABANDONED
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_ABANDONED"
msgid "I think Woby and I can sniff them out on our own."
msgstr "Sanırım Woby ve ben onları kendi başımıza koklayıp bulabiliriz."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_DEAD
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_DEAD"
msgid "I-it's okay Woby, he's just taking a nap! Let's keep going."
msgstr "S-sorun yok Woby, sadece şekerleme yapıyor! Devam edelim."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_GET_LEADER_ATTENTION
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_GET_LEADER_ATTENTION"
msgid "Look Woby, I think he's trying to get our attention!"
msgstr "Bak Woby, sanırım dikkatimizi çekmeye çalışıyor!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_LOST_KITCOON
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_LOST_KITCOON"
msgid "I guess he lost the scent."
msgstr "Sanırım kokuyu kaybetti."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_NEAR_KITCOON
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_NEAR_KITCOON"
msgid "I think he smells something nearby!"
msgstr "Sanırım yakınlarda bir şey kokluyor!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_NOTHING_TO_TRACK
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_NOTHING_TO_TRACK"
msgid "It doesn't look like he's picking up any scents."
msgstr "Hiçbir koku alıyor gibi görünmüyor."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_START_TRACKING
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_START_TRACKING"
msgid "I think he knows the way!"
msgstr "Sanırım yolu biliyor!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_WAITING_FOR_LEADER
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TICOON_WAITING_FOR_LEADER"
msgid "Wait up! I'm coming!"
msgstr "Bekle! Geliyorum!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOADESCAPED
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOADESCAPED"
msgid "Darnit... he got away."
msgstr "Lanet olsun... kaçtı."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOADESCAPING
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOADESCAPING"
msgid "Hey wait! Come back!"
msgstr "Hey dur! Geri gel!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOOL_SLIP
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOOL_SLIP"
msgid "I- I meant to do that!"
msgstr "B-bunu kasten yaptım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOOL_TOOWEAK
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOOL_TOOWEAK"
msgid "It's okay Woby, we just need to find a stronger tool!"
msgstr "Sorun yok Woby, sadece daha güçlü bir alet bulmamız lazım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TORCH_OUT
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TORCH_OUT"
msgid "Uh oh... this is usually the part when something bad happens."
msgstr "Eyvah... genelde kötü bir şey olan kısım burası."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOWNPORTALTELEPORT
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TOWNPORTALTELEPORT"
msgid "Do you think I'll be the same person when I come out the other side?"
msgstr "Sence öbür taraftan çıktığımda aynı kişi mi olacağım?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_TRAP_WENT_OFF
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_TRAP_WENT_OFF"
msgid "It looked way easier in my handbook..."
msgstr "El kitabımda çok daha kolay görünüyordu..."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_UNIMPLEMENTED
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_UNIMPLEMENTED"
msgid "I don't think it's done yet."
msgstr "Sanırım henüz bitmemiş."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_VAULT_TELEPORTER_DOES_NOTHING
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_VAULT_TELEPORTER_DOES_NOTHING"
msgid "I don't know, Woby! Must be a bad connection!"
msgstr "Bilmiyorum, Woby! Bağlantı kötü olmalı!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WASHED_ASHORE
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WASHED_ASHORE"
msgid "Woby...? Oh good, you're okay!"
msgstr "Woby...? Ah ne güzel, iyisin!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WEAK_RAT
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WEAK_RAT"
msgid "This carrat doesn't look healthy..."
msgstr "Bu havufare sağlıklı görünmüyor..."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WEAPON_TOOWEAK
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WEAPON_TOOWEAK"
msgid "We need something stronger, Woby!"
msgstr "Daha güçlü bir şeye ihtiyacımız var, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WEIGHT
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WEIGHT"
msgid "Weight: {weight}"
msgstr "Ağırlık: {weight}"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WEIGHT_HEAVY
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WEIGHT_HEAVY"
msgid "Weight: {weight}\nIs there a badge for heaviest fish?"
msgstr "Ağırlık: {weight}\nEn ağır balık için rozet var mı?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WENDY_BABYSITTER_SET
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WENDY_BABYSITTER_SET"
msgid "only_used_by_wendy"
msgstr "only_used_by_wendy"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WENDY_BABYSITTER_STOP
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WENDY_BABYSITTER_STOP"
msgid "only_used_by_wendy"
msgstr "only_used_by_wendy"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WET
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WET"
msgid "This is starting to get uncomfortable."
msgstr "Bu rahatsız edici olmaya başlıyor."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WETTER
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WETTER"
msgid "Did anyone remember to pack a towel?"
msgstr "Havlu almayı hatırlayan oldu mu?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WINCH_CLAW_MISS
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WINCH_CLAW_MISS"
msgid "Next time I'll get it!"
msgstr "Bir dahaki sefere yakalayacağım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WINCH_CLAW_NO_ITEM
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WINCH_CLAW_NO_ITEM"
msgid "What? Nothing?"
msgstr "Ne? Hiçbir şey mi?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WINTERS_FEAST_BUFF
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WINTERS_FEAST_BUFF"
msgid "It almost feels like I'm back home."
msgstr "Neredeyse evime dönmüşüm gibi hissediyorum."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WINTERS_FEAST_BUFF_OVER
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WINTERS_FEAST_BUFF_OVER"
msgid "Well, that was fun!"
msgstr "Eh, eğlenceliydi!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.1"
msgid "Go, Woby! Go!"
msgstr "Git, Woby! Git!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.2"
msgid "Off you go! And don't get distracted, silly girl!"
msgstr "Hadi bakalım! Ve dikkatin dağılmasın, sersem kız!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.3"
msgid "Go on, Wobes!"
msgstr "Hadi, Wobes!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.4
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.4"
msgid "Be careful out there, Woby!"
msgstr "Dışarda dikkatli ol, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.5
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.5"
msgid "Don't get lost, Wobers!"
msgstr "Kaybolma, Wobers!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.6
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.6"
msgid "And away she goes!"
msgstr "Ve işte gidiyor!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.7
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.7"
msgid "On your way now, girl!"
msgstr "Hadi yola koyul, kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.8
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_COURIER.8"
msgid "Woby, follow your nose! It knows! Heh."
msgstr "Woby, burnunu takip et! O bilir! Heh."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.1"
msgid "Woby, come!"
msgstr "Woby, gel!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.2"
msgid "Follow me, girl!"
msgstr "Beni takip et, kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.3"
msgid "With me, Wobes!"
msgstr "Yanımda, Wobes!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.4
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.4"
msgid "Come on, Wobers! Let's go!"
msgstr "Hadi, Wobers! Gidelim!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.5
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FOLLOW.5"
msgid "Keep up, Woby!"
msgstr "Yetiş, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FORAGE.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FORAGE.1"
msgid "Find more of these, Woby!"
msgstr "Bunlardan daha fazla bul, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FORAGE.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FORAGE.2"
msgid "Help get us more, girl!"
msgstr "Daha fazlasını almamıza yardım et, kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FORAGE.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FORAGE.3"
msgid "Woby, just like these ones."
msgstr "Woby, aynen bunlar gibi."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FORAGE.4
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_FORAGE.4"
msgid "Look for these, Woby."
msgstr "Bunları ara, Woby."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.1"
msgid "Good girl!"
msgstr "Aferin kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.10
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.10"
msgid "You're the best best friend, Woby."
msgstr "Sen en iyi en iyi dostsun, Woby."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.11
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.11"
msgid "I'm so proud of you!"
msgstr "Seninle gurur duyuyorum!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.12
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.12"
msgid "Alright, Wobes!"
msgstr "Pekâlâ, Wobes!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.13
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.13"
msgid "Woby the Wonderdog!"
msgstr "Harika Köpek Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.14
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.14"
msgid "Woah, Woby! Heh."
msgstr "Vay, Woby! Heh."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.2"
msgid "Thanks, Woby!"
msgstr "Teşekkürler, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.3"
msgid "Atta girl, Wobers!"
msgstr "Aferin kızım, Wobers!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.4
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.4"
msgid "You're the best, Woby!"
msgstr "Sen en iyisisin, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.5
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.5"
msgid "Yay, Woby!"
msgstr "Yaşasın, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.6
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.6"
msgid "Awww... sweet girl, Wobes."
msgstr "Aaay... tatlı kızım, Wobes."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.7
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.7"
msgid "Nice one, girl!"
msgstr "Aferin sana, kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.8
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.8"
msgid "Who's the smartest, Wobers? Yup, it's you!"
msgstr "En zeki kim, Wobers? Evet, sensin!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.9
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_PRAISE.9"
msgid "I love you, silly girl!"
msgstr "Seni seviyorum, sersem kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_REMEMBERCHEST_FAIL.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_REMEMBERCHEST_FAIL.1"
msgid "Let's find a better spot, Woby."
msgstr "Daha iyi bir yer bulalım, Woby."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_REMEMBERCHEST_FAIL.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_REMEMBERCHEST_FAIL.2"
msgid "Not here, silly girl!"
msgstr "Burada değil, sersem kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_REMEMBERCHEST_FAIL.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_REMEMBERCHEST_FAIL.3"
msgid "We should try somewhere else."
msgstr "Başka bir yerde denesek iyi olur."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.1"
msgid "Wooooooby!"
msgstr "Wooooooby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.2"
msgid "Come here, girl!"
msgstr "Buraya gel, kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.3"
msgid "Woby, over here!"
msgstr "Woby, buradayım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.4
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.4"
msgid "Get over here, silly girl!"
msgstr "Buraya gel, sersem kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.5
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.5"
msgid "Hurry up, Wobers!"
msgstr "Acele et, Wobers!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.6
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_RETURN.6"
msgid "Shake a leg, Wobes!"
msgstr "Hızlan, Wobes!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.1"
msgid "Woby, stay!"
msgstr "Woby, dur!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.2"
msgid "Stay, girl!"
msgstr "Dur, kızım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.3"
msgid "Take a break, Wobers!"
msgstr "Mola ver, Wobers!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.4
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.4"
msgid "Stay, Wobes! That's it."
msgstr "Dur, Wobes! İşte böyle."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.5
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_SIT.5"
msgid "Paws here Woby! Heh."
msgstr "Patiler buraya Woby! Heh."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.1"
msgid "Woby, come help me!"
msgstr "Woby, gel bana yardım et!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.2"
msgid "Lend a paw, girl! Heh."
msgstr "Pati ver, kızım! Heh."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.3"
msgid "Wanna help, Wobes?"
msgstr "Yardım etmek ister misin, Wobes?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.4
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.4"
msgid "You gotta minute, Woby?"
msgstr "Bir dakikan var mı, Woby?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.5
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOBY_WORK.5"
msgid "Who's my special helper?"
msgstr "Benim özel yardımcım kim?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOLFGANG_BEGIN_COACHING
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_WOLFGANG_BEGIN_COACHING"
msgid "only_used_by_wolfgang"
