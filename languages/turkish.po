msgstr "Merak etmeyin kediciklerim, bunu bir çırpıda birleştiririm!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOONDEN.BURNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOONDEN.BURNT"
