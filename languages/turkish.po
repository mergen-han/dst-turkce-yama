#. STRINGS.BOARLORD_PLAYERDEATH_BANTER.1
msgctxt "STRINGS.BOARLORD_PLAYERDEATH_BANTER.1"
msgid "Ha!"
msgstr "Ha!"

#. STRINGS.BOARLORD_PLAYERDEATH_BANTER.2
msgctxt "STRINGS.BOARLORD_PLAYERDEATH_BANTER.2"
msgid "You are unworthy."
msgstr "Layık değilsiniz."

#. STRINGS.BOARLORD_PLAYERDEATH_BANTER.3
msgctxt "STRINGS.BOARLORD_PLAYERDEATH_BANTER.3"
msgid "You never stood a chance."
msgstr "Hiç şansınız yoktu."

#. STRINGS.BOARLORD_PLAYERDEATH_BANTER.4
msgctxt "STRINGS.BOARLORD_PLAYERDEATH_BANTER.4"
msgid "Ha ha!"
msgstr "Ha ha!"

#. STRINGS.BOARLORD_PLAYERDEATH_BANTER.5
msgctxt "STRINGS.BOARLORD_PLAYERDEATH_BANTER.5"
msgid "Weak."
msgstr "Zayıf."

#. STRINGS.BOARLORD_PLAYERDEATH_BANTER.6
msgctxt "STRINGS.BOARLORD_PLAYERDEATH_BANTER.6"
msgid "We are stronger."
msgstr "Biz daha güçlüyüz."

#. STRINGS.BOARLORD_PLAYERDEATH_BANTER.7
msgctxt "STRINGS.BOARLORD_PLAYERDEATH_BANTER.7"
msgid "Well struck!"
msgstr "Güzel vuruş!"

#. STRINGS.BOARLORD_PLAYERS_DEFEATED_BATTLECRY.1
msgctxt "STRINGS.BOARLORD_PLAYERS_DEFEATED_BATTLECRY.1"
msgid "At last, our realm returns to glory!"
msgstr "Sonunda diyarımız ihtişamına kavuşuyor!"

#. STRINGS.BOARLORD_PLAYERS_DEFEATED_BATTLECRY.2
msgctxt "STRINGS.BOARLORD_PLAYERS_DEFEATED_BATTLECRY.2"
msgid "Warriors, rekindle the Gateway..."
msgstr "Savaşçılar, Geçit'i yeniden tutuşturun..."

#. STRINGS.BOARLORD_PLAYERS_DEFEATED_BATTLECRY.3
msgctxt "STRINGS.BOARLORD_PLAYERS_DEFEATED_BATTLECRY.3"
msgid "Today we take the Throne!"
msgstr "Bugün Taht'ı ele geçiriyoruz!"

#. STRINGS.BOARLORD_ROUND1_FIGHT_BANTER.1
msgctxt "STRINGS.BOARLORD_ROUND1_FIGHT_BANTER.1"
msgid "It's good to have a challenge once again!"
msgstr "Yeniden bir meydan okuyan görmek güzel!"

#. STRINGS.BOARLORD_ROUND1_FIGHT_BANTER.2
msgctxt "STRINGS.BOARLORD_ROUND1_FIGHT_BANTER.2"
msgid "This should be fun."
msgstr "Bu eğlenceli olacak."

#. STRINGS.BOARLORD_ROUND1_FIGHT_BANTER.3
msgctxt "STRINGS.BOARLORD_ROUND1_FIGHT_BANTER.3"
msgid "More pigs! Overwhelm them!"
msgstr "Daha çok domuz! Onları altedin!"

#. STRINGS.BOARLORD_ROUND1_FIGHT_BANTER.4
msgctxt "STRINGS.BOARLORD_ROUND1_FIGHT_BANTER.4"
msgid "More pigs!"
msgstr "Daha çok domuz!"

#. STRINGS.BOARLORD_ROUND1_START.1
msgctxt "STRINGS.BOARLORD_ROUND1_START.1"
msgid "What have we here?"
msgstr "Karşımızda ne varmış bakalım?"

#. STRINGS.BOARLORD_ROUND1_START.2
msgctxt "STRINGS.BOARLORD_ROUND1_START.2"
msgid "Gatekeepers? Ha! Have you come to return us to the Throne?"
msgstr "Geçit Bekçileri mi? Ha! Bizi Taht'a döndürmeye mi geldiniz?"

#. STRINGS.BOARLORD_ROUND1_START.3
msgctxt "STRINGS.BOARLORD_ROUND1_START.3"
msgid "I am Battlemaster Pugna, and I protect what is mine."
msgstr "Ben Savaş Ustası Pugna; benim olanı korurum."

#. STRINGS.BOARLORD_ROUND1_START.4
msgctxt "STRINGS.BOARLORD_ROUND1_START.4"
msgid "Warriors. Release the pigs!"
msgstr "Savaşçılar. Domuzları salın!"

#. STRINGS.BOARLORD_ROUND2_FIGHT_BANTER.1
msgctxt "STRINGS.BOARLORD_ROUND2_FIGHT_BANTER.1"
msgid "For the Forge!"
msgstr "Demirhane için!"

#. STRINGS.BOARLORD_ROUND2_FIGHT_BANTER.2
msgctxt "STRINGS.BOARLORD_ROUND2_FIGHT_BANTER.2"
msgid "Give the Gatekeepers no quarter!"
msgstr "Geçit Bekçilerine aman vermeyin!"

#. STRINGS.BOARLORD_ROUND2_FIGHT_BANTER.3
msgctxt "STRINGS.BOARLORD_ROUND2_FIGHT_BANTER.3"
msgid "Fly your banners proudly, warriors!"
msgstr "Sancaklarınızı gururla dalgalandırın, savaşçılar!"

#. STRINGS.BOARLORD_ROUND2_START.1
msgctxt "STRINGS.BOARLORD_ROUND2_START.1"
msgid "Impressive. You handled our foot soldiers with ease."
msgstr "Etkileyici. Piyade askerlerimizle kolayca baş ettiniz."

#. STRINGS.BOARLORD_ROUND2_START.2
msgctxt "STRINGS.BOARLORD_ROUND2_START.2"
msgid "But our battalions are trained to work together."
msgstr "Ama bizim taburlarımız birlikte çalışmaya eğitildi."

#. STRINGS.BOARLORD_ROUND2_START.3
msgctxt "STRINGS.BOARLORD_ROUND2_START.3"
msgid "Can you do the same? Crocommanders, to the ring!"
msgstr "Siz de aynısını yapabilir misiniz? Timsahkomutanlar, arenaya!"

#. STRINGS.BOARLORD_ROUND3_START.1
msgctxt "STRINGS.BOARLORD_ROUND3_START.1"
msgid "We've endured more here than you know."
msgstr "Burada bilmediğiniz nice acılara katlandık."

#. STRINGS.BOARLORD_ROUND3_START.2
msgctxt "STRINGS.BOARLORD_ROUND3_START.2"
msgid "And as forging fires temper steel,"
msgstr "Ve döven ateş çeliği nasıl tavlarsa,"

#. STRINGS.BOARLORD_ROUND3_START.3
msgctxt "STRINGS.BOARLORD_ROUND3_START.3"
msgid "Hardship has only made us stronger."
msgstr "Çile bizi yalnızca daha da güçlendirdi."

#. STRINGS.BOARLORD_ROUND3_START.4
msgctxt "STRINGS.BOARLORD_ROUND3_START.4"
msgid "Now, Snortoises. Attack!"
msgstr "Şimdi, Horultaplumbağalar. Saldırın!"

#. STRINGS.BOARLORD_ROUND4_FIGHT_BANTER.1
msgctxt "STRINGS.BOARLORD_ROUND4_FIGHT_BANTER.1"
msgid "End this now my warriors!"
msgstr "Buna bir son verin, savaşçılarım!"

#. STRINGS.BOARLORD_ROUND4_FIGHT_BANTER.2
msgctxt "STRINGS.BOARLORD_ROUND4_FIGHT_BANTER.2"
msgid "We... cannot lose the Forge..."
msgstr "Demirhane'yi... kaybedemeyiz..."

#. STRINGS.BOARLORD_ROUND4_PLAYER_VICTORY.1
msgctxt "STRINGS.BOARLORD_ROUND4_PLAYER_VICTORY.1"
msgid "No! How can this be?!"
msgstr "Hayır! Bu nasıl olabilir?!"

#. STRINGS.BOARLORD_ROUND4_PLAYER_VICTORY.2
msgctxt "STRINGS.BOARLORD_ROUND4_PLAYER_VICTORY.2"
msgid "You have defeated the mighty Boarilla!"
msgstr "Kudretli Yabongoril'i alt ettiniz!"

#. STRINGS.BOARLORD_ROUND4_PLAYER_VICTORY.3
msgctxt "STRINGS.BOARLORD_ROUND4_PLAYER_VICTORY.3"
msgid "You may have won the battle, Gatekeepers... but not the war!"
msgstr "Savaşı kazanmış olabilirsiniz, Geçit Bekçileri... ama harbi değil!"

#. STRINGS.BOARLORD_ROUND4_START.1
msgctxt "STRINGS.BOARLORD_ROUND4_START.1"
msgid "...Do you understand the forces you serve?"
msgstr "...Hizmet ettiğiniz güçleri anlıyor musunuz?"

#. STRINGS.BOARLORD_ROUND4_START.2
msgctxt "STRINGS.BOARLORD_ROUND4_START.2"
msgid "They destroy all They touch..."
msgstr "Dokundukları her şeyi yok ediyorlar..."

#. STRINGS.BOARLORD_ROUND4_START.3
msgctxt "STRINGS.BOARLORD_ROUND4_START.3"
msgid "We were severed from the Throne, trapped in a realm of stone and fire!"
msgstr "Taht'tan koparıldık, taşın ve ateşin diyarına hapsolduk!"

#. STRINGS.BOARLORD_ROUND4_START.4
msgctxt "STRINGS.BOARLORD_ROUND4_START.4"
msgid "That is why we cannot let you win."
msgstr "İşte bu yüzden kazanmanıza izin veremeyiz."

#. STRINGS.BOARLORD_ROUND4_TRAILS_INTRO.1
msgctxt "STRINGS.BOARLORD_ROUND4_TRAILS_INTRO.1"
msgid "Send in the Boarilla."
msgstr "Yabongoril'i meydana sürün."

#. STRINGS.BOARLORD_ROUND5_BOARRIOR_INTRO.1
msgctxt "STRINGS.BOARLORD_ROUND5_BOARRIOR_INTRO.1"
msgid "Grand Forge Boarrior!"
msgstr "Yüce Demirhane Yabansavaşçısı!"

#. STRINGS.BOARLORD_ROUND5_BOARRIOR_INTRO.2
msgctxt "STRINGS.BOARLORD_ROUND5_BOARRIOR_INTRO.2"
msgid "The ring is yours! Destroy them, my champion!"
msgstr "Meydan senindir! Yok et onları, şampiyonum!"

#. STRINGS.BOARLORD_ROUND5_FIGHT_BANTER1.1
msgctxt "STRINGS.BOARLORD_ROUND5_FIGHT_BANTER1.1"
msgid "The Gatekeepers must not take the Forge!"
msgstr "Geçit Bekçileri Demirhane'yi ele geçirmemeli!"

#. STRINGS.BOARLORD_ROUND5_FIGHT_BANTER1.2
msgctxt "STRINGS.BOARLORD_ROUND5_FIGHT_BANTER1.2"
msgid "Drive the interlopers back!"
msgstr "Mütecavizleri geri püskürtün!"

#. STRINGS.BOARLORD_ROUND5_FIGHT_BANTER1.3
msgctxt "STRINGS.BOARLORD_ROUND5_FIGHT_BANTER1.3"
msgid "Do not hold back! Kill them!"
msgstr "Kendinizi tutmayın! Öldürün onları!"

#. STRINGS.BOARLORD_ROUND5_FIGHT_BANTER2.1
msgctxt "STRINGS.BOARLORD_ROUND5_FIGHT_BANTER2.1"
msgid "Why are the Gatekeepers still not dead?!"
msgstr "Geçit Bekçileri neden hâlâ ölmedi?!"

#. STRINGS.BOARLORD_ROUND5_FIGHT_BANTER2.2
msgctxt "STRINGS.BOARLORD_ROUND5_FIGHT_BANTER2.2"
msgid "Destroy them!!"
msgstr "Yok edin onları!!"

#. STRINGS.BOARLORD_ROUND5_FIGHT_BANTER2.3
msgctxt "STRINGS.BOARLORD_ROUND5_FIGHT_BANTER2.3"
msgid "We will not live in the Throne's shadow!"
msgstr "Taht'ın gölgesinde yaşamayacağız!"

#. STRINGS.BOARLORD_ROUND5_PLAYER_VICTORY.1
msgctxt "STRINGS.BOARLORD_ROUND5_PLAYER_VICTORY.1"
msgid "What?! My champion!?!"
msgstr "Ne?! Şampiyonum!?!"

#. STRINGS.BOARLORD_ROUND5_PLAYER_VICTORY.2
msgctxt "STRINGS.BOARLORD_ROUND5_PLAYER_VICTORY.2"
msgid "I see. You've demonstrated your might."
msgstr "Anlıyorum. Kudretinizi kanıtladınız."

#. STRINGS.BOARLORD_ROUND5_PLAYER_VICTORY.3
msgctxt "STRINGS.BOARLORD_ROUND5_PLAYER_VICTORY.3"
msgid "...But we will live to fight again!!"
msgstr "...Ama yine savaşmak için yaşayacağız!!"

#. STRINGS.BOARLORD_ROUND5_START.1
msgctxt "STRINGS.BOARLORD_ROUND5_START.1"
msgid "Know this, Gatekeepers:"
msgstr "Şunu bilin, Geçit Bekçileri:"

#. STRINGS.BOARLORD_ROUND5_START.2
msgctxt "STRINGS.BOARLORD_ROUND5_START.2"
msgid "Once you are dead, we will activate the Gateway."
msgstr "Siz öldüğünüzde, Geçit'i etkinleştireceğiz."

#. STRINGS.BOARLORD_ROUND5_START.3
msgctxt "STRINGS.BOARLORD_ROUND5_START.3"
msgid "We'll return to the hub and destroy the Throne."
msgstr "Merkeze döneceğiz ve Taht'ı yok edeceğiz."

#. STRINGS.BOARLORD_ROUND5_START.4
msgctxt "STRINGS.BOARLORD_ROUND5_START.4"
msgid "We will end this, once and for all."
msgstr "Buna ebediyen son vereceğiz."

#. STRINGS.BOARLORD_ROUND6_PLAYER_VICTORY.1
msgctxt "STRINGS.BOARLORD_ROUND6_PLAYER_VICTORY.1"
msgid "You have won the battle,"
msgstr "Savaşı kazandınız,"

#. STRINGS.BOARLORD_ROUND6_PLAYER_VICTORY.2
msgctxt "STRINGS.BOARLORD_ROUND6_PLAYER_VICTORY.2"
msgid "But the war rages on eternally."
msgstr "Ama harp ebediyen sürer."

#. STRINGS.BOARLORD_ROUND6_PLAYER_VICTORY.3
msgctxt "STRINGS.BOARLORD_ROUND6_PLAYER_VICTORY.3"
msgid "We are not ready to give up yet."
msgstr "Henüz pes etmeye hazır değiliz."

#. STRINGS.BOARLORD_ROUND6_START.1
msgctxt "STRINGS.BOARLORD_ROUND6_START.1"
msgid "We do not fear you."
msgstr "Sizden korkmuyoruz."

#. STRINGS.BOARLORD_ROUND6_START.2
msgctxt "STRINGS.BOARLORD_ROUND6_START.2"
msgid "But you will fear us!"
msgstr "Ama siz bizden korkacaksınız!"

#. STRINGS.BOARLORD_ROUND6_START.3
msgctxt "STRINGS.BOARLORD_ROUND6_START.3"
msgid "Fear my new champions! Fear the Rhinocebros!"
msgstr "Yeni şampiyonlarımdan korkun! Gergedankardeşler'den korkun!"

#. STRINGS.BOARLORD_ROUND7_PLAYER_VICTORY.1
msgctxt "STRINGS.BOARLORD_ROUND7_PLAYER_VICTORY.1"
msgid "No! My Forge, felled by the Throne's lapdogs!"
msgstr "Hayır! Demirhane'm, Taht'ın yalakaları tarafından yıkıldı!"

#. STRINGS.BOARLORD_ROUND7_PLAYER_VICTORY.2
msgctxt "STRINGS.BOARLORD_ROUND7_PLAYER_VICTORY.2"
msgid "Please. No more, Gatekeepers. We surrender."
msgstr "Lütfen. Yeter, Geçit Bekçileri. Teslim oluyoruz."

#. STRINGS.BOARLORD_ROUND7_PLAYER_VICTORY.3
msgctxt "STRINGS.BOARLORD_ROUND7_PLAYER_VICTORY.3"
msgid "The day is yours, as is the Gateway."
msgstr "Gün de Geçit de sizindir."

#. STRINGS.BOARLORD_ROUND7_START.1
msgctxt "STRINGS.BOARLORD_ROUND7_START.1"
msgid "You have had many victories, Gatekeepers..."
msgstr "Birçok zafer kazandınız, Geçit Bekçileri..."

#. STRINGS.BOARLORD_ROUND7_START.2
msgctxt "STRINGS.BOARLORD_ROUND7_START.2"
msgid "...but from our dungeons comes our most brutal warrior."
msgstr "...ama zindanlarımızdan en vahşi savaşçımız geliyor."

#. STRINGS.BOARLORD_ROUND7_START.3
msgctxt "STRINGS.BOARLORD_ROUND7_START.3"
msgid "Behold: The Infernal Swineclops!"
msgstr "İşte karşınızda: Cehennemi Domuzgöz!"

