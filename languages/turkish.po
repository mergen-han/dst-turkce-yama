msgstr "Satranç taşları kendi başlarına hareket ediyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BUTTERFLY
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BUTTERFLY"
msgid "It looks nice, doesn't it?"
msgstr "Hoş görünüyor, değil mi?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CARRAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CARRAT"
msgid "We have a winner!"
msgstr "Kazananımız var!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CATCOON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CATCOON"
msgid "It would probably make a great scratching post."
msgstr "Muhtemelen harika bir tırnaklama direği olurdu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CLAYHOUND
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CLAYHOUND"
msgid "That thing's the leashed of my worries."
msgstr "O şey, en tasmasız kaygım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CLAYWARG
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CLAYWARG"
msgid "And I didn't even get eaten!"
msgstr "Ve yenmedim bile!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CRABKING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_CRABKING"
msgid "Still not as crabby as Maxwell."
msgstr "Yine de Maxwell kadar yengeç-suratlı değil."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DAYWALKER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DAYWALKER"
msgid "Now he's off who-knows-were."
msgstr "Şimdi gözden uzak, kim bilir nere-deydi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DAYWALKER2
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DAYWALKER2"
msgid "This belongs in a junkpile!"
msgstr "Bu hurda yığınında olmalı!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DEERCLOPS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DEERCLOPS"
msgid "It feels like its eye follows you."
msgstr "Gözünün seni takip ettiğini hissediyorsun."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DEERCLOPS_MUTATED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DEERCLOPS_MUTATED"
msgid "This sculpture is a bit of an eyesore."
msgstr "Bu heykel biraz göz tırmalayıcı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DEPTHWORM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DEPTHWORM"
msgid "It's a worm, figures."
msgstr "Bir solucan, tabii ki."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DRAGONFLY
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_DRAGONFLY"
msgid "Ah, that brings back memories. Bad ones."
msgstr "Ah, anılar tazelendi. Kötü olanlar."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_EYEOFTERROR
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_EYEOFTERROR"
msgid "It's giving me a stony stare."
msgstr "Bana taş gibi sert bir bakış atıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_FORMAL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_FORMAL"
msgid "Doesn't seem very \"kingly\" to me."
msgstr "Bana pek \"krallık\" gibi görünmüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_GUARDIANPHASE3
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_GUARDIANPHASE3"
msgid "I much prefer it this way."
msgstr "Bunu böyle çok daha çok seviyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_HORNUCOPIA
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_HORNUCOPIA"
msgid "Makes my stomach rumble just looking at it."
msgstr "Bakmak bile karnımı guruldatıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_KITCOON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_KITCOON"
msgid "These ones are much easier to find."
msgstr "Bunları bulmak çok daha kolay."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_KLAUS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_KLAUS"
msgid "Can I invoke the \"no holiday decorations\" Klaus?"
msgstr "\"Tatil dekorasyonu yok\" Klaus'unu çağırabilir miyim?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_KNIGHT.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_KNIGHT.GENERIC"
msgid "It's a horse, of course."
msgstr "At, tabii ki at."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_KNIGHT.STRUGGLE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_KNIGHT.STRUGGLE"
msgid "The chess pieces are moving themselves!"
msgstr "Satranç taşları kendi başlarına hareket ediyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MALBATROSS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MALBATROSS"
