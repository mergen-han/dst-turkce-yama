msgstr "Ateşle gerçekten \"dövüşemezsin\", %s!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.WOLFGANG.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.WOLFGANG.GENERIC"
