msgstr "Yumurtadan çıkması için sabırsızlanıyorum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAE_EGG_CRACKED.COLD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAE_EGG_CRACKED.COLD"
msgid "It needs more warmth!"
msgstr "Daha fazla sıcaklığa ihtiyacı var!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAE_EGG_CRACKED.COMFY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAE_EGG_CRACKED.COMFY"
