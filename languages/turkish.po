msgstr "Geçit dengesini kaybediyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_GATE.OFF
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_GATE.OFF"
