msgstr "Bir kabağın sırıtışı, titrek bir ışık, hayaletlere Cadılar Gecesi boyunca rehberlik eder."

#. STRINGS.SKIN_DESCRIPTIONS.mushroom_light2_lily
msgctxt "STRINGS.SKIN_DESCRIPTIONS.mushroom_light2_lily"
