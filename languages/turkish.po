msgstr "Kardeşin beni biraz ürkütüyor ama sen iyisin!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL2.2
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL2.2"
msgid "Your sister kind of creeps me out, but you're alright!"
msgstr "Kardeşin beni biraz ürkütüyor ama sen iyisin!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL3.1
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL3.1"
msgid "Your sister kind of creeps me out, but you're alright!"
msgstr "Kardeşin beni biraz ürkütüyor ama sen iyisin!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL3.2
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL.LEVEL3.2"
msgid "Your sister kind of creeps me out, but you're alright!"
msgstr "Kardeşin beni biraz ürkütüyor ama sen iyisin!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.GENERIC"
msgid "Did that flower just whisper something?"
msgstr "O çiçek bir şey mi fısıldadı?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.HAUNTED_GROUND
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.HAUNTED_GROUND"
msgid "I'd die to find out what it does."
msgstr "Ne yaptığını öğrenmek için ölürüm."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.HAUNTED_POCKET
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.HAUNTED_POCKET"
msgid "I don't think I should hang on to this."
msgstr "Bunu yanımda tutmamam gerek galiba."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.LEVEL1
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.LEVEL1"
msgid "Oh, Abigail! I didn't recognize you."
msgstr "Ah, Abigail! Seni tanıyamadım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.LEVEL2
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.LEVEL2"
msgid "Don't eat the haunted flower, Woby!"
msgstr "Perili çiçeği yeme, Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.LEVEL3
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.LEVEL3"
msgid "You're not really as spooky when you're a flower."
msgstr "Çiçek olunca o kadar da ürkütücü değilsin."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.LONG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.LONG"
msgid "It hurts my soul to look at that thing."
msgstr "O şeye bakmak ruhumu acıtıyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.MEDIUM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.MEDIUM"
msgid "It's giving me the creeps."
msgstr "Tüylerimi diken diken ediyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.SOON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABIGAIL_FLOWER.SOON"
msgid "Something is up with that flower!"
msgstr "O çiçekte bir şeyler dönüyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABYSSPILLAR_MINION.ACTIVATED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABYSSPILLAR_MINION.ACTIVATED"
msgid "Hey, it moves when I move!"
msgstr "Hey, ben hareket edince hareket ediyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABYSSPILLAR_MINION.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABYSSPILLAR_MINION.GENERIC"
msgid "So creepy!"
msgstr "Çok ürkütücü!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ABYSSPILLAR_TRIAL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ABYSSPILLAR_TRIAL"
msgid "Great idea, Woby! Let's pull it!"
msgstr "Harika fikir, Woby! Hadi çekelim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ACCOMPLISHMENT_SHRINE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ACCOMPLISHMENT_SHRINE"
msgid "I love checking tasks off a list!"
msgstr "Listedeki görevleri silmeyi çok severim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ACORN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ACORN"
msgid "I wonder if there's any squirrels around."
msgstr "Acaba etrafta sincap var mı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ACORN_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ACORN_COOKED"
msgid "Nutty."
msgstr "Cevizli."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ACORN_SAPLING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ACORN_SAPLING"
msgid "More firewood in the making!"
msgstr "Daha fazla yakacak odun yolda!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ADVENTURE_PORTAL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ADVENTURE_PORTAL"
msgid "Don't be scared Woby, we'll do this together!"
msgstr "Korkma Woby, bunu beraber yapacağız!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIANHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIANHAT"
msgid "It tells me all kinds of stories."
msgstr "Bana her türlü hikâyeyi anlatıyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIANHATSHARD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIANHATSHARD"
msgid "I'm sure we can still find a use for it!"
msgstr "Eminim hâlâ bir kullanım bulabiliriz!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_CONTAINED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_CONTAINED"
msgid "Wow, we sure are lucky he happened to have that with him!"
msgstr "Vay, onu yanında bulundurması ne şanslıymış!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE1.DEAD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE1.DEAD"
msgid "Aww, I wanted to ask them what it's like up in space..."
msgstr "Ay, ona uzayda nasıl olduğunu sormak istiyordum..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE1.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE1.GENERIC"
msgid "Woah, is that a space creature?!"
msgstr "Vay, o bir uzay yaratığı mı?!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE1_LUNARRIFT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE1_LUNARRIFT"
msgid "It's extra glowy isn't it, Woby?"
msgstr "Ekstra parlıyor, değil mi Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE1_LUNARRIFT_GESTALT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE1_LUNARRIFT_GESTALT"
msgid "That must be it, Wobes!"
msgstr "İşte o olmalı, Wobes!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE2.DEAD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE2.DEAD"
msgid "At least now I can get a better look at it!"
msgstr "En azından şimdi daha iyi bakabilirim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE2.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE2.GENERIC"
msgid "I'm starting to think they might be mad at us, Woby."
msgstr "Bize kızgın olabileceklerini düşünmeye başlıyorum, Woby."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE2SPIKE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE2SPIKE"
msgid "I think they're trying to keep us from getting away!"
msgstr "Sanırım kaçmamızı engellemeye çalışıyorlar!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE3
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE3"
msgid "If I just get a bit closer... I'm sure I can convince them we just want to be friends!"
msgstr "Sadece biraz daha yaklaşırsam... eminim onları arkadaş olmak istediğimize ikna edebilirim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE3DEAD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE3DEAD"
msgid "Well... I guess that's that."
msgstr "Eh... sanırım bu kadar."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE3DEADORB
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE3DEADORB"
msgid "Do you think they're going to get up again, Woby?"
msgstr "Sence yine kalkacaklar mı, Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE3TRAP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE3TRAP"
msgid "We should probably stay away from those, Woby."
msgstr "Onlardan uzak dursak iyi olur, Woby."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE4_LUNARRIFT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ALTERGUARDIAN_PHASE4_LUNARRIFT"
msgid "Has anyone asked why it's so upset?"
msgstr "Neden bu kadar üzgün olduğunu kimse sordu mu?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.AMULET
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.AMULET"
msgid "I'm invincible!!"
msgstr "Yenilmezim!!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCHOR
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCHOR"
msgid "That's another important boat part."
msgstr "Bu da önemli bir tekne parçası."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCHOR_ITEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCHOR_ITEM"
msgid "I've got all the supplies ready to build an anchor."
msgstr "Bir çapa yapmak için tüm erzağı hazırladım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTFRUIT_GEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTFRUIT_GEM"
msgid "Is this really a fruit? It's as hard as a rock!"
msgstr "Bu cidden meyve mi? Kaya kadar sert!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTFRUIT_NIGHTVISION
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTFRUIT_NIGHTVISION"
msgid "Did you ever hear the story about the disembodied heart that kept beating?"
msgstr "Atmaya devam eden gövdesiz kalp hikâyesini hiç duydun mu?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTFRUIT_NIGHTVISION_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTFRUIT_NIGHTVISION_COOKED"
msgid "It was more exciting when it was moving."
msgstr "Hareket ederkenki hâli daha heyecanlıydı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_GEM.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_GEM.GENERIC"
msgid "Neat! I wonder how the tree keeps from catching fire?"
msgstr "Şık! Acaba ağaç nasıl ateş almıyor?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_GEM.STUMP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_GEM.STUMP"
msgid "Is that a rock? No wait, it's a stump!"
msgstr "O bir kaya mı? Hayır dur, bu bir kütük!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_NIGHTVISION.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_NIGHTVISION.GENERIC"
msgid "It looks kind of like a monster... but I think it's just a tree."
msgstr "Biraz canavar gibi görünüyor... ama sanırım sadece bir ağaç."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_NIGHTVISION.STUMP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_NIGHTVISION.STUMP"
msgid "Aww, I liked that tree..."
msgstr "Ay, o ağacı sevmiştim..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SAPLING.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SAPLING.GENERIC"
msgid "I can't wait to see what kind of tree it grows into!"
msgstr "Nasıl bir ağaca büyüyeceğini görmek için sabırsızlanıyorum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SAPLING.WRONG_SEASON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SAPLING.WRONG_SEASON"
msgid "It seems happy there, I guess now I just need to be patient."
msgstr "Orada mutlu görünüyor, sanırım şimdi sadece sabırlı olmam gerek."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SAPLING.WRONG_TILE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SAPLING.WRONG_TILE"
msgid "It just doesn't seem to want to grow here."
msgstr "Burada büyümek istemiyor gibi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SAPLING_ITEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SAPLING_ITEM"
msgid "Sniff out a good spot for us to plant the tree, Woby!"
msgstr "Ağacı dikmek için iyi bir yer kokla bize, Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SEED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENTTREE_SEED"
msgid "I need to find just the right spot for this."
msgstr "Bunun için tam doğru yeri bulmam gerek."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENT_ALTAR
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENT_ALTAR"
msgid "Do you think aliens helped them make it?"
msgstr "Sence onları yapmaya uzaylılar mı yardım etmiş?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENT_ALTAR_BROKEN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENT_ALTAR_BROKEN"
msgid "It looks broken to me."
msgstr "Bana bozuk görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENT_HUSK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENT_HUSK"
msgid "It makes me feel bad too, Woby."
msgstr "Beni de kötü hissettiriyor, Woby."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENT_STATUE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANCIENT_STATUE"
msgid "Woah! Is this what they looked like?"
msgstr "Vay! Onlar böyle mi görünüyordu?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANIMAL_TRACK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANIMAL_TRACK"
msgid "Tracks! They go this way!"
msgstr "İzler! Bu yöne gidiyorlar!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTCHOVIES
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTCHOVIES"
msgid "I have mixed feelings."
msgstr "Karışık duygularım var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLION.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLION.GENERIC"
msgid "Hi!"
msgstr "Selam!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLION.UNHAPPY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLION.UNHAPPY"
msgid "It's hard to read her expression..."
msgstr "İfadesini okumak zor..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLION.VERYHAPPY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLION.VERYHAPPY"
msgid "We're becoming pals already."
msgstr "Şimdiden ahbap olduk."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLIONHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLIONHAT"
msgid "I've always wanted to look like bug royalty!"
msgstr "Her zaman böcek soyluları gibi görünmek istemişimdir!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLIONTRINKET
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ANTLIONTRINKET"
msgid "Hm, I guess I could give it away as a gift?"
msgstr "Hmm, sanırım hediye olarak verebilirim?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_CENTIPEDE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_CENTIPEDE"
msgid "Maybe it's friendly?"
msgstr "Belki dostçadır?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_CENTIPEDE_HUSK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_CENTIPEDE_HUSK"
msgid "I don't think it's worked in a long time."
msgstr "Uzun zamandır çalıştığını sanmıyorum."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.BURNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.BURNT"
msgid "It's uh... extra done!"
msgstr "Eee... fazladan pişmiş!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.COOKING_LONG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.COOKING_LONG"
msgid "This might take a while. Wanna see this cool bug I found in the meantime?"
msgstr "Bu biraz sürebilir. Bu arada bulduğum havalı böceği görmek ister misin?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.COOKING_SHORT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.COOKING_SHORT"
msgid "Almost time to eat!"
msgstr "Yeme vakti yaklaştı!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.DONE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.DONE"
msgid "Come and get it!"
msgstr "Gelin alın!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.EMPTY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_COOKPOT.EMPTY"
msgid "They weren't so different from us, were they?"
msgstr "Bizden o kadar da farklı değillermiş, değil mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_LOCKBOX
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_LOCKBOX"
msgid "I wish it came with instructions..."
msgstr "Keşke talimatlarıyla gelseydi..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_LOCKBOX_DISPENCER.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_LOCKBOX_DISPENCER.GENERIC"
msgid "That glass part looks kind of familiar."
msgstr "O cam parça biraz tanıdık geldi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_LOCKBOX_DISPENCER.POWEROFF
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_LOCKBOX_DISPENCER.POWEROFF"
msgid "I wonder what they used it for."
msgstr "Acaba ne için kullanıyorlardı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_MOON_STATUE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_MOON_STATUE"
msgid "Well, they look happier than the statues outside... I think."
msgstr "Eh, dışardaki heykellerden daha mutlu görünüyorlar... sanırım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_ORCHESTRINA_MAIN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_ORCHESTRINA_MAIN"
msgid "Wanna solve a puzzle, Woby?"
msgstr "Bir bulmaca çözelim mi, Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_PORTAL.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_PORTAL.GENERIC"
msgid "Weird, this is the only thing that didn't turn back on."
msgstr "Tuhaf, tekrar açılmayan tek şey bu."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_PORTAL.POWEROFF
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_PORTAL.POWEROFF"
msgid "I wonder what this did?"
msgstr "Acaba bu ne yapıyordu?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RESONATOR.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RESONATOR.GENERIC"
msgid "I guess it's kind of like a compass."
msgstr "Sanırım pusula gibi bir şey."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RESONATOR.IDLE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RESONATOR.IDLE"
msgid "We must've found them all!"
msgstr "Hepsini bulmuş olmalıyız!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RESONATOR_ITEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RESONATOR_ITEM"
msgid "It must do something important."
msgstr "Önemli bir şey yapıyor olmalı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_1
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_1"
msgid "I sure wish I could read it."
msgstr "Keşke okuyabilseydim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_2
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_2"
msgid "I wonder what it says."
msgstr "Acaba ne diyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_3
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_3"
msgid "I sure wish I could read it."
msgstr "Keşke okuyabilseydim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_4
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_4"
msgid "I wonder what it says."
msgstr "Acaba ne diyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_5
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_RUNE_STATUE.LINE_5"
msgid "I sure wish I could read it."
msgstr "Keşke okuyabilseydim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SECURITY_DESK.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SECURITY_DESK.GENERIC"
msgid "Any respectable ancient ruin should have some kind of traps."
msgstr "Saygıdeğer her antik harabede bir tür tuzak olmalı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SECURITY_DESK.POWEROFF
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SECURITY_DESK.POWEROFF"
msgid "It doesn't seem to work anymore."
msgstr "Artık çalışıyor gibi görünmüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SECURITY_PULSE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SECURITY_PULSE"
msgid "Come on Woby, let's see where it goes!"
msgstr "Hadi Woby, nereye gittiğini görelim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SWITCH.GEMS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SWITCH.GEMS"
msgid "There's something missing..."
msgstr "Bir şey eksik..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SWITCH.VALID
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARCHIVE_SWITCH.VALID"
msgid "I think these gems might be important, Woby!"
msgstr "Sanırım bu cevherler önemli olabilir, Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORDRAGONFLY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORDRAGONFLY"
msgid "I still wish we could've been friends..."
msgstr "Hâlâ keşke arkadaş olabilseydik diyorum..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORDREADSTONE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORDREADSTONE"
msgid "It looks like an evil knight's armor. Neat!"
msgstr "Kötü bir şövalyenin zırhına benziyor. Şık!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORGRASS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORGRASS"
msgid "Smells like a freshly mowed lawn."
msgstr "Yeni biçilmiş çim gibi kokuyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORMARBLE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORMARBLE"
msgid "Will I be able to walk in that?"
msgstr "Onun içinde yürüyebilecek miyim?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORRUINS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORRUINS"
msgid "Woah! It's not even heavy!"
msgstr "Vay! Ağır bile değil!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORSKELETON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORSKELETON"
msgid "Yessss bone armor!!"
msgstr "Evettt kemik zırh!!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORSLURPER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORSLURPER"
msgid "The smell kind of ruins my appetite."
msgstr "Koku iştahımı biraz kaçırıyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORSNURTLESHELL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORSNURTLESHELL"
msgid "I'm the terrifying snail boy! Part boy, part snail!"
msgstr "Ben dehşet salgın salyangoz çocuğum! Yarı çocuk, yarı salyangoz!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORWAGPUNK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORWAGPUNK"
msgid "I'll be part boy, part machine!"
msgstr "Yarı çocuk, yarı makine olacağım!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORWOOD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMORWOOD"
msgid "Trees are pretty useful."
msgstr "Ağaçlar epey işe yarıyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_BRAMBLE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_BRAMBLE"
msgid "No hugging while you're wearing that."
msgstr "Onu giyerken sarılmak yok."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_CARROTLURE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_CARROTLURE"
msgid "Nice VESTable! Get it, Woby?"
msgstr "Güzel YELEK-zek! Anladın mı, Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_LUNARPLANT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_LUNARPLANT"
msgid "It makes me feel so safe, it's scary!"
msgstr "Bu kadar güvende hissettirmesi korkutucu!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_LUNARPLANT_HUSK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_LUNARPLANT_HUSK"
msgid "Aww. Why don't I get to wear it?"
msgstr "Ay. Neden ben giyemiyorum?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_SANITY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_SANITY"
msgid "Wait... is this dangerous?"
msgstr "Dur... bu tehlikeli mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_VOIDCLOTH
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_VOIDCLOTH"
msgid "It almost looks like it has a face, doesn't it?"
msgstr "Neredeyse yüzü varmış gibi görünüyor, değil mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_YOTH_KNIGHT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARMOR_YOTH_KNIGHT"
msgid "Now I'm really stallion!"
msgstr "Şimdi cidden aygır gibiyim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_PANEL.BURNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_PANEL.BURNT"
msgid "Hopefully it didn't say anything important."
msgstr "Umarım önemli bir şey demiyordu."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_PANEL.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_PANEL.GENERIC"
msgid "Someone has bad handwriting."
msgstr "Birinin el yazısı kötü."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_PANEL.UNWRITTEN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_PANEL.UNWRITTEN"
msgid "Well... I guess SOMETHING is in that direction."
msgstr "Eh... sanırım o yönde BİR ŞEY var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_POST.BURNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_POST.BURNT"
msgid "Hopefully it didn't say anything important."
msgstr "Umarım önemli bir şey demiyordu."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_POST.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_POST.GENERIC"
msgid "Someone has bad handwriting."
msgstr "Birinin el yazısı kötü."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_POST.UNWRITTEN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ARROWSIGN_POST.UNWRITTEN"
msgid "Well... I guess SOMETHING is in that direction."
msgstr "Eh... sanırım o yönde BİR ŞEY var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASH.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASH.GENERIC"
msgid "Did someone have a campfire without me?"
msgstr "Birisi bensiz kamp ateşi mi yaktı?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASH.REMAINS_EYE_BONE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASH.REMAINS_EYE_BONE"
msgid "Aw, I liked that thing!"
msgstr "Ay, o şeyi sevmiştim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASH.REMAINS_GLOMMERFLOWER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASH.REMAINS_GLOMMERFLOWER"
msgid "Too bad."
msgstr "Yazık oldu."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASH.REMAINS_THINGIE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASH.REMAINS_THINGIE"
msgid "Now I'll never know what it was..."
msgstr "Artık ne olduğunu hiç bilemeyeceğim..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUS"
msgid "It's not my favourite."
msgstr "En sevdiğim değil."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUSSOUP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUSSOUP"
msgid "Asparagus again? Er, not that I'm complaining..."
msgstr "Yine kuşkonmaz mı? Eee, şikâyet ediyor değilim..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUS_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUS_COOKED"
msgid "I'll eat my vegetables."
msgstr "Sebzelerimi yiyeceğim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUS_OVERSIZED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUS_OVERSIZED"
msgid "Oh... that's a lot of asparagus..."
msgstr "Ah... bu çok fazla kuşkonmaz..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUS_SEEDS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ASPARAGUS_SEEDS"
msgid "Where should we plant them, Woby?"
msgstr "Bunları nereye dikelim, Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.CHARGING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.CHARGING"
msgid "I guess we'll have to wait for it to power up."
msgstr "Sanırım güçlenmesini beklememiz gerek."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.COOLDOWN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.COOLDOWN"
msgid "I guess I should give it a rest for now."
msgstr "Sanırım şimdilik dinlendirmeliyim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.DESTABILIZING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.DESTABILIZING"
msgid "Is it supposed to be making that sound?"
msgstr "O sesi çıkarması gerekiyor mu?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.OFF
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.OFF"
msgid "It looks like it's missing a piece."
msgstr "Bir parçası eksik gibi görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.ON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_GATE.ON"
msgid "It's working!"
msgstr "Çalışıyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_KEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_KEY"
msgid "It's the key to this whole mystery!"
msgstr "Tüm bu gizemin anahtarı bu!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_LIGHT.OFF
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_LIGHT.OFF"
msgid "There's got to be a way to turn it on."
msgstr "Onu açmanın bir yolu olmalı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_LIGHT.ON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_LIGHT.ON"
msgid "Well, we got the lights working!"
msgstr "Eh, ışıkları çalıştırdık!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_OVERGROWTH
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_OVERGROWTH"
msgid "What does it mean?!"
msgstr "Bu ne anlama geliyor?!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_1
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_1"
msgid "It looks like things weren't going so well for the people here."
msgstr "Anlaşılan buradaki insanlar için işler pek iyi gitmiyormuş."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_2
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_2"
msgid "I can't tell what's happening in this one, the picture's worn off."
msgstr "Burada ne olduğunu söyleyemiyorum, resim aşınmış."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_3
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_3"
msgid "There's... a shadow? Or something... they took some artistic liberties."
msgstr "Bir... gölge mi? Ya da bir şey... biraz sanatsal özgürlük almışlar."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_4
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_4"
msgid "Woah, looks like they all started changing."
msgstr "Vay, hepsi değişmeye başlamış gibi görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_5
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_RUBBLE.LINE_5"
msgid "That must be what the city looked like a long time ago."
msgstr "Şehir uzun zaman önce böyle görünüyor olmalı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_STATUE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.ATRIUM_STATUE"
msgid "If it could speak, I wonder what it would tell us."
msgstr "Konuşabilseydi, bize neler söylerdi acaba."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.AXE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.AXE"
msgid "The favoured tool of axe murderers and loggers."
msgstr "Balta katillerinin ve oduncuların gözde aleti."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BABYBEEFALO.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BABYBEEFALO.GENERIC"
msgid "Hey little guy!"
msgstr "Hey küçük dostum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BABYBEEFALO.SLEEPING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BABYBEEFALO.SLEEPING"
msgid "Shhh! Woby, they're sleeping!"
msgstr "Şşşt! Woby, uyuyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BACKPACK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BACKPACK"
msgid "Perfect for carrying supplies! And bugs!"
msgstr "Erzak taşımak için harika! Ve böcekler!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BACONEGGS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BACONEGGS"
msgid "A good camping breakfast."
msgstr "İyi bir kamp kahvaltısı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BALATRO_MACHINE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BALATRO_MACHINE"
msgid "Woby, let's take paws and play a few hands. Oh, Walter!"
msgstr "Woby, biraz pati-mola verip birkaç el oynayalım. Ah, Walter!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOON"
msgid "My keen tracking senses are telling me there's a clown nearby."
msgstr "Keskin iz sürme duyularım yakınlarda bir palyaço olduğunu söylüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONHAT"
msgid "I'm a bit too old for this kind of thing."
msgstr "Bu tür şeyler için biraz büyüğüm."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONPARTY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONPARTY"
msgid "Is someone having a party?"
msgstr "Birisi parti mi veriyor?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONSPEED.DEFLATED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONSPEED.DEFLATED"
msgid "It's pretty much just a regular balloon now."
msgstr "Şimdi neredeyse sıradan bir balon."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONSPEED.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONSPEED.GENERIC"
msgid "Clowns have strange and mysterious ways..."
msgstr "Palyaçoların tuhaf ve gizemli yöntemleri var..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONS_EMPTY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONS_EMPTY"
msgid "Someone left litter here!"
msgstr "Birisi buraya çöp bırakmış!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONVEST
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BALLOONVEST"
msgid "I guess it's better than not having a life jacket at all..."
msgstr "Hiç can yeleğinin olmamasından iyidir herhalde..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BANANABUSH
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BANANABUSH"
msgid "Wait, I thought bananas grew on trees around here?"
msgstr "Dur, buralarda muzların ağaçlarda yetiştiğini sanıyordum?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BANANAJUICE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BANANAJUICE"
msgid "Mmm, it's even better than the ones they made at the malted shop!"
msgstr "Mmm, maltlı dükkânda yaptıklarından bile daha iyi!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BANANAPOP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BANANAPOP"
msgid "Those are for little kids. But bananas are healthy so I guess it's alright."
msgstr "Onlar küçük çocuklar içindir. Ama muzlar sağlıklı, sanırım sorun yok."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BANDAGE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BANDAGE"
msgid "You can never be too prepared when you're out in the wilderness."
msgstr "Doğada hiçbir zaman fazla hazırlıklı olamazsın."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BANDAGE_BUTTERFLYWINGS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BANDAGE_BUTTERFLYWINGS"
msgid "It's made from butterfly wings! Cute! And a little sad."
msgstr "Kelebek kanatlarından yapılmış! Sevimli! Ve biraz hüzünlü."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLE"
msgid "Foraged from the sea!"
msgstr "Denizden toplandı!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLEPITA
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLEPITA"
msgid "Further proof that anything can be a sandwich."
msgstr "Her şeyin sandviç olabileceğinin daha fazla kanıtı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLESTUFFEDFISHHEAD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLESTUFFEDFISHHEAD"
msgid "Uhh Woby? Do you want this one?"
msgstr "Eee Woby? Bunu sen ister misin?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLESUSHI
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLESUSHI"
msgid "It's... interesting."
msgstr "Bu... ilginç."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLE_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLE_COOKED"
msgid "Hmm, it's not bad!"
msgstr "Hmm, fena değil!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLINGUINE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BARNACLINGUINE"
msgid "Just about anything tastes good with pasta."
msgstr "Hemen hemen her şey makarnayla güzel tat verir."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BASALT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BASALT"
msgid "I don't think we'll be able to break through that."
msgstr "Onu kırabileceğimizi sanmıyorum."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BAT"
msgid "Maybe if we're lucky it'll turn into a vampire!"
msgstr "Belki şanslıysak vampire dönüşür!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATBAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATBAT"
msgid "Bat 'er up!"
msgstr "Yarasala vur!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATCAVE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATCAVE"
msgid "Looks like they're sleeping. Should we wake them up?"
msgstr "Uyuyorlar gibi görünüyor. Onları uyandıralım mı?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATHBOMB
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATHBOMB"
msgid "It smells pretty good."
msgstr "Bayağı güzel kokuyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATNOSE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATNOSE"
msgid "Looks like someone got a bit nosy. Get it? Because it's a nose?"
msgstr "Birisi biraz burnunu sokmuş gibi. Anladın mı? Burun olduğu için?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATNOSEHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATNOSEHAT"
msgid "Milk is good for your skeleton!"
msgstr "Süt iskeletin için iyidir!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATNOSE_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATNOSE_COOKED"
msgid "It sure doesn't smell so good now..."
msgstr "Şimdi pek güzel kokmuyor..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_CONTAINER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_CONTAINER"
msgid "It's like a special backpack for songs!"
msgstr "Şarkılar için özel bir sırt çantası gibi!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_DURABILITY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_DURABILITY"
msgid "This seems a bit more complicated than the songs I learned in the Pioneers."
msgstr "Bu Öncülerde öğrendiğim şarkılardan biraz daha karmaşık görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_FIRERESISTANCE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_FIRERESISTANCE"
msgid "This seems a bit more complicated than the songs I learned in the Pioneers."
msgstr "Bu Öncülerde öğrendiğim şarkılardan biraz daha karmaşık görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_HEALTHGAIN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_HEALTHGAIN"
msgid "This seems a bit more complicated than the songs I learned in the Pioneers."
msgstr "Bu Öncülerde öğrendiğim şarkılardan biraz daha karmaşık görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_INSTANT_PANIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_INSTANT_PANIC"
msgid "This story could use a few more monsters."
msgstr "Bu hikâyeye birkaç canavar daha yakışırdı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_INSTANT_REVIVE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_INSTANT_REVIVE"
msgid "This seems a bit more complicated than the songs I learned in the Pioneers."
msgstr "Bu Öncülerde öğrendiğim şarkılardan biraz daha karmaşık görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_INSTANT_TAUNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_INSTANT_TAUNT"
msgid "This story could use a few more monsters."
msgstr "Bu hikâyeye birkaç canavar daha yakışırdı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_LUNARALIGNED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_LUNARALIGNED"
msgid "This seems a bit more complicated than the songs I learned in the Pioneers."
msgstr "Bu Öncülerde öğrendiğim şarkılardan biraz daha karmaşık görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_SANITYAURA
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_SANITYAURA"
msgid "This seems a bit more complicated than the songs I learned in the Pioneers."
msgstr "Bu Öncülerde öğrendiğim şarkılardan biraz daha karmaşık görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_SANITYGAIN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_SANITYGAIN"
msgid "This seems a bit more complicated than the songs I learned in the Pioneers."
msgstr "Bu Öncülerde öğrendiğim şarkılardan biraz daha karmaşık görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_SHADOWALIGNED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATTLESONG_SHADOWALIGNED"
msgid "This seems a bit more complicated than the songs I learned in the Pioneers."
msgstr "Bu Öncülerde öğrendiğim şarkılardan biraz daha karmaşık görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATWING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATWING"
msgid "Where did the rest of the bat go?"
msgstr "Yarasanın geri kalanı nereye gitti?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BATWING_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BATWING_COOKED"
msgid "Uh... Woby, do you want this?"
msgstr "Eee... Woby, bunu sen ister misin?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARDHAIR
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARDHAIR"
msgid "Aw, I thought it was yeti fur..."
msgstr "Ay, yeti kürkü sanmıştım..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGER"
msgid "Look at those razor sharp claws! I need to get a closer view!"
msgstr "Şu jilet gibi keskin pençelere bak! Daha yakından bakmalıyım!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERCORPSE.BURNING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERCORPSE.BURNING"
msgid "This isn't a fun campfire..."
msgstr "Bu eğlenceli bir kamp ateşi değil..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERCORPSE.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERCORPSE.GENERIC"
msgid "I'm sorry..."
msgstr "Üzgünüm..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERCORPSE.REVIVING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERCORPSE.REVIVING"
msgid "Back from the dead!"
msgstr "Ölümden geri döndü!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERFUR_SACK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERFUR_SACK"
msgid "We can keep our snacks cold when we go exploring, Woby!"
msgstr "Keşfe çıktığımızda atıştırmalıklarımızı soğuk tutabiliriz, Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERVEST
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGERVEST"
msgid "Hey Woby, we match!"
msgstr "Hey Woby, uyumluyuz!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGER_FUR
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEARGER_FUR"
msgid "It's so soft!"
msgstr "Çok yumuşak!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEAST_BLUEPRINT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEAST_BLUEPRINT"
msgid "I wonder what kind of animal this costume is based off of?"
msgstr "Acaba bu kostüm hangi hayvana dayanıyor?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEDROLL_FURRY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEDROLL_FURRY"
msgid "It feels nice, like cuddling up with Woby."
msgstr "Hoş hissettiriyor, Woby ile sarılmak gibi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEDROLL_STRAW
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEDROLL_STRAW"
msgid "You make due with what you have out in the wilderness."
msgstr "Doğada elindekiyle idare edersin."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEE.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEE.GENERIC"
msgid "Heh... sure wish I wasn't deathly allergic to them!"
msgstr "Heh... keşke onlara ölümcül alerjim olmasaydı!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEE.HELD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEE.HELD"
msgid "Ha ha... you wouldn't sting me... right little guy?"
msgstr "Ha ha... beni sokmazsın... değil mi küçük dostum?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.BURNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.BURNT"
msgid "What! Who burned the hive?"
msgstr "Ne! Kovanı kim yaktı?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.FULLHONEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.FULLHONEY"
msgid "Look at all that honey!"
msgstr "Şu kadar bala bak!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.GENERIC"
msgid "Oh bees, why can't we be friends..."
msgstr "Ah arılar, neden arkadaş olamıyoruz..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.NOHONEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.NOHONEY"
msgid "They need a bit more time."
msgstr "Biraz daha zamana ihtiyaçları var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.READY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.READY"
msgid "Look at all that honey!"
msgstr "Şu kadar bala bak!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.SOMEHONEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX.SOMEHONEY"
msgid "They're still busy making honey."
msgstr "Hâlâ bal yapmakla meşguller."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.BURNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.BURNT"
msgid "It burned up!"
msgstr "Yanıp gitmiş!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.FULLHONEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.FULLHONEY"
msgid "M-ma'am, I think your honey is ready."
msgstr "H-hanımefendi, sanırım balınız hazır."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.GENERIC"
msgid "Don't panic Walter, the bees smell your fear..."
msgstr "Paniklemen Walter, arılar korkunu kokluyor..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.NOHONEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.NOHONEY"
msgid "It doesn't look like they've made any honey."
msgstr "Hiç bal yapmamış gibi görünüyorlar."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.READY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.READY"
msgid "M-ma'am, I think your honey is ready."
msgstr "H-hanımefendi, sanırım balınız hazır."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.SOMEHONEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEBOX_HERMIT.SOMEHONEY"
msgid "There's some honey, but not enough to be worth the stings."
msgstr "Biraz bal var ama sokulmaya değecek kadar değil."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.DEAD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.DEAD"
msgid "Poor beefalo."
msgstr "Zavallı bızonsığır."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.DEAD_MYPARTNER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.DEAD_MYPARTNER"
msgid "D-don't worry! I know first aid!"
msgstr "M-merak etme! İlk yardımı biliyorum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.DOMESTICATED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.DOMESTICATED"
msgid "He's almost as friendly as Woby now."
msgstr "Artık neredeyse Woby kadar dost canlısı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.FOLLOWER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.FOLLOWER"
msgid "Look Woby, we made a new friend!"
msgstr "Bak Woby, yeni bir arkadaş edindik!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.GENERIC"
msgid "He's almost as big as you are, Woby!"
msgstr "Neredeyse senin kadar büyük, Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.MYPARTNER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.MYPARTNER"
msgid "I'm glad you and Woby get along so well. We're like a team!"
msgstr "Sen ve Woby'nin bu kadar iyi anlaşmasına seviniyorum. Bir takım gibiyiz!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.NAKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.NAKED"
msgid "Don't worry Woby, I'd never do that to you... unless you had mats."
msgstr "Merak etme Woby, sana bunu asla yapmazdım... keçeleşmiş tüylerin olmadıkça."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.ORNERY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.ORNERY"
msgid "Hey, what's wrong?"
msgstr "Hey, ne oldu?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.PUDGY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.PUDGY"
msgid "We might need to cut back on the treats..."
msgstr "İkramları azaltmamız gerekebilir..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.RIDER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.RIDER"
msgid "Wanna go for a ride?"
msgstr "Bir gezintiye çıkmak ister misin?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.SLEEPING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO.SLEEPING"
msgid "They're snoozing."
msgstr "Şekerleme yapıyorlar."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALOFEED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALOFEED"
msgid "Come here, beefalo! Dinner time!"
msgstr "Buraya gel, bızonsığır! Yemek vakti!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALOHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALOHAT"
msgid "It sure smells like beefalo..."
msgstr "Bızonsığır gibi kokuyor..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALOTREAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALOTREAT"
msgid "Don't worry Woby, I'll get a treat for you too."
msgstr "Merak etme Woby, sana da ikram alacağım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALOWOOL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALOWOOL"
msgid "Sorry, beefalo."
msgstr "Üzgünüm, bızonsığır."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO_GROOMER.BURNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO_GROOMER.BURNT"
msgid "We all need to be much more careful with fire."
msgstr "Hepimizin ateş konusunda çok daha dikkatli olması lazım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO_GROOMER.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO_GROOMER.GENERIC"
msgid "Woby doesn't like getting dressed up, but beefalo seem to!"
msgstr "Woby giyinip kuşanmayı sevmiyor ama bızonsığırlar seviyor gibi!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO_GROOMER.OCCUPIED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO_GROOMER.OCCUPIED"
msgid "You're going to look great when we're done, just you wait!"
msgstr "Bitirince harika görüneceksin, bekle göreceksin!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO_GROOMER_ITEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEFALO_GROOMER_ITEM"
msgid "Better get this all set up."
msgstr "Bunları kursam iyi olacak."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEF_BELL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEF_BELL"
msgid "The beefalo seem to really like the sound it makes!"
msgstr "Bızonsığırlar çıkardığı sesi cidden seviyor gibi!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEGUARD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEGUARD"
msgid "They're just trying to protect their queen."
msgstr "Sadece kraliçelerini korumaya çalışıyorlar."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEHAT"
msgid "I can finally walk among the bees!"
msgstr "Sonunda arıların arasında yürüyebiliyorum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEHIVE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEHIVE"
msgid "I reeaally shouldn't get closer..."
msgstr "Cidden daaha yaklaşmamalıyım..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEMINE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEMINE"
msgid "W-what could go wrong?"
msgstr "N-ne yanlış gidebilir ki?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEMINE_MAXWELL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEMINE_MAXWELL"
msgid "How do I get the mosquitoes out?"
msgstr "Sivrisinekleri nasıl çıkaracağım?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEQUEEN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEQUEEN"
msgid "If I make friends with their queen, maybe the bees won't sting me!"
msgstr "Kraliçeleriyle arkadaş olursam, belki arılar beni sokmaz!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEQUEENHIVE.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEQUEENHIVE.GENERIC"
msgid "I shouldn't walk on that, I'll get my shoes sticky."
msgstr "Onun üstüne basmamalıyım, ayakkabılarım yapışkan olur."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEQUEENHIVE.GROWING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEQUEENHIVE.GROWING"
msgid "It looks bigger than it did yesterday..."
msgstr "Dünkünden daha büyük görünüyor..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEQUEENHIVEGROWN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEEQUEENHIVEGROWN"
msgid "Woah, it's huge!"
msgstr "Vay, devasa!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEESWAX
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEESWAX"
msgid "It's none of my beeswax. Heh..."
msgstr "Bal mumumu yakmaz. Heh..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEESWAX_SPRAY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEESWAX_SPRAY"
msgid "It looks kind of like my mom's perfume, but it sure doesn't smell like it."
msgstr "Annemin parfümüne biraz benziyor ama hiç ona benzemiyor kokusu."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BEETLETAUR
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BEETLETAUR"
msgid "I can smell him from here!"
msgstr "Buradan kokusunu alabiliyorum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BELL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BELL"
msgid "What if we put it on your collar Woby?"
msgstr "Ya bunu tasmana takarsak Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERNIE_ACTIVE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERNIE_ACTIVE"
msgid "Woah! Is your bear haunted? Cursed?"
msgstr "Vay! Ayın perili mi? Lanetli mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERNIE_BIG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERNIE_BIG"
msgid "If you play with fire, you're gonna get Bernie'd. Heh..."
msgstr "Ateşle oynarsan, Bernie'lenirsin. Heh..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERNIE_INACTIVE.BROKEN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERNIE_INACTIVE.BROKEN"
msgid "I-I'm sure we can fix him."
msgstr "E-eminim onu tamir edebiliriz."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERNIE_INACTIVE.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERNIE_INACTIVE.GENERIC"
msgid "He burnt himself out."
msgstr "Kendini tüketti."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRIES
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRIES"
msgid "They're not in the poisonous section of my handbook, must be safe!"
msgstr "El kitabımın zehirli bölümünde değiller, güvenli olmalı!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRIES_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRIES_COOKED"
msgid "Well, now I have hot berries."
msgstr "Eh, şimdi sıcak meyvelerim var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRIES_JUICY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRIES_JUICY"
msgid "Yes! These are the best kind!"
msgstr "Evet! Bunlar en iyi çeşit!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRIES_JUICY_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRIES_JUICY_COOKED"
msgid "I should eat these fast."
msgstr "Bunları hızlıca yemeliyim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.BARREN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.BARREN"
msgid "My handbook says some kind of fertilizer should help."
msgstr "El kitabım bir tür gübrenin yardımcı olacağını söylüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.BURNING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.BURNING"
msgid "That's not a campfire..."
msgstr "Bu kamp ateşi değil..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.DISEASED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.DISEASED"
msgid "Uh, something's definitely wrong with it."
msgstr "Eee, kesinlikle bir şey yanlış."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.DISEASING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.DISEASING"
msgid "Is something wrong with it?"
msgstr "Onunla bir sorun mu var?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.GENERIC"
msgid "Foraging is an important wilderness skill!"
msgstr "Yiyecek toplamak önemli bir doğa becerisidir!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.PICKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.PICKED"
msgid "If I wait long enough, they'll grow back."
msgstr "Yeterince beklersem geri büyürler."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.WITHERED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH.WITHERED"
msgid "It's way too hot out for anything to grow."
msgstr "Dışarısı bir şeyin büyümesi için fazla sıcak."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.BARREN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.BARREN"
msgid "It won't be making more berries anytime soon."
msgstr "Yakın zamanda daha fazla meyve yapmayacak."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.BURNING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.BURNING"
msgid "That's not a campfire..."
msgstr "Bu kamp ateşi değil..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.DISEASED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.DISEASED"
msgid "Uh, something's definitely wrong with it."
msgstr "Eee, kesinlikle bir şey yanlış."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.DISEASING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.DISEASING"
msgid "Is something wrong with it?"
msgstr "Onunla bir sorun mu var?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.GENERIC"
msgid "They look so tasty..."
msgstr "Çok lezzetli görünüyorlar..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.PICKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.PICKED"
msgid "More will grow soon."
msgstr "Yakında daha fazlası büyür."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.WITHERED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYBUSH_JUICY.WITHERED"
msgid "I guess this isn't the season for berries."
msgstr "Sanırım meyve mevsimi değil."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYSAUCE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BERRYSAUCE"
msgid "It somehow tastes even better than regular berries!"
msgstr "Bir şekilde sıradan meyvelerden bile daha lezzetli!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIBINGKA
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIBINGKA"
msgid "Woah... where did we get the shaved coconut from?"
msgstr "Vay... rendelenmiş hindistan cevizini nereden bulduk?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIGFOOT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIGFOOT"
msgid "I knew he was real!"
msgstr "Gerçek olduğunu biliyordum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRCHNUTDRAKE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRCHNUTDRAKE"
msgid "Hey little guy! What's got you all worked up?"
msgstr "Hey küçük dostum! Seni böyle sinirlendiren ne?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.DEAD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.DEAD"
msgid "I'm... a terrible pet owner..."
msgstr "Ben... berbat bir evcil hayvan sahibiyim..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.GENERIC"
msgid "Now we just need to catch a bird!"
msgstr "Şimdi sadece bir kuş yakalamamız gerek!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.HUNGRY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.HUNGRY"
msgid "We need some bird food!"
msgstr "Biraz kuş yemine ihtiyacımız var!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.OCCUPIED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.OCCUPIED"
msgid "Aw, you miss the trees don't you?"
msgstr "Ay, ağaçları özlüyorsun değil mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.SKELETON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.SKELETON"
msgid "Someone should bury it."
msgstr "Birinin onu gömmesi gerek."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.SLEEPING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.SLEEPING"
msgid "Are you sleeping?"
msgstr "Uyuyor musun?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.STARVING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCAGE.STARVING"
msgid "Oh no! Did we forget to feed you?"
msgstr "Aman tanrım! Seni beslemeyi mi unuttuk?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCORPSE.BURNING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCORPSE.BURNING"
msgid "Smells kinda yummy."
msgstr "Biraz lezzetli kokuyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCORPSE.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCORPSE.GENERIC"
msgid "Stay away from it, Woby!"
msgstr "Ondan uzak dur, Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCORPSE.REVIVING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDCORPSE.REVIVING"
msgid "Yes! I knew it!"
msgstr "Evet! Biliyordum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDTRAP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRDTRAP"
msgid "A bird trap! Classic survival stuff!"
msgstr "Bir kuş tuzağı! Klasik hayatta kalma malzemesi!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRD_EGG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRD_EGG"
msgid "Egg-cellent! Get it? Because... egg...?"
msgstr "Yumur-tane! Anladın mı? Çünkü... yumurta...?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRD_EGG_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRD_EGG_COOKED"
msgid "Smells like breakfast is ready!"
msgstr "Kahvaltı hazır gibi kokuyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRD_MUTANT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRD_MUTANT"
msgid "Woah! That doesn't look like any of the birds in my handbook!"
msgstr "Vay! Bu el kitabımdaki hiçbir kuşa benzemiyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRD_MUTANT_SPITTER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BIRD_MUTANT_SPITTER"
msgid "Maybe it's a cardinal? A... really sick cardinal?"
msgstr "Belki kızılkuştur? Bir... gerçekten hasta kızılkuş?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BISHOP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BISHOP"
msgid "It's a Martian!"
msgstr "Bu bir Marslı!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BISHOP_CHARGE_HIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BISHOP_CHARGE_HIT"
msgid "Ah!! Why?!"
msgstr "Ah!! Neden?!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BISHOP_NIGHTMARE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BISHOP_NIGHTMARE"
msgid "Oooh, look at that! What's that stuff oozing out of it?"
msgstr "Aaah, şuna bak! İçinden sızan o şey ne?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLACKFLAG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLACKFLAG"
msgid "I should paint something friendly on it, so people know we're helpful pirates."
msgstr "Üzerine dostane bir şey çizmeliyim ki insanlar yardımsever korsanlar olduğumuzu bilsin."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_FIRE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_FIRE"
msgid "It's not as good as my slingshot, but it'll do the trick."
msgstr "Sapanım kadar iyi değil ama iş görür."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_LAVA
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_LAVA"
msgid "That's a weapon I could use from range."
msgstr "Uzaktan kullanabileceğim bir silah."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_LAVA2
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_LAVA2"
msgid "It uses a strong blast of air to propel a projectile."
msgstr "Bir mermiyi fırlatmak için güçlü bir hava patlaması kullanıyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_PIPE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_PIPE"
msgid "It's not as good as my slingshot, but it'll do the trick."
msgstr "Sapanım kadar iyi değil ama iş görür."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_SLEEP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_SLEEP"
msgid "It's not as good as my slingshot, but it'll do the trick."
msgstr "Sapanım kadar iyi değil ama iş görür."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_YELLOW
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLOWDART_YELLOW"
msgid "It's not as good as my slingshot, but it'll do the trick."
msgstr "Sapanım kadar iyi değil ama iş görür."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEAMULET
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEAMULET"
msgid "Brr... how does it stay so cold?"
msgstr "Brr... nasıl bu kadar soğuk kalıyor?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEGEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEGEM"
msgid "A magic blue gem!"
msgstr "Sihirli mavi bir cevher!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEMOONEYE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEMOONEYE"
msgid "You don't come across one of these very often."
msgstr "Bunlardan birine sık rastlanmaz."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEPRINT.COMMON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEPRINT.COMMON"
msgid "I'm great at following directions!"
msgstr "Yönergeleri takip etmekte harikayım!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEPRINT.RARE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUEPRINT.RARE"
msgid "I think I found something interesting!"
msgstr "Sanırım ilginç bir şey buldum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_CAP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_CAP"
msgid "I'm preeetty sure this isn't the poisonous kind..."
msgstr "Buuun zehirli olmadığına epeey eminim..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_CAP_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_CAP_COOKED"
msgid "Nothing ventured, nothing gained!"
msgstr "Risk almazsan kazanamazsın!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_MUSHROOM.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_MUSHROOM.GENERIC"
msgid "Hm... there's no blue mushrooms in my handbook..."
msgstr "Hmm... el kitabımda mavi mantar yok..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_MUSHROOM.INGROUND
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_MUSHROOM.INGROUND"
msgid "Woby, do you think you could dig it up? Guess not."
msgstr "Woby, sence kazıp çıkarabilir misin? Sanırım hayır."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_MUSHROOM.PICKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BLUE_MUSHROOM.PICKED"
msgid "Maybe it will grow back eventually."
msgstr "Belki eninde sonunda geri büyür."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOARDS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOARDS"
msgid "Some boards."
msgstr "Birkaç tahta."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOARON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOARON"
msgid "I can take him!"
msgstr "Onunla başa çıkabilirim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOARRIOR
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOARRIOR"
msgid "You sure are big!"
msgstr "Cidden büyüksün!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATFRAGMENT03
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATFRAGMENT03"
msgid "Looks like a sea monster got them."
msgstr "Anlaşılan deniz canavarı yakalamış."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATFRAGMENT04
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATFRAGMENT04"
msgid "Looks like a sea monster got them."
msgstr "Anlaşılan deniz canavarı yakalamış."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATFRAGMENT05
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATFRAGMENT05"
msgid "Looks like a sea monster got them."
msgstr "Anlaşılan deniz canavarı yakalamış."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATPATCH
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATPATCH"
msgid "Better to be prepared."
msgstr "Hazırlıklı olmak iyidir."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATPATCH_KELP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATPATCH_KELP"
msgid "I knew it was a good idea to pick all that kelp!"
msgstr "O kadar yosun toplamanın iyi bir fikir olduğunu biliyordum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_CHECKPOINT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_CHECKPOINT"
msgid "Hope it doesn't float away."
msgstr "Umarım sürüklenip gitmez."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_CHECKPOINT_THROWABLE_DEPLOYKIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_CHECKPOINT_THROWABLE_DEPLOYKIT"
msgid "Where should we toss this, Woby?"
msgstr "Bunu nereye fırlatalım, Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_PRIMEMATE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_PRIMEMATE"
msgid "We're not afraid of a little friendly competition. Right, Woby?"
msgstr "Küçük bir dostça rekabetten korkmuyoruz. Değil mi, Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SEASTACK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SEASTACK"
msgid "Buoy off the port side! Er, I mean starboard! I'll double check my handbook..."
msgstr "İskele tarafında şamandıra! Eee, yani sancak! El kitabıma tekrar bakayım..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SEASTACK_MONKEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SEASTACK_MONKEY"
msgid "Buoy off the port side! Er, I mean starboard! I'll double check my handbook..."
msgstr "İskele tarafında şamandıra! Eee, yani sancak! El kitabıma tekrar bakayım..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SEASTACK_MONKEY_THROWABLE_DEPLOYKIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SEASTACK_MONKEY_THROWABLE_DEPLOYKIT"
msgid "I'll have it in the water in a jiffy!"
msgstr "Onu suya bir çırpıda atacağım!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SEASTACK_THROWABLE_DEPLOYKIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SEASTACK_THROWABLE_DEPLOYKIT"
msgid "I'll have it in the water in a jiffy!"
msgstr "Onu suya bir çırpıda atacağım!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SPECTATOR_DRAGONLING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_SPECTATOR_DRAGONLING"
msgid "Look Woby! I think he's rooting for us!"
msgstr "Bak Woby! Sanırım bizi destekliyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_START
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_START"
msgid "So this is where we start the race."
msgstr "Demek yarışı buradan başlatıyoruz."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_START_THROWABLE_DEPLOYKIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOATRACE_START_THROWABLE_DEPLOYKIT"
msgid "Hmm, I wonder where we should start the race."
msgstr "Hmm, yarışı nerede başlatsak acaba."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ANCIENT_CONTAINER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ANCIENT_CONTAINER"
msgid "This should keep our supplies safe, Woby."
msgstr "Bu erzağımızı güvende tutacak, Woby."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ANCIENT_ITEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ANCIENT_ITEM"
msgid "Is this really how they used to build boats in the olden days?"
msgstr "Eski günlerde tekneleri cidden böyle mi yapıyorlardı?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_CRABKING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_CRABKING"
msgid "Don't worry Woby, I'm really good at sailing. That's just a precaution!"
msgstr "Merak etme Woby, denizcilikte cidden iyiyim. Bu sadece bir önlem!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_CRABKING_KIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_CRABKING_KIT"
msgid "It's always best to be prepared!"
msgstr "Hazırlıklı olmak her zaman en iyisidir!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_KELP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_KELP"
msgid "Don't worry Woby, I'm really good at sailing. That's just a precaution!"
msgstr "Merak etme Woby, denizcilikte cidden iyiyim. Bu sadece bir önlem!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_KELP_KIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_KELP_KIT"
msgid "It's always best to be prepared!"
msgstr "Hazırlıklı olmak her zaman en iyisidir!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_SHELL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_SHELL"
msgid "Don't worry Woby, I'm really good at sailing. That's just a precaution!"
msgstr "Merak etme Woby, denizcilikte cidden iyiyim. Bu sadece bir önlem!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_SHELL_KIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_SHELL_KIT"
msgid "It's always best to be prepared!"
msgstr "Hazırlıklı olmak her zaman en iyisidir!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_YOTD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_YOTD"
msgid "Neat! Are those real dragon teeth?"
msgstr "Şık! O dişler gerçek ejderha dişleri mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_YOTD_KIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_BUMPER_YOTD_KIT"
msgid "It's always best to be prepared!"
msgstr "Hazırlıklı olmak her zaman en iyisidir!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_CANNON.AMMOLOADED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_CANNON.AMMOLOADED"
msgid "It's kind of like a giant slingshot, if you think about it."
msgstr "Düşününce, biraz dev bir sapan gibi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_CANNON.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_CANNON.GENERIC"
msgid "I'll load the cannonball!"
msgstr "Top güllesini yükleyeceğim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_CANNON.NOAMMO
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_CANNON.NOAMMO"
msgid "I forgot the cannonballs! This won't make me lose points toward my badge, right?"
msgstr "Top güllelerini unuttum! Bu rozet puanımı düşürmez, değil mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_CANNON_KIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_CANNON_KIT"
msgid "I've got all the supplies I need to build a cannon."
msgstr "Bir top yapmak için tüm erzağı topladım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_GRASS_ITEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_GRASS_ITEM"
msgid "You have to make do with what you have out in the wilderness!"
msgstr "Doğada elindekiyle idare etmek zorundasın!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ITEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ITEM"
msgid "Let's get building, Woby!"
msgstr "İnşaata başlayalım, Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_LEAK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_LEAK"
msgid "Don't worry! I have a badge in sailing, I know what to do!"
msgstr "Merak etme! Denizcilikte rozetim var, ne yapacağımı biliyorum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET.ACTIVATED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET.ACTIVATED"
msgid "It's definitely pulling us toward something!"
msgstr "Kesinlikle bizi bir şeye doğru çekiyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET.GENERIC"
msgid "Woah, I've never seen a magnet that big!"
msgstr "Vay, bu kadar büyük mıknatıs hiç görmemiştim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET_BEACON.ACTIVATED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET_BEACON.ACTIVATED"
msgid "It's blinking! I think that means it's working?"
msgstr "Yanıp sönüyor! Sanırım bu çalıştığı anlamına geliyor?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET_BEACON.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET_BEACON.GENERIC"
msgid "I don't really get how it works, but it sure looks neat!"
msgstr "Nasıl çalıştığını pek anlamıyorum ama epey şık görünüyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET_KIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_MAGNET_KIT"
msgid "I hope I get Mr. Wilson's instructions right... he kind of muttered through a lot of it."
msgstr "Umarım Bay Wilson'ın talimatlarını doğru anlamışımdır... çoğunu mırıldanarak söyledi biraz."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ROTATOR
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ROTATOR"
msgid "Rudders are very important for sailing!"
msgstr "Dümenler denizcilik için çok önemlidir!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ROTATOR_KIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOAT_ROTATOR_KIT"
msgid "A rudder might come in handy."
msgstr "Bir dümen işe yarayabilir."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BODYPILLOW_BEEFALOWOOL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BODYPILLOW_BEEFALOWOOL"
msgid "It's almost as good of a pillow as Woby!"
msgstr "Neredeyse Woby kadar iyi bir yastık!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BODYPILLOW_KELP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BODYPILLOW_KELP"
msgid "Well, um... I guess there are worse things to use for a pillow?"
msgstr "Eh, eee... sanırım yastık için daha kötü şeyler de var?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BODYPILLOW_PETALS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BODYPILLOW_PETALS"
msgid "Don't worry, I already checked it for bees."
msgstr "Merak etme, içinde arı var mı diye baktım zaten."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BODYPILLOW_STEELWOOL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BODYPILLOW_STEELWOOL"
msgid "It's not so bad, I once made a bed out of pine needles."
msgstr "O kadar fena değil, bir keresinde çam iğnelerinden yatak yapmıştım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOMB_LUNARPLANT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOMB_LUNARPLANT"
msgid "If only I could use it in my slingshot."
msgstr "Keşke sapanımda kullanabilseydim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOMB_LUNARPLANT_WORMWOOD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOMB_LUNARPLANT_WORMWOOD"
msgid "Woah, it looks a lot stronger now!"
msgstr "Vay, şimdi çok daha güçlü görünüyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BONESHARD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BONESHARD"
msgid "It's a bone!"
msgstr "Bu bir kemik!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BONESOUP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BONESOUP"
msgid "It really fills you up."
msgstr "Cidden seni doyuruyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BONESTEW
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BONESTEW"
msgid "Tasty!"
msgstr "Lezzetli!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOKSTATION.BURNT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOKSTATION.BURNT"
msgid "Poor Ms. Wickerbottom..."
msgstr "Zavallı Bayan Wickerbottom..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOKSTATION.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOKSTATION.GENERIC"
msgid "If you read the books out loud it's almost like listening to a radio play."
msgstr "Kitapları sesli okursan neredeyse bir radyo tiyatrosu dinlemek gibi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_BEES
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_BEES"
msgid "There aren't real bees inside, right? Heh, no, that would be silly."
msgstr "İçinde gerçek arı yok, değil mi? Heh, hayır, bu aptalca olurdu."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_BIRDS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_BIRDS"
msgid "I don't want to brag... but I do have a badge in birdwatching."
msgstr "Övünmek istemem... ama kuş gözleminde rozetim var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_BRIMSTONE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_BRIMSTONE"
msgid "Wendy already spoiled the ending for me..."
msgstr "Wendy sonunu bana zaten anlatmıştı..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_ELEMENTAL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_ELEMENTAL"
msgid "I can't make out the text."
msgstr "Metni okuyamıyorum."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_FIRE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_FIRE"
msgid "There's a lot of good fire safety tips in here! Um... has Willow read it?"
msgstr "Burada çok iyi yangın güvenliği ipuçları var! Eee... Willow bunu okudu mu?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_FISH
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_FISH"
msgid "Fishing is a reel-y important part of wilderness survival. Get it? Reel-y?"
msgstr "Balıkçılık doğada hayatta kalmanın makara-li önemli bir parçası. Anladın mı? Makara-li?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_FOSSIL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_FOSSIL"
msgid "This'll keep those monsters held for a little while."
msgstr "Bu o canavarları bir süreliğine durduracak."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_GARDENING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_GARDENING"
msgid "I already have my gardening badge."
msgstr "Bahçıvanlık rozetim zaten var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_HORTICULTURE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_HORTICULTURE"
msgid "I already have my gardening badge."
msgstr "Bahçıvanlık rozetim zaten var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_HORTICULTURE_UPGRADED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_HORTICULTURE_UPGRADED"
msgid "Maybe I can get another gardening badge?"
msgstr "Belki bir bahçıvanlık rozeti daha alabilirim?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_LIGHT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_LIGHT"
msgid "Sounds pretty mysterious!"
msgstr "Bayağı esrarengiz duruyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_LIGHT_UPGRADED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_LIGHT_UPGRADED"
msgid "This one sounds extra mysterious."
msgstr "Bu daha da esrarengiz duruyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_MOON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_MOON"
msgid "Aww, it doesn't even mention aliens!"
msgstr "Aaaa, uzaylılardan bile bahsetmiyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_RAIN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_RAIN"
msgid "I wonder what impractical rain rituals look like?"
msgstr "Acaba pratik olmayan yağmur ritüelleri nasıl görünür?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_RESEARCH_STATION
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_RESEARCH_STATION"
msgid "It's almost as useful as my Pinetree Pioneer handbook."
msgstr "Neredeyse Çamağacı Öncüsü el kitabım kadar faydalı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_SILVICULTURE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_SILVICULTURE"
msgid "There's so much to learn about the woods!"
msgstr "Ormanlar hakkında öğrenecek o kadar çok şey var ki!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_SLEEP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_SLEEP"
msgid "My idea of a bedtime story has a lot more monsters in it..."
msgstr "Benim uyku öncesi hikâye anlayışımda çok daha fazla canavar var..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_TEMPERATURE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_TEMPERATURE"
msgid "I hope it works on Woby, I worry about her in the summer with all that fur..."
msgstr "Umarım Woby'de işe yarar, yazın o kadar tüyle ona üzülüyorum..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_TENTACLES
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_TENTACLES"
msgid "Oooh, this reminds me of a radio play where a ship gets eaten by a giant squid!"
msgstr "Oooh, bu bana dev ahtapotun gemi yediği bir radyo tiyatrosunu hatırlattı!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_WEB
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOK_WEB"
msgid "Maybe I should give this book to Mr. Wolfgang."
msgstr "Belki bu kitabı Bay Wolfgang'a vermeliyim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOMERANG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOMERANG"
msgid "Fetch, Woby!"
msgstr "Getir Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOTLEG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BOOTLEG"
msgid "Sorry Woby, that bone isn't for you."
msgstr "Üzgünüm Woby, o kemik sana göre değil."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BROKEN_FORGEDITEM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BROKEN_FORGEDITEM"
msgid "Woby! Were you playing with that?"
msgstr "Woby! Sen mi oynuyordun bununla?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BRUSH
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BRUSH"
msgid "Woby loves getting her fur brushed."
msgstr "Woby tüylerinin fırçalanmasına bayılıyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUGNET
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUGNET"
msgid "I'm an expert at catching bugs."
msgstr "Böcek yakalamada uzmanım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BULLKELP_PLANT.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BULLKELP_PLANT.GENERIC"
msgid "It's kelp... or a sea monster DISGUISING themselves as kelp."
msgstr "Yosun bu... ya da kendini yosun KILIĞINA sokmuş bir deniz canavarı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BULLKELP_PLANT.PICKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BULLKELP_PLANT.PICKED"
msgid "I guess it's just kelp."
msgstr "Galiba sadece yosunmuş."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BULLKELP_ROOT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BULLKELP_ROOT"
msgid "I could plant this back in the ocean."
msgstr "Bunu okyanusa geri ekebilirim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUNDLE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUNDLE"
msgid "It's packed full of provisions."
msgstr "Erzakla tıka basa dolu."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUNDLEWRAP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUNDLEWRAP"
msgid "Efficient packing is truly an overlooked art in camping."
msgstr "Verimli paketleme kampçılıkta gerçekten göz ardı edilen bir sanat."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUNNYMAN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUNNYMAN"
msgid "I've never heard of the Bunnyman before! Better make a note."
msgstr "Tavşanadam'ı daha önce hiç duymadım! Bir not düşsem iyi olur."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUNNYSTEW
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUNNYSTEW"
msgid "There's no Pioneer that could say no to this!"
msgstr "Buna hayır diyebilecek hiçbir Öncü yoktur!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BURNT_MARSH_BUSH
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BURNT_MARSH_BUSH"
msgid "Guess it wasn't a bog monster after all."
msgstr "Demek bataklık canavarı değilmiş sonuçta."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUSHHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUSHHAT"
msgid "Camouflage!"
msgstr "Kamuflaj!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTER"
msgid "This makes far more sense, honestly."
msgstr "Bu çok daha mantıklı, dürüst olmak gerekirse."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTERFLY.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTERFLY.GENERIC"
msgid "I wonder if I can catch it."
msgstr "Acaba yakalayabilir miyim?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTERFLY.HELD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTERFLY.HELD"
msgid "Gotcha!"
msgstr "Yakaladım!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTERFLYMUFFIN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTERFLYMUFFIN"
msgid "I feel kind of bad about the butterfly."
msgstr "Kelebek için biraz kötü hissediyorum."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTERFLYWINGS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUTTERFLYWINGS"
msgid "Nature's pretty amazing, isn't it?"
msgstr "Doğa epey muhteşem, değil mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUZZARD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUZZARD"
msgid "That seems like a bad sign."
msgstr "Kötüye işaret gibi duruyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUZZARDCORPSE.BURNING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUZZARDCORPSE.BURNING"
msgid "Smells kinda yummy."
msgstr "Kokusu hafif iştah açıcı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUZZARDCORPSE.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUZZARDCORPSE.GENERIC"
msgid "Stay away from it, Woby!"
msgstr "Ondan uzak dur Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.BUZZARDCORPSE.REVIVING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.BUZZARDCORPSE.REVIVING"
msgid "Yes! I knew it!"
msgstr "Evet! Biliyordum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.CABBAGEROLLS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.CABBAGEROLLS"
msgid "This would make great camping food!"
msgstr "Bu harika bir kamp yemeği olur!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS.GENERIC"
msgid "That's one prickly plant."
msgstr "Şu bir dikenli bitki."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS.PICKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS.PICKED"
msgid "You'd better be tasty."
msgstr "Lezzetli olsan iyi olur."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS_FLOWER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS_FLOWER"
msgid "It looks nice, but getting it was a pain."
msgstr "Güzel görünüyor ama almak çile oldu."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS_MEAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS_MEAT"
msgid "Maybe I should take out the spines first."
msgstr "Belki önce dikenleri çıkarmalıyım."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS_MEAT_COOKED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.CACTUS_MEAT_COOKED"
msgid "At least it's safe to eat now."
msgstr "En azından artık yenilebilir."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.CALIFORNIAROLL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.CALIFORNIAROLL"
msgid "Is that raw fish?"
msgstr "Bu çiğ balık mı?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.CAMPFIRE.EMBERS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.CAMPFIRE.EMBERS"
msgid "We need more fuel for the fire!"
msgstr "Ateşe daha fazla yakıt lazım!"

