msgstr "Bir kurgu! Çok... sahnelenmiş hissettiriyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSJUNK1
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSJUNK1"
