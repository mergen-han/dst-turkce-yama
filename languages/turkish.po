#. STRINGS.CHARACTER_QUOTES.walter
msgctxt "STRINGS.CHARACTER_QUOTES.walter"
msgid "\"A Pinetree Pioneer is always prepared!\""
msgstr "\"Bir Çamağacı Öncüsü her daim hazırlıklıdır!\""

#. STRINGS.CHARACTER_QUOTES.wanda
msgctxt "STRINGS.CHARACTER_QUOTES.wanda"
msgid "\"Time! I just need more time!\""
msgstr "\"Zaman! Tek ihtiyacım daha fazla zaman!\""

#. STRINGS.CHARACTER_QUOTES.warly
msgctxt "STRINGS.CHARACTER_QUOTES.warly"
msgid "\"Nothing worthwhile is ever done on an empty stomach!\""
msgstr "\"Aç karna değerli hiçbir iş yapılmaz!\""

#. STRINGS.CHARACTER_QUOTES.wathgrithr
msgctxt "STRINGS.CHARACTER_QUOTES.wathgrithr"
msgid "\"All the wörld's a stage. För me!\""
msgstr "\"Tüm dünyä bir sahnedir. Bänim için!\""

#. STRINGS.CHARACTER_QUOTES.waxwell
msgctxt "STRINGS.CHARACTER_QUOTES.waxwell"
msgid "\"Freedom suits me.\""
msgstr "\"Özgürlük bana yakıştı.\""

#. STRINGS.CHARACTER_QUOTES.webber
msgctxt "STRINGS.CHARACTER_QUOTES.webber"
msgid "\"We're always together, and never alone!\""
msgstr "\"Hep beraberiz, asla yalnız değiliz!\""

#. STRINGS.CHARACTER_QUOTES.wendy
msgctxt "STRINGS.CHARACTER_QUOTES.wendy"
msgid "\"Abigail? Come back! I'm not done playing with you.\""
msgstr "\"Abigail? Geri dön! Seninle oynamayı bitirmedim.\""

#. STRINGS.CHARACTER_QUOTES.wes
msgctxt "STRINGS.CHARACTER_QUOTES.wes"
msgid "..."
msgstr "..."

#. STRINGS.CHARACTER_QUOTES.wickerbottom
msgctxt "STRINGS.CHARACTER_QUOTES.wickerbottom"
msgid "\"Shhhh! No talking!\""
msgstr "\"Şişşşt! Konuşmak yasak!\""

#. STRINGS.CHARACTER_QUOTES.willow
msgctxt "STRINGS.CHARACTER_QUOTES.willow"
msgid "\"All will bathe in the prettiest of flames.\""
msgstr "\"Hepsi en güzel alevlerin içinde yıkanacak.\""

#. STRINGS.CHARACTER_QUOTES.wilson
msgctxt "STRINGS.CHARACTER_QUOTES.wilson"
msgid "\"I'll conquer this world with the power of my MIND!\""
msgstr "\"Bu dünyayı ZİHNİMİN gücüyle fethedeceğim!\""

#. STRINGS.CHARACTER_QUOTES.winona
msgctxt "STRINGS.CHARACTER_QUOTES.winona"
msgid "\"Anything can be fixed with hard work and elbow grease.\""
msgstr "\"Çalışkanlık ve dirsek çürütmekle her şey onarılır.\""

#. STRINGS.CHARACTER_QUOTES.wolfgang
msgctxt "STRINGS.CHARACTER_QUOTES.wolfgang"
msgid "\"I am mighty! No one is mightier!\""
msgstr "\"Ben kudretli! Kimse benden kudretli değil!\""

#. STRINGS.CHARACTER_QUOTES.wonkey
msgctxt "STRINGS.CHARACTER_QUOTES.wonkey"
msgid "\"Ook OOK!\""
msgstr "\"Uuk UUK!\""

#. STRINGS.CHARACTER_QUOTES.woodie
msgctxt "STRINGS.CHARACTER_QUOTES.woodie"
msgid "\"That's a nice lookin' tree, eh? Not for long.\""
msgstr "\"Hoş bir ağaç, ha? Uzun sürmez.\""

#. STRINGS.CHARACTER_QUOTES.wormwood
msgctxt "STRINGS.CHARACTER_QUOTES.wormwood"
msgid "\"Hello friend?\""
msgstr "\"Selam dost?\""

#. STRINGS.CHARACTER_QUOTES.wortox
msgctxt "STRINGS.CHARACTER_QUOTES.wortox"
msgid "\"Pardon me if I don't shake your hand.\""
msgstr "\"Bağışla beni, sıkmazsam elini.\""

#. STRINGS.CHARACTER_QUOTES.wurt
