msgctxt "STRINGS.SKIN_DESCRIPTIONS.treasurechest_upgraded_vintage"
msgid "Adds a nice, homey touch to any camp."
msgstr "Herhangi bir kampa hoş, ev gibi bir hava katar."

#. STRINGS.SKIN_DESCRIPTIONS.treasurechest_vintage
msgctxt "STRINGS.SKIN_DESCRIPTIONS.treasurechest_vintage"
msgid "Adds a nice, homey touch to any camp."
msgstr "Herhangi bir kampa hoş, ev gibi bir hava katar."

#. STRINGS.SKIN_DESCRIPTIONS.trident_merm
msgctxt "STRINGS.SKIN_DESCRIPTIONS.trident_merm"
msgid "A young warrior must learn to turn the tide in their favor."
msgstr "Genç bir savaşçı gelgiti kendi lehine çevirmeyi öğrenmelidir."

#. STRINGS.SKIN_DESCRIPTIONS.trophyscale_fish_handmade
msgctxt "STRINGS.SKIN_DESCRIPTIONS.trophyscale_fish_handmade"
msgid "What waits to be weighed 'neath the waves?"
msgstr "Dalgaların altında tartılmayı bekleyen ne var?"

