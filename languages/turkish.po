msgstr "Daha bile çok bozuk satranç taşı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_ANCHOR
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_ANCHOR"
msgid "It's as heavy as it looks."
msgstr "Göründüğü kadar ağır."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_ANTLION
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_ANTLION"
msgid "A stagn-antlion."
msgstr "Bir durga-aslan."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BEARGER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BEARGER"
