msgstr "Bekle, o mu...?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIE_STAGE_POST
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIE_STAGE_POST"
