msgctxt "STRINGS.SKIN_DESCRIPTIONS.sisturn_nest"
msgid "Nestled in beautiful nature, there is nothing natural about losing someone so young."
msgstr "Güzel doğanın bağrına kuruludur, ama bu kadar genç birini kaybetmenin doğal yanı yoktur."

