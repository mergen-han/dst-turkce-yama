msgstr "Ben artık gidiyorum."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_RECHARGERHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_RECHARGERHAT"
msgid "Those crystals will quicken my abilities."
msgstr "O kristaller yeteneklerimi hızlandıracak."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_SPAWNER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_SPAWNER"
