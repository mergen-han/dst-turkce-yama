#. STRINGS.SKIN_DESCRIPTIONS.warly_masquerade
msgctxt "STRINGS.SKIN_DESCRIPTIONS.warly_masquerade"
msgid "This mysterious gentleman has whipped up a cracking ensemble."
msgstr "Bu gizemli beyefendi nefis bir kıyafet hazırlamış."

#. STRINGS.SKIN_DESCRIPTIONS.warly_nature
msgctxt "STRINGS.SKIN_DESCRIPTIONS.warly_nature"
msgid "Warly has found a deep appreciation for the natural world and all it provides."
msgstr "Warly doğal dünyaya ve sunduğu her şeye derin bir saygı duymaya başladı."

#. STRINGS.SKIN_DESCRIPTIONS.warly_none
msgctxt "STRINGS.SKIN_DESCRIPTIONS.warly_none"
