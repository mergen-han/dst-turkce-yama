msgstr "Bir şekilde gerçeğinden daha huysuz görünüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BEEFALO
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BEEFALO"
