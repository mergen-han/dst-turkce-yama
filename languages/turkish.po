msgstr "Eski bir uygarlığı resmediyor. İnsanlar aç ve korkmuş görünüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_2
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_2"
msgid "This tablet is too worn to make out."
msgstr "Bu tablet seçilemeyecek kadar yıpranmış."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_3
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_3"
msgid "Something dark creeps over the city and its people."
msgstr "Karanlık bir şey şehrin ve halkının üzerine sızıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_4
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_4"
