#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUTATOR_WARRIOR
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUTATOR_WARRIOR"
msgid "Oh wow, that looks um... delicious, Webber!"
msgstr "Vay, bu şey... ee... lezzetli görünüyor, Webber!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUTATOR_WATER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUTATOR_WATER"
msgid "Oh wow, that looks um... delicious, Webber!"
msgstr "Vay, bu şey... ee... lezzetli görünüyor, Webber!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.NATURE_BLUEPRINT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.NATURE_BLUEPRINT"
