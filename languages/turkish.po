msgstr "Güç topluyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_GATE.COOLDOWN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_GATE.COOLDOWN"
