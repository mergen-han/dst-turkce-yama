msgstr "İğğrenç. Gerçekçi gibi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MUSE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MUSE"
msgid "Hmm... Looks familiar."
msgstr "Hımm... Tanıdık geliyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_PAWN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_PAWN"
msgid "I can relate."
msgstr "Anlayabiliyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_PIPE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_PIPE"
