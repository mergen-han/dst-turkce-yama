msgstr "Kafandaki bu miğfer onları dehşetle dolduracak."

#. STRINGS.SKIN_DESCRIPTIONS.hat_glommer_costume
msgctxt "STRINGS.SKIN_DESCRIPTIONS.hat_glommer_costume"
