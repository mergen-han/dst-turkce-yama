msgstr "Yapım aşamasında bir mantar bulutu!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUSHROOMHAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUSHROOMHAT"
