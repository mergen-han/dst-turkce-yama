msgstr "Hey! Geri dönmen lazım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_CARRAT_ERROR_WRONG_WAY.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_CARRAT_ERROR_WRONG_WAY.2"
