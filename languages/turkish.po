msgstr "Sanırım yeni en sevdiğim böcek türüm var!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNINGGOAT.CHARGED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNINGGOAT.CHARGED"
