#. STRINGS.UI.OPTIONS.TITLE
msgctxt "STRINGS.UI.OPTIONS.TITLE"
msgid "Game Options"
msgstr "Oyun Ayarları"

#. STRINGS.UI.OPTIONS.TOOLTIPS.ADVANCED
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.ADVANCED"
msgid "Modify advanced features of the game and user interface"
msgstr "Oyunun ve kullanıcı arayüzünün gelişmiş özelliklerini değiştir"

#. STRINGS.UI.OPTIONS.TOOLTIPS.AMBIENT
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.AMBIENT"
msgid "The environment makes noise too, luckily you can control how loudly it does."
msgstr "Çevre de ses çıkarır, şükür ki bunun ne kadar yüksek olduğunu kontrol edebiliyorsun."

#. STRINGS.UI.OPTIONS.TOOLTIPS.ANIMATED_HEADS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.ANIMATED_HEADS"
msgid "Animates the survivor's heads in the menus."
msgstr "Menülerdeki hayatta kalanların kafalarını canlandırır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.AUTOLOGIN
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.AUTOLOGIN"
msgid "Log into your Klei account automatically when booting up Don't Starve Together."
msgstr "Don't Starve Together'ı başlatırken Klei hesabına otomatik giriş yap."

#. STRINGS.UI.OPTIONS.TOOLTIPS.AUTOMODS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.AUTOMODS"
msgid "Keep up to date with the mods of all the servers you join."
msgstr "Katıldığın tüm sunucuların modlarını güncel tut."

#. STRINGS.UI.OPTIONS.TOOLTIPS.AUTOPAUSE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.AUTOPAUSE"
msgid "When you are the only player in the world, this will pause the game while you are in the ingame menus, crafting, or viewing the cookbook or plant registry. If there are other players in the world, only the server admin will have permissions to pause the game."
msgstr "Dünyada tek oyuncuysan, oyun içi menülerdeyken, üretim yaparken veya yemek kitabı ya da bitki kayıtlarına bakarken oyunu duraklatır. Dünyada başka oyuncular varsa, oyunu duraklatma yetkisine sadece sunucu yöneticisi sahip olur."

#. STRINGS.UI.OPTIONS.TOOLTIPS.AXISALIGNEDPLACEMENT
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.AXISALIGNEDPLACEMENT"
msgid "Structures and other deployables will automatically lock to a grid for making buildings look structured."
msgstr "Yapılar ve diğer yerleştirilebilirler, binaların düzenli görünmesi için otomatik olarak ızgaraya kilitlenir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.AXISALIGNEDPLACEMENTINTERVALS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.AXISALIGNEDPLACEMENTINTERVALS"
msgid "This sets how big the grid is between each, measured in common units such as Wall width or Tile width."
msgstr "Bu, ızgaranın aralarındaki boyutu Duvar genişliği veya Karo genişliği gibi yaygın birimlerle ayarlar."

#. STRINGS.UI.OPTIONS.TOOLTIPS.BACKPACKMODE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.BACKPACKMODE"
msgid "Change how the contents of the backpack are displayed. Integrated with the inventory bar or separated at the side of the screen."
msgstr "Sırt çantasının içeriğinin nasıl gösterileceğini değiştir. Envanter çubuğuyla bütünleşik veya ekranın yanında ayrı."

#. STRINGS.UI.OPTIONS.TOOLTIPS.BLOOM
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.BLOOM"
msgid "Increases the visual intensity of lights."
msgstr "Işıkların görsel yoğunluğunu artırır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.BOATCAMERA
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.BOATCAMERA"
msgid "Allows the camera to focus on your boat while sailing."
msgstr "Yelken açarken kameranın teknene odaklanmasına izin verir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.BOATHOPDELAY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.BOATHOPDELAY"
msgid "Adjust how much time is needed to start hopping onto and off of a boat."
msgstr "Bir tekneye atlamak ve ondan inmek için ne kadar süre gerektiğini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CINEMATICS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CINEMATICS"
msgid "Sit back and watch a video"
msgstr "Arkana yaslan ve bir video izle"

#. STRINGS.UI.OPTIONS.TOOLTIPS.COMMANDWHEEL
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.COMMANDWHEEL"
msgid "Allows you to control your player movement and the Social Menu independently."
msgstr "Oyuncu hareketini ve Sosyal Menüyü bağımsız kontrol etmeni sağlar."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONSOLEAUTOPAUSE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONSOLEAUTOPAUSE"
msgid "Allows the server to auto-pause while the console screen is open."
msgstr "Konsol ekranı açıkken sunucunun otomatik duraklamasına izin verir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLLER_AUDIO
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLLER_AUDIO"
msgid "Enable audio from your wireless controller at key gameplay moments."
msgstr "Önemli oynanış anlarında kablosuz kontrolcünden ses çıkışını etkinleştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLLER_LAYOUT
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLLER_LAYOUT"
msgid "Use the default controls or customize them to your liking."
msgstr "Varsayılan kontrolleri kullan veya zevkine göre özelleştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS"
msgid "Rebind which input does which in-game action"
msgstr "Hangi girişin oyun içi hangi eyleme yapacağını yeniden ata"

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_CONSOLE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_CONSOLE"
msgid "Check which control does which in-game action"
msgstr "Hangi kontrolün oyun içi hangi eyleme yaptığını kontrol et"

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.10
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.10"
msgid "Move the camera farther from your character."
msgstr "Kamerayı karakterinden uzaklaştır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.11
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.11"
msgid "Rotate the camera to the left."
msgstr "Kamerayı sola döndür."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.12
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.12"
msgid "Rotate the camera to the right."
msgstr "Kamerayı sağa döndür."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.13
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.13"
msgid "Pause and Unpause the game."
msgstr "Oyunu Duraklat ve Devam Ettir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.14
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.14"
msgid "Open and Close the minimap"
msgstr "Mini haritayı Aç ve Kapat"

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.3
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.3"
msgid "Inspect the current target."
msgstr "Mevcut hedefi incele."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.45
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.45"
msgid "Open and Close the inventory bar."
msgstr "Envanter çubuğunu Aç ve Kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.46
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.46"
msgid "Open and Close the crafting menu."
msgstr "Üretim menüsünü Aç ve Kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.51
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.51"
msgid "Examine the selected inventory item."
msgstr "Seçili envanter eşyasını incele."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.52
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.52"
msgid "Use the selected inventory item on yourself."
msgstr "Seçili envanter eşyasını kendinde kullan."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.53
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.53"
msgid "Use the selected inventory item on the world."
msgstr "Seçili envanter eşyasını dünyada kullan."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.54
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.54"
msgid "Drop the selected inventory item."
msgstr "Seçili envanter eşyasını bırak."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.55
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.55"
msgid "Put part of the selected stack of inventory items into another inventory slot."
msgstr "Seçili envanter eşya yığınının bir kısmını başka bir envanter slotuna koy."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.56
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.56"
msgid "Attack the current target."
msgstr "Mevcut hedefe saldır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.57
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.57"
msgid "Perform the default action on the current target."
msgstr "Mevcut hedefte varsayılan eylemi gerçekleştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.58
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.58"
msgid "Perform an alternate action on the current target (when applicable)."
msgstr "Mevcut hedefte alternatif bir eylem gerçekleştir (uygun olduğunda)."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.59
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.59"
msgid "Use the selected inventory item on another."
msgstr "Seçili envanter eşyasını başkasında kullan."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.60
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.60"
msgid "Zoom in while using the minimap."
msgstr "Mini harita kullanırken yakınlaştır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.61
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.61"
msgid "Zoom out while using the minimap."
msgstr "Mini harita kullanırken uzaklaştır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.87
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.87"
msgid "Open and Close the Social Menu."
msgstr "Sosyal Menüyü Aç ve Kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.88
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.88"
msgid "Lock on to the current target."
msgstr "Mevcut hedefe kilitlen."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.89
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.89"
msgid "Lock on to the next available target."
msgstr "Sonraki uygun hedefe kilitlen."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.9
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.9"
msgid "Move the camera closer to your character."
msgstr "Kamerayı karakterine yaklaştır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROL_SCHEME_CAM_AND_INV
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROL_SCHEME_CAM_AND_INV"
msgid "Choose between control schemes for the camera, inventory, and aiming."
msgstr "Kamera, envanter ve nişan alma için kontrol şemaları arasından seç."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGAUTOPAUSE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGAUTOPAUSE"
msgid "When you are the only player in the world, this will pause the game while the crafting menu is open."
msgstr "Dünyada tek oyuncuysan, üretim menüsü açıkken oyunu duraklatır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGHINTALLRECIPES
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGHINTALLRECIPES"
msgid "Preview the next available research tier or show all locked recipes."
msgstr "Sonraki uygun araştırma kademesini önizle veya tüm kilitli tarifleri göster."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUBUFFEREDBUILDAUTOCLOSE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUBUFFEREDBUILDAUTOCLOSE"
msgid "Closes the crafting menu when building a structure that is placed in the world."
msgstr "Dünyaya yerleştirilen bir yapı inşa ederken üretim menüsünü kapatır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUNUMPINPAGES
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUNUMPINPAGES"
msgid "Set how many pages of pinned recipes you would like to cycle through."
msgstr "Kaç sayfa sabitlenmiş tarif arasında dolaşmak istediğini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUSENSITIVITY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUSENSITIVITY"
msgid "Adjust the input sensitivity while navigating through the crafting menu."
msgstr "Üretim menüsünde gezinirken giriş hassasiyetini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUSIZE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUSIZE"
msgid "Customize the size of the crafting menu."
msgstr "Üretim menüsünün boyutunu özelleştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DATACOLLECTION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DATACOLLECTION"
msgid "We collect metrics and telemetry on Don't Starve Together, including how long and how often you play. This information helps us troubleshoot the game, provide rewards, and improve your experience. Refer to https://www.klei.com/privacy-policy for more information."
msgstr "Don't Starve Together hakkında, ne kadar süre ve ne sıklıkla oynadığın dahil metrik ve telemetri toplarız. Bu bilgi oyunu hata ayıklamamıza, ödül vermemize ve deneyimini iyileştirmemize yardımcı olur. Daha fazla bilgi için https://www.klei.com/privacy-policy adresine bak."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DEFAULTCLOUDSAVES
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DEFAULTCLOUDSAVES"
msgid "Chooses whether new saves will be stored in the cloud or not by default."
msgstr "Yeni kayıtların varsayılan olarak bulutta saklanıp saklanmayacağını seçer."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DISPLAY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DISPLAY"
msgid "Got multiple screens? We've got you covered, choose where the game window goes when playing the game. (Fullscreen only)"
msgstr "Birden fazla ekranın mı var? Halletmişiz, oyun oynarken oyun penceresinin nereye gideceğini seç. (Sadece Tam Ekran)"

#. STRINGS.UI.OPTIONS.TOOLTIPS.DISPLAYAREA
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DISPLAYAREA"
msgid "Maximize the screen size on your display."
msgstr "Ekranındaki ekran boyutunu maksimuma çıkar."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DISTORTION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DISTORTION"
msgid "Allows you to turn off screen distortions in the game, especially notable during moments of insanity."
msgstr "Oyundaki, özellikle akıl yitimi anlarında belirgin olan ekran bozulmalarını kapatmana izin verir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DYNAMIC_TREE_SHADOWS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DYNAMIC_TREE_SHADOWS"
msgid "Renders the ground shadow while under a canopy."
msgstr "Bir tepe altındayken zemin gölgesini işler."

#. STRINGS.UI.OPTIONS.TOOLTIPS.FULLSCREEN
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.FULLSCREEN"
msgid "Fill your screen with Don't Starve Together."
msgstr "Ekranını Don't Starve Together ile doldur."

#. STRINGS.UI.OPTIONS.TOOLTIPS.FX
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.FX"
msgid "Change how loud things are in the world."
msgstr "Dünyadaki şeylerin ne kadar yüksek olduğunu değiştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.GRAPHICS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.GRAPHICS"
msgid "Modify the graphics settings"
msgstr "Grafik ayarlarını değiştir"

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_BOSS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_BOSS"
msgid "Toggle haptic effects from boss enemy actions."
msgstr "Boss düşman eylemlerinden gelen dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_DANGER
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_DANGER"
msgid "Toggle haptic effects when your character is in danger."
msgstr "Karakterin tehlikedeyken dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_ENVIRO
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_ENVIRO"
msgid "Toggle haptic effects from the environment."
msgstr "Çevreden gelen dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_PLAYER
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_PLAYER"
msgid "Toggle haptic effects from your character's actions."
msgstr "Karakterinin eylemlerinden gelen dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_UI
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_UI"
msgid "Toggle haptic effects from interacting with the user interface."
msgstr "Kullanıcı arayüzü ile etkileşimden gelen dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_STRENGTH
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_STRENGTH"
msgid "Adjust the strength of haptic effects."
msgstr "Dokunsal efektlerin şiddetini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HUD
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HUD"
msgid "Modify features of the user interface"
msgstr "Kullanıcı arayüzünün özelliklerini değiştir"

#. STRINGS.UI.OPTIONS.TOOLTIPS.HUDSIZE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HUDSIZE"
msgid "Customize the size of your Heads Up Display."
msgstr "HUD ekranının boyutunu özelleştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.INPUT
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.INPUT"
msgid "Controller or Keyboard? Play Don't Starve Together your way."
msgstr "Kontrolcü mü yoksa Klavye mi? Don't Starve Together'ı kendi tarzında oyna."

#. STRINGS.UI.OPTIONS.TOOLTIPS.INVENTORYSENSITIVITY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.INVENTORYSENSITIVITY"
msgid "Adjust the input sensitivity while navigating through the inventory."
msgstr "Envanterde gezinirken giriş hassasiyetini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.INVERTCAMERAROTATION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.INVERTCAMERAROTATION"
msgid "Flips the camera rotation direction."
msgstr "Kamera dönüş yönünü ters çevirir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.LANGUAGES
