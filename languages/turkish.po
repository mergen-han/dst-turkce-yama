msgstr "Seçili envanter eşyasını başkasında kullan."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.60
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.60"
msgid "Zoom in while using the minimap."
msgstr "Mini harita kullanırken yakınlaştır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.61
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.61"
msgid "Zoom out while using the minimap."
msgstr "Mini harita kullanırken uzaklaştır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.87
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.87"
msgid "Open and Close the Social Menu."
msgstr "Sosyal Menüyü Aç ve Kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.88
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.88"
msgid "Lock on to the current target."
msgstr "Mevcut hedefe kilitlen."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.89
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.89"
msgid "Lock on to the next available target."
msgstr "Sonraki uygun hedefe kilitlen."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.9
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROLS_EDITOR.9"
msgid "Move the camera closer to your character."
msgstr "Kamerayı karakterine yaklaştır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CONTROL_SCHEME_CAM_AND_INV
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CONTROL_SCHEME_CAM_AND_INV"
msgid "Choose between control schemes for the camera, inventory, and aiming."
msgstr "Kamera, envanter ve nişan alma için kontrol şemaları arasından seç."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGAUTOPAUSE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGAUTOPAUSE"
msgid "When you are the only player in the world, this will pause the game while the crafting menu is open."
msgstr "Dünyada tek oyuncuysan, üretim menüsü açıkken oyunu duraklatır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGHINTALLRECIPES
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGHINTALLRECIPES"
msgid "Preview the next available research tier or show all locked recipes."
msgstr "Sonraki uygun araştırma kademesini önizle veya tüm kilitli tarifleri göster."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUBUFFEREDBUILDAUTOCLOSE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUBUFFEREDBUILDAUTOCLOSE"
msgid "Closes the crafting menu when building a structure that is placed in the world."
msgstr "Dünyaya yerleştirilen bir yapı inşa ederken üretim menüsünü kapatır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUNUMPINPAGES
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUNUMPINPAGES"
msgid "Set how many pages of pinned recipes you would like to cycle through."
msgstr "Kaç sayfa sabitlenmiş tarif arasında dolaşmak istediğini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUSENSITIVITY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUSENSITIVITY"
msgid "Adjust the input sensitivity while navigating through the crafting menu."
msgstr "Üretim menüsünde gezinirken giriş hassasiyetini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUSIZE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.CRAFTINGMENUSIZE"
msgid "Customize the size of the crafting menu."
msgstr "Üretim menüsünün boyutunu özelleştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DATACOLLECTION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DATACOLLECTION"
msgid "We collect metrics and telemetry on Don't Starve Together, including how long and how often you play. This information helps us troubleshoot the game, provide rewards, and improve your experience. Refer to https://www.klei.com/privacy-policy for more information."
msgstr "Don't Starve Together hakkında, ne kadar süre ve ne sıklıkla oynadığın dahil metrik ve telemetri toplarız. Bu bilgi oyunu hata ayıklamamıza, ödül vermemize ve deneyimini iyileştirmemize yardımcı olur. Daha fazla bilgi için https://www.klei.com/privacy-policy adresine bak."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DEFAULTCLOUDSAVES
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DEFAULTCLOUDSAVES"
msgid "Chooses whether new saves will be stored in the cloud or not by default."
msgstr "Yeni kayıtların varsayılan olarak bulutta saklanıp saklanmayacağını seçer."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DISPLAY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DISPLAY"
msgid "Got multiple screens? We've got you covered, choose where the game window goes when playing the game. (Fullscreen only)"
msgstr "Birden fazla ekranın mı var? Halletmişiz, oyun oynarken oyun penceresinin nereye gideceğini seç. (Sadece Tam Ekran)"

#. STRINGS.UI.OPTIONS.TOOLTIPS.DISPLAYAREA
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DISPLAYAREA"
msgid "Maximize the screen size on your display."
msgstr "Ekranındaki ekran boyutunu maksimuma çıkar."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DISTORTION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DISTORTION"
msgid "Allows you to turn off screen distortions in the game, especially notable during moments of insanity."
msgstr "Oyundaki, özellikle akıl yitimi anlarında belirgin olan ekran bozulmalarını kapatmana izin verir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.DYNAMIC_TREE_SHADOWS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.DYNAMIC_TREE_SHADOWS"
msgid "Renders the ground shadow while under a canopy."
msgstr "Bir tepe altındayken zemin gölgesini işler."

#. STRINGS.UI.OPTIONS.TOOLTIPS.FULLSCREEN
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.FULLSCREEN"
msgid "Fill your screen with Don't Starve Together."
msgstr "Ekranını Don't Starve Together ile doldur."

#. STRINGS.UI.OPTIONS.TOOLTIPS.FX
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.FX"
msgid "Change how loud things are in the world."
msgstr "Dünyadaki şeylerin ne kadar yüksek olduğunu değiştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.GRAPHICS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.GRAPHICS"
msgid "Modify the graphics settings"
msgstr "Grafik ayarlarını değiştir"

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_BOSS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_BOSS"
msgid "Toggle haptic effects from boss enemy actions."
msgstr "Boss düşman eylemlerinden gelen dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_DANGER
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_DANGER"
msgid "Toggle haptic effects when your character is in danger."
msgstr "Karakterin tehlikedeyken dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_ENVIRO
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_ENVIRO"
msgid "Toggle haptic effects from the environment."
msgstr "Çevreden gelen dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_PLAYER
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_PLAYER"
msgid "Toggle haptic effects from your character's actions."
msgstr "Karakterinin eylemlerinden gelen dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_UI
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_EFFECTS_UI"
msgid "Toggle haptic effects from interacting with the user interface."
msgstr "Kullanıcı arayüzü ile etkileşimden gelen dokunsal efektleri aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_STRENGTH
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HAPTICS_STRENGTH"
msgid "Adjust the strength of haptic effects."
msgstr "Dokunsal efektlerin şiddetini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.HUD
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HUD"
msgid "Modify features of the user interface"
msgstr "Kullanıcı arayüzünün özelliklerini değiştir"

#. STRINGS.UI.OPTIONS.TOOLTIPS.HUDSIZE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.HUDSIZE"
msgid "Customize the size of your Heads Up Display."
msgstr "HUD ekranının boyutunu özelleştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.INPUT
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.INPUT"
msgid "Controller or Keyboard? Play Don't Starve Together your way."
msgstr "Kontrolcü mü yoksa Klavye mi? Don't Starve Together'ı kendi tarzında oyna."

#. STRINGS.UI.OPTIONS.TOOLTIPS.INVENTORYSENSITIVITY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.INVENTORYSENSITIVITY"
msgid "Adjust the input sensitivity while navigating through the inventory."
msgstr "Envanterde gezinirken giriş hassasiyetini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.INVERTCAMERAROTATION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.INVERTCAMERAROTATION"
msgid "Flips the camera rotation direction."
msgstr "Kamera dönüş yönünü ters çevirir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.LANGUAGES
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.LANGUAGES"
msgid "Select display language"
msgstr "Görüntü dilini seç"

#. STRINGS.UI.OPTIONS.TOOLTIPS.LOADING_TIPS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.LOADING_TIPS"
msgid "Learn more about the lore and the gameplay of Don't Starve while your world loads."
msgstr "Dünyan yüklenirken Don't Starve'ın hikâyesi ve oynanışı hakkında daha fazla bilgi edin."

#. STRINGS.UI.OPTIONS.TOOLTIPS.MINIMAPZOOMCURSOR
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.MINIMAPZOOMCURSOR"
msgid "Zooming on the minimap will focus where the cursor is located."
msgstr "Mini haritada yakınlaştırma, imlecin bulunduğu yere odaklanır."

#. STRINGS.UI.OPTIONS.TOOLTIPS.MINIMAPZOOMSENSITIVITY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.MINIMAPZOOMSENSITIVITY"
msgid "Adjust the input sensitivity while zooming in and out on the minimap."
msgstr "Mini haritada yakınlaştırıp uzaklaştırırken giriş hassasiyetini ayarla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.MORE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.MORE"
msgid "View additional options"
msgstr "Ek seçenekleri görüntüle"

#. STRINGS.UI.OPTIONS.TOOLTIPS.MOVEMENTPREDICTION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.MOVEMENTPREDICTION"
msgid "Allows the game to predict your movements to compensate for any possible lag."
msgstr "Olası gecikmeyi telafi etmek için oyunun hareketlerini tahmin etmesine izin verir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.MUSIC
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.MUSIC"
msgid "Tone up or down the musical fanfare in your adventures."
msgstr "Maceralarındaki müzikal fanfarın tonunu yükselt veya düşür."

#. STRINGS.UI.OPTIONS.TOOLTIPS.NETBOOKMODE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.NETBOOKMODE"
msgid "Reduces the game's update frequency. (Only recommended for min-spec computers)"
msgstr "Oyunun güncelleme sıklığını azaltır. (Yalnızca minimum sistem gereksinimli bilgisayarlar için tavsiye edilir)"

#. STRINGS.UI.OPTIONS.TOOLTIPS.NPCCHAT
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.NPCCHAT"
msgid "Allows key dialogue from creatures in the world to be displayed in the chat box."
msgstr "Dünyadaki yaratıkların önemli diyaloglarının sohbet kutusunda gösterilmesine izin verir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.POIDISPLAY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.POIDISPLAY"
msgid "Hide all the Point of Interest Icons."
msgstr "Tüm İlgi Noktası Simgelerini gizle."

#. STRINGS.UI.OPTIONS.TOOLTIPS.PROMOTIONS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.PROMOTIONS"
msgid "Display store promotions in the main menus."
msgstr "Ana menülerde mağaza tanıtımlarını göster."

#. STRINGS.UI.OPTIONS.TOOLTIPS.REFRESHRATE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.REFRESHRATE"
msgid "Customize how many times per second the game screen refreshes. (Fullscreen only)"
msgstr "Oyun ekranının saniyede kaç kez yenileneceğini özelleştir. (Sadece Tam Ekran)"

#. STRINGS.UI.OPTIONS.TOOLTIPS.RESOLUTION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.RESOLUTION"
msgid "Change the game screen resolution. (Fullscreen only)"
msgstr "Oyun ekran çözünürlüğünü değiştir. (Sadece Tam Ekran)"

#. STRINGS.UI.OPTIONS.TOOLTIPS.SCAPBOOKHUDDISPLAY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SCAPBOOKHUDDISPLAY"
msgid "Toggle HUD notifications from the Scrapbook on and off."
msgstr "Karalama Defteri'nden gelen HUD bildirimlerini aç/kapat."

#. STRINGS.UI.OPTIONS.TOOLTIPS.SCREENSHAKE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SCREENSHAKE"
msgid "Keep your camera static or allow it to shake freely in moments of high intensity."
msgstr "Kameranı sabit tut veya yüksek yoğunluk anlarında özgürce sallanmasına izin ver."

#. STRINGS.UI.OPTIONS.TOOLTIPS.SCREEN_FLASH_INTENSITY
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SCREEN_FLASH_INTENSITY"
msgid "Control the intensity of screen flashes during explosions and lightning strikes."
msgstr "Patlamalar ve yıldırım çarpmaları sırasındaki ekran parlamalarının yoğunluğunu kontrol et."

#. STRINGS.UI.OPTIONS.TOOLTIPS.SCREEN_FLASH_INTENSITY_SWITCH
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SCREEN_FLASH_INTENSITY_SWITCH"
msgid "Control the intensity of flashing effects during explosions and lightning strikes."
msgstr "Patlamalar ve yıldırım çarpmaları sırasındaki yanıp sönen efektlerin yoğunluğunu kontrol et."

#. STRINGS.UI.OPTIONS.TOOLTIPS.SERVER_NAME_PROFANITY_CHAT_FILTER
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SERVER_NAME_PROFANITY_CHAT_FILTER"
msgid "Use Steam's chat filters. This can be configured in Steam's setting in the section In-Game under Chat Filtering."
msgstr "Steam sohbet filtrelerini kullan. Bu, Steam ayarlarında Oyun İçi bölümünün altındaki Sohbet Filtreleme'de yapılandırılabilir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.SERVER_NAME_PROFANITY_FILTER
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SERVER_NAME_PROFANITY_FILTER"
msgid "Filter out the profanity when browsing the server list. Filtered servers will have their names displayed as \"This server name has been filtered\" and can still be joined."
msgstr "Sunucu listesine göz atarken küfürleri filtrele. Filtrelenen sunucuların adları \"Bu sunucu adı filtrelendi\" olarak gösterilir ve hâlâ katılınabilir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.SETTINGS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SETTINGS"
msgid "Modify features of the game and user interface"
msgstr "Oyunun ve kullanıcı arayüzünün özelliklerini değiştir"

#. STRINGS.UI.OPTIONS.TOOLTIPS.SHOWPASSWORD
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SHOWPASSWORD"
msgid "Show or hide your passwords."
msgstr "Parolalarını göster veya gizle."

#. STRINGS.UI.OPTIONS.TOOLTIPS.SMALLTEXTURES
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SMALLTEXTURES"
msgid "Reduces texture quality for better performance. (Only recommended for min-spec computers)"
msgstr "Daha iyi performans için doku kalitesini düşürür. (Yalnızca minimum sistem gereksinimli bilgisayarlar için tavsiye edilir)"

#. STRINGS.UI.OPTIONS.TOOLTIPS.SMALLTEXTURES_CONSOLE
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.SMALLTEXTURES_CONSOLE"
msgid "Reduces texture quality for better performance.\n(Only recommended if you're having problems with your world)"
msgstr "Daha iyi performans için doku kalitesini düşürür.\n(Yalnızca dünyanla ilgili sorun yaşıyorsan tavsiye edilir)"

#. STRINGS.UI.OPTIONS.TOOLTIPS.TARGETLOCKING
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.TARGETLOCKING"
msgid "Focus on one target at a time."
msgstr "Bir seferde tek bir hedefe odaklan."

#. STRINGS.UI.OPTIONS.TOOLTIPS.TEXTURESTREAMING
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.TEXTURESTREAMING"
msgid "Reduces the memory overhead for textures. Enabling this should improve performance."
msgstr "Dokular için bellek yükünü azaltır. Bunu etkinleştirmek performansı iyileştirir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.THREADEDRENDER
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.THREADEDRENDER"
msgid "Renders the game on a different core. Enabling this should improve performance."
msgstr "Oyunu farklı bir çekirdekte işler. Bunu etkinleştirmek performansı iyileştirir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.VIBRATION
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.VIBRATION"
msgid "Make your controller vibrate at key gameplay moments."
msgstr "Önemli oynanış anlarında kontrolcünün titremesini sağla."

#. STRINGS.UI.OPTIONS.TOOLTIPS.VIBRATION_WIRELESS
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.VIBRATION_WIRELESS"
msgid "Enable vibration of your wireless controller at key gameplay moments."
msgstr "Önemli oynanış anlarında kablosuz kontrolcünün titreşimini etkinleştir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.WALTERCAMERA
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.WALTERCAMERA"
msgid "Allows the camera to focus on Walter while he tells campfire stories."
msgstr "Walter kamp ateşi hikâyeleri anlatırken kameranın ona odaklanmasına izin verir."

#. STRINGS.UI.OPTIONS.TOOLTIPS.WATHGRITHRFONT
msgctxt "STRINGS.UI.OPTIONS.TOOLTIPS.WATHGRITHRFONT"
msgid "Replaces Wigfrid's o's with ö's when she speaks."
msgstr "Wigfrid konuşurken o harflerini ö ile değiştirir."

#. STRINGS.UI.OPTIONS.VERSION
msgctxt "STRINGS.UI.OPTIONS.VERSION"
msgid "Version"
msgstr "Sürüm"

#. STRINGS.UI.OPTIONS.VIBRATION
msgctxt "STRINGS.UI.OPTIONS.VIBRATION"
msgid "Vibration:"
msgstr "Titreşim:"

#. STRINGS.UI.OPTIONS.VIDEO_CHANNEL
msgctxt "STRINGS.UI.OPTIONS.VIDEO_CHANNEL"
msgid "More Klei Videos"
msgstr "Daha Fazla Klei Videosu"

#. STRINGS.UI.OPTIONS.WALTERCAMERA
msgctxt "STRINGS.UI.OPTIONS.WALTERCAMERA"
msgid "Campfire Camera:"
msgstr "Kamp Ateşi Kamerası:"

#. STRINGS.UI.OPTIONS.WATHGRITHRFONT
msgctxt "STRINGS.UI.OPTIONS.WATHGRITHRFONT"
msgid "Wigfrid's Umlauts:"
msgstr "Wigfrid'in Umlautları:"

#. STRINGS.UI.OPTIONS.WEAK
msgctxt "STRINGS.UI.OPTIONS.WEAK"
msgid "Weak"
msgstr "Zayıf"

#. STRINGS.UI.OPTIONS.XB1_CONTROLLER_LAYOUT
msgctxt "STRINGS.UI.OPTIONS.XB1_CONTROLLER_LAYOUT"
msgid "Gamepad Layout:"
msgstr "Gamepad Düzeni:"

#. STRINGS.UI.OPTIONS.YES
msgctxt "STRINGS.UI.OPTIONS.YES"
msgid "Yes"
msgstr "Evet"

#. STRINGS.UI.PAUSEMENU.AFK
msgctxt "STRINGS.UI.PAUSEMENU.AFK"
msgid "Go AFK"
msgstr "Mola Ver"

#. STRINGS.UI.PAUSEMENU.AUTOPAUSED_DST_TITLE
msgctxt "STRINGS.UI.PAUSEMENU.AUTOPAUSED_DST_TITLE"
msgid "Auto-Paused!"
msgstr "Otomatik Duraklatıldı!"

