msgstr "Sarılmak istiyorum, ama taş tahriş ediyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MINOTAUR
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MINOTAUR"
msgid "Now you're the one scared stiff!"
msgstr "Şimdi sıkışıp donmuş olan sensin!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MOON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MOON"
msgid "I've been feeling pretty inspired lately."
msgstr "Son zamanlarda epey ilhamlı hissediyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MOOSEGOOSE.1
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_MOOSEGOOSE.1"
