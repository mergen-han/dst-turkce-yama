msgstr "Gerçekten huzursuz edici bir ışık."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_OVERGROWTH
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_OVERGROWTH"
