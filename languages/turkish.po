msgstr "Muhtemelen yapmamalıyım..."

#. STRINGS.CHARACTERS.WALTER.ACTIONFAIL.WRITE.INUSE
msgctxt "STRINGS.CHARACTERS.WALTER.ACTIONFAIL.WRITE.INUSE"
msgid "Hey! What are you writing?"
msgstr "Hey! Ne yazıyorsun?"

#. STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_STARTCONTEST.ALREADYACTIVE
msgctxt "STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_STARTCONTEST.ALREADYACTIVE"
msgid "There must be another contest going on somewhere else."
msgstr "Başka bir yerde devam eden bir yarışma olmalı."

#. STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_STARTCONTEST.DOESNTWORK
msgctxt "STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_STARTCONTEST.DOESNTWORK"
msgid "Maybe he took the day off?"
msgstr "Belki bugün izin almıştır?"

#. STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_STARTCONTEST.NORESPONSE
msgctxt "STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_STARTCONTEST.NORESPONSE"
msgid "He must be wandering around somewhere."
msgstr "Bir yerlerde dolaşıyor olmalı."

#. STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_STARTCONTEST.RIGHTTHERE
msgctxt "STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_STARTCONTEST.RIGHTTHERE"
msgid "Busy as a bee—f!"
msgstr "Arı gibi—f meşgul!"

#. STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_UNLOCKSKIN.ALREADYKNOWN
msgctxt "STRINGS.CHARACTERS.WALTER.ACTIONFAIL.YOTB_UNLOCKSKIN.ALREADYKNOWN"
msgid "We already know this one, don't we Woby?"
msgstr "Bunu zaten biliyoruz, değil mi Woby?"

#. STRINGS.CHARACTERS.WALTER.ACTIONFAIL_GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.ACTIONFAIL_GENERIC"
msgid "It won't work."
msgstr "İşe yaramayacak."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ACCOMPLISHMENT
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ACCOMPLISHMENT"
msgid "I did it!"
msgstr "Başardım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ACCOMPLISHMENT_DONE
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ACCOMPLISHMENT_DONE"
msgid "If I were back home, I'd get a badge for that!"
msgstr "Evde olsaydım bunun için bir rozet alırdım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ACIDBATS
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ACIDBATS"
msgid "Here they come!"
msgstr "İşte geliyorlar!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ADVENTUREFAIL
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ADVENTUREFAIL"
msgid "Perseverance is the Pinetree Pioneer way!"
msgstr "Azim, Çamağacı Öncüsü'nün yoludur!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_AMMO_SLOT_OVERSTACKED
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_AMMO_SLOT_OVERSTACKED"
msgid "There's too much ammo to swap out now."
msgstr "Şimdi değiştirmek için fazla mermi var."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_SINKHOLE.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_SINKHOLE.1"
msgid "Woah!"
msgstr "Vay!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_SINKHOLE.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_SINKHOLE.2"
msgid "I think there's something moving underground!"
msgstr "Sanırım yer altında bir şey hareket ediyor!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_SINKHOLE.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_SINKHOLE.3"
msgid "Hang on, I'm sure my handbook says what to do in an earthquake!"
msgstr "Bekle, eminim el kitabım depremde ne yapacağımı söylüyor!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_TRIBUTE.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_TRIBUTE.1"
msgid "I brought you something!"
msgstr "Sana bir şey getirdim!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_TRIBUTE.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_TRIBUTE.2"
msgid "This is for you!"
msgstr "Bu senin için!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_TRIBUTE.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ANTLION_TRIBUTE.3"
msgid "Woah... you're amazing!"
msgstr "Vay... harikasın!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ARCHIVE_NEW_KNOWLEDGE
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ARCHIVE_NEW_KNOWLEDGE"
msgid "Huh? It's giving me instructions!"
msgstr "Ha? Bana talimatlar veriyor!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ARCHIVE_NO_POWER
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ARCHIVE_NO_POWER"
msgid "Hm, it doesn't look like it's working."
msgstr "Hmm, çalışıyor gibi görünmüyor."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ARCHIVE_OLD_KNOWLEDGE
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ARCHIVE_OLD_KNOWLEDGE"
msgid "I knew that one already."
msgstr "Onu zaten biliyordum."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATRIUM_DESTABILIZING.1
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATRIUM_DESTABILIZING.1"
msgid "Woah! What's happening?"
msgstr "Vay! Neler oluyor?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATRIUM_DESTABILIZING.2
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATRIUM_DESTABILIZING.2"
msgid "Don't be scared, Woby!"
msgstr "Korkma, Woby!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATRIUM_DESTABILIZING.3
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATRIUM_DESTABILIZING.3"
msgid "Hey... I think this might not be safe."
msgstr "Hey... sanırım bu güvenli olmayabilir."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_ATTACK
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_ATTACK"
msgid "Woah! I feel like I can take on the world!"
msgstr "Vay! Dünyaya kafa tutabilirmişim gibi hissediyorum!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_ELECTRICATTACK
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_ELECTRICATTACK"
msgid "This reminds me of a radio program I heard where a guy was hit by lightning and turned into pure electricity and-"
msgstr "Bu bana radyoda dinlediğim bir programı hatırlattı, bir adama yıldırım çarpmış ve saf elektriğe dönüşmüş ve-"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_MOISTUREIMMUNITY
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_MOISTUREIMMUNITY"
msgid "Nothing's going to rain on my parade! Because I'm waterproof, get it?"
msgstr "Hiçbir şey keyfime yağmur olmayacak! Çünkü su geçirmezim, anladın mı?"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_PLAYERABSORPTION
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_PLAYERABSORPTION"
msgid "I'm invincible!"
msgstr "Yenilmezim!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_SLEEPRESISTANCE
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_SLEEPRESISTANCE"
msgid "Wide awake and ready for anything!"
msgstr "Apaçık uyanık ve her şeye hazır!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_WORKEFFECTIVENESS
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_ATTACH_BUFF_WORKEFFECTIVENESS"
msgid "Come on Woby, let's get to work!"
msgstr "Hadi Woby, işe koyulalım!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_BECOMEGHOST
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_BECOMEGHOST"
msgid "oOooOooo!!"
msgstr "böÖööBöööö!!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_BEES
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_BEES"
msgid "I love bees! Too bad I'm uh... deathly allergic to them."
msgstr "Arıları çok severim! Maalesef şey... onlara ölümcül alerjim var."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_BOAT_LEAK
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_BOAT_LEAK"
msgid "Um. That might be a problem."
msgstr "Eee. Bu sorun olabilir."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_BOAT_SINK
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_BOAT_SINK"
msgid "Better put my swimming badge to good use!"
msgstr "Yüzme rozetimi iyi kullansam iyi olacak!"

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_BOOMERANG
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_BOOMERANG"
