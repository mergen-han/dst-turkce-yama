msgstr "Ne mantar-arsız!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUSHROOMSPROUT.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUSHROOMSPROUT.GENERIC"
msgid "How scientific!"
msgstr "Ne bilimsel!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUSHROOM_FARM.BURNT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MUSHROOM_FARM.BURNT"
