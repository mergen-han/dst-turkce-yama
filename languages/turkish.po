msgstr "Bu 'tazıkemiği beyazı' renkli etek dört saplı düğmeyle kapatılıyor."

#. STRINGS.SKIN_DESCRIPTIONS.legs_skirt_plaid_blue_cornflower
msgctxt "STRINGS.SKIN_DESCRIPTIONS.legs_skirt_plaid_blue_cornflower"
