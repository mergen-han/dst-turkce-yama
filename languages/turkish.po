msgstr "Sanırım dinleniyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAE_EGG.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAE_EGG.GENERIC"
