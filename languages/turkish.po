#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_formalp
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_formalp"
msgid "She resembles a Visigothic princess."
msgstr "Bir Vizigot prensesini andırıyor."

#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_gladiator
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_gladiator"
msgid "The question was never IF Wigfrid would master the ring, but when."
msgstr "Soru hiçbir zaman Wigfrid'in ringi fethedip etmeyeceği değildi, ne zaman fethedeceğiydi."

#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_ice
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_ice"
