msgid "Walls for the lunar loony."
msgstr "Ay delisi için duvarlar."

#. STRINGS.RECIPE_DESC.WALL_RUINS_ITEM
msgctxt "STRINGS.RECIPE_DESC.WALL_RUINS_ITEM"
msgid "These walls will take quite a beating."
msgstr "Bu duvarlar epey dayak yer."

#. STRINGS.RECIPE_DESC.WALL_SCRAP_ITEM
msgctxt "STRINGS.RECIPE_DESC.WALL_SCRAP_ITEM"
msgid "A pile of junk, roughly wall-shaped."
msgstr "Kabaca duvar şeklinde bir hurda yığını."

#. STRINGS.RECIPE_DESC.WALL_STONE_ITEM
msgctxt "STRINGS.RECIPE_DESC.WALL_STONE_ITEM"
msgid "Stone wall segments."
msgstr "Taş duvar parçaları."

#. STRINGS.RECIPE_DESC.WALL_WOOD_ITEM
msgctxt "STRINGS.RECIPE_DESC.WALL_WOOD_ITEM"
msgid "Wooden wall segments."
msgstr "Tahta duvar parçaları."

#. STRINGS.RECIPE_DESC.WALTERHAT
msgctxt "STRINGS.RECIPE_DESC.WALTERHAT"
msgid "Form and function over fashion."
msgstr "Şıklıktan önce şekil ve işlev."

#. STRINGS.RECIPE_DESC.WANDERINGTRADERSHOP_LIVINGLOG
msgctxt "STRINGS.RECIPE_DESC.WANDERINGTRADERSHOP_LIVINGLOG"
msgid "Life wood be a scream..."
msgstr "Hayat ağaçi çığlıktır..."

#. STRINGS.RECIPE_DESC.WARDROBE
msgctxt "STRINGS.RECIPE_DESC.WARDROBE"
msgid "Change your look to suit your mood."
msgstr "Görünüşünü ruh haline göre değiştir."

#. STRINGS.RECIPE_DESC.WARGSHRINE
msgctxt "STRINGS.RECIPE_DESC.WARGSHRINE"
msgid "Make offerings to the earthen Varg."
msgstr "Toprak Varg'a sunularda bulun."

#. STRINGS.RECIPE_DESC.WATERBALLOON
msgctxt "STRINGS.RECIPE_DESC.WATERBALLOON"
msgid "Spheroid fire suppression."
msgstr "Küresel yangın söndürme."

#. STRINGS.RECIPE_DESC.WATERINGCAN
msgctxt "STRINGS.RECIPE_DESC.WATERINGCAN"
msgid "Keep plants happy and hydrated."
msgstr "Bitkileri mutlu ve sulanmış tut."

#. STRINGS.RECIPE_DESC.WATERMELONHAT
msgctxt "STRINGS.RECIPE_DESC.WATERMELONHAT"
msgid "Refreshing, but sticky."
msgstr "Ferahlatıcı ama yapışkan."

#. STRINGS.RECIPE_DESC.WATERPUMP
msgctxt "STRINGS.RECIPE_DESC.WATERPUMP"
msgid "Water, water everywhere!"
msgstr "Su, su her yerde su!"

#. STRINGS.RECIPE_DESC.WATHGRITHRHAT
msgctxt "STRINGS.RECIPE_DESC.WATHGRITHRHAT"
msgid "The unicorn is what protects you."
msgstr "Seni koruyan şey, tek boynuzlu attır."

#. STRINGS.RECIPE_DESC.WATHGRITHR_IMPROVEDHAT
msgctxt "STRINGS.RECIPE_DESC.WATHGRITHR_IMPROVEDHAT"
msgid "A helm fit for a Valkyrie queen."
msgstr "Bir Valkyrie kraliçesine yakışır miğfer."

#. STRINGS.RECIPE_DESC.WATHGRITHR_SHIELD
msgctxt "STRINGS.RECIPE_DESC.WATHGRITHR_SHIELD"
msgid "A shield can be a weapon too, if it believes in itself."
msgstr "Bir kalkan da silah olabilir, kendine inanırsa."

#. STRINGS.RECIPE_DESC.WAXPAPER
msgctxt "STRINGS.RECIPE_DESC.WAXPAPER"
msgid "For wrapping things."
msgstr "Bir şeyleri sarmak için."

#. STRINGS.RECIPE_DESC.WAXWELLJOURNAL
msgctxt "STRINGS.RECIPE_DESC.WAXWELLJOURNAL"
msgid "It'll blow your mind."
msgstr "Aklını başından alır."

#. STRINGS.RECIPE_DESC.WENDY_RECIPE_GRAVESTONE
msgctxt "STRINGS.RECIPE_DESC.WENDY_RECIPE_GRAVESTONE"
msgid "No one deserves an unmarked grave."
msgstr "Hiç kimse mezarsız ölmeyi hak etmez."

#. STRINGS.RECIPE_DESC.WENDY_RESURRECTIONGRAVE
msgctxt "STRINGS.RECIPE_DESC.WENDY_RESURRECTIONGRAVE"
msgid "Death is but an inconvenience."
msgstr "Ölüm sadece bir aksaklıktır."

#. STRINGS.RECIPE_DESC.WEREITEM_BEAVER
msgctxt "STRINGS.RECIPE_DESC.WEREITEM_BEAVER"
msgid "Invokes the curse of the Werebeaver."
msgstr "Kunduzkurt lanetini çağırır."

#. STRINGS.RECIPE_DESC.WEREITEM_GOOSE
msgctxt "STRINGS.RECIPE_DESC.WEREITEM_GOOSE"
msgid "Invokes the curse of the Weregoose."
msgstr "Kazkurt lanetini çağırır."

#. STRINGS.RECIPE_DESC.WEREITEM_MOOSE
msgctxt "STRINGS.RECIPE_DESC.WEREITEM_MOOSE"
msgid "Invokes the curse of the Weremoose."
msgstr "Mooskurt lanetini çağırır."

#. STRINGS.RECIPE_DESC.WHIP
msgctxt "STRINGS.RECIPE_DESC.WHIP"
msgid "Dish out constructive feedback."
msgstr "Yapıcı geri bildirim dağıt."

#. STRINGS.RECIPE_DESC.WINCH
msgctxt "STRINGS.RECIPE_DESC.WINCH"
msgid "Let it do the heavy lifting for you."
msgstr "Ağır işi senin yerine o yapsın."

#. STRINGS.RECIPE_DESC.WINCH_BLUEPRINT
msgctxt "STRINGS.RECIPE_DESC.WINCH_BLUEPRINT"
msgid "For deep sea grabs."
msgstr "Derin deniz tutuşları için."

#. STRINGS.RECIPE_DESC.WINONA_BATTERY_HIGH
msgctxt "STRINGS.RECIPE_DESC.WINONA_BATTERY_HIGH"
msgid "This one uses gems, so you know it's good."
msgstr "Bu cevher kullanır, yani iyi olduğundan emin ol."

#. STRINGS.RECIPE_DESC.WINONA_BATTERY_LOW
msgctxt "STRINGS.RECIPE_DESC.WINONA_BATTERY_LOW"
msgid "Someone's gotta keep the juice flowing."
msgstr "Birinin akımı akar tutması lazım."

#. STRINGS.RECIPE_DESC.WINONA_CATAPULT
msgctxt "STRINGS.RECIPE_DESC.WINONA_CATAPULT"
msgid "Lob big rocks at fearful foes."
msgstr "Korkak düşmanlara büyük kayalar fırlat."

#. STRINGS.RECIPE_DESC.WINONA_REMOTE
msgctxt "STRINGS.RECIPE_DESC.WINONA_REMOTE"
msgid "Control your creations with the push of a button."
msgstr "Yaratımlarını bir tuşa basarak kontrol et."

#. STRINGS.RECIPE_DESC.WINONA_SPOTLIGHT
msgctxt "STRINGS.RECIPE_DESC.WINONA_SPOTLIGHT"
msgid "Shine a light both day and night."
msgstr "Hem gündüz hem gece ışık saç."

#. STRINGS.RECIPE_DESC.WINONA_STORAGE_ROBOT
msgctxt "STRINGS.RECIPE_DESC.WINONA_STORAGE_ROBOT"
msgid "This collector belongs in your collection."
msgstr "Bu koleksiyoncu, koleksiyonuna ait."

#. STRINGS.RECIPE_DESC.WINONA_TELEBRELLA
msgctxt "STRINGS.RECIPE_DESC.WINONA_TELEBRELLA"
msgid "The best way to send anything home is by the particle."
msgstr "Bir şeyi eve göndermenin en iyi yolu parçacıktır."

#. STRINGS.RECIPE_DESC.WINONA_TELEPORT_PAD_ITEM
msgctxt "STRINGS.RECIPE_DESC.WINONA_TELEPORT_PAD_ITEM"
msgid "When it comes to transporting items, this machine really delivers."
msgstr "Eşya taşımaya gelince bu makine gerçekten teslim eder."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_BERRYSAUCE
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_BERRYSAUCE"
msgid "Fill your belly with a bowl full of jelly."
msgstr "Karnını jöle dolu bir kaseyle doldur."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_BIBINGKA
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_BIBINGKA"
msgid "This dish will leaf you wanting more."
msgstr "Bu yemek seni daha çok ister yapraklayacak."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_CABBAGEROLLS
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_CABBAGEROLLS"
msgid "Get your holiday feast rolling."
msgstr "Şölen ziyafetini saracak."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_FESTIVEFISH
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_FESTIVEFISH"
msgid "It just isn't the holidays without it."
msgstr "O olmadan tatil tatil olmaz."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_GRAVY
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_GRAVY"
msgid "All aboard the gravy train."
msgstr "Et suyu treni kalkıyor."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_LATKES
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_LATKES"
msgid "You'll like them a latke."
msgstr "Latke kadar seveceksin."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_LUTEFISK
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_LUTEFISK"
msgid "Sea-son's eatings."
msgstr "Deni-mevsim afiyetler."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_MULLEDDRINK
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_MULLEDDRINK"
msgid "A hot drink for a cold winter."
msgstr "Soğuk bir kış için sıcak bir içecek."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_PANETTONE
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_PANETTONE"
msgid "Like fruitcake, but edible!"
msgstr "Meyveli kek gibi ama yenebilir!"

#. STRINGS.RECIPE_DESC.WINTERCOOKING_PAVLOVA
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_PAVLOVA"
msgid "Light and crisp as new fallen snow."
msgstr "Yeni yağmış kar kadar hafif ve gevrek."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_PICKLEDHERRING
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_PICKLEDHERRING"
msgid "A salty seasonal supper."
msgstr "Tuzlu bir mevsim akşam yemeği."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_POLISHCOOKIE
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_POLISHCOOKIE"
msgid "Just like babcia used to make."
msgstr "Tıpkı babcia'nın yaptığı gibi."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_PUMPKINPIE
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_PUMPKINPIE"
msgid "Gourd tidings we bring."
msgstr "Kabakkün haberleri getiriyoruz."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_ROASTTURKEY
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_ROASTTURKEY"
msgid "Gobble-gobble it up."
msgstr "Gulguluyla mideye indir."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_STUFFING
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_STUFFING"
msgid "Stuff your face!"
msgstr "Suratını doldur!"

#. STRINGS.RECIPE_DESC.WINTERCOOKING_SWEETPOTATO
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_SWEETPOTATO"
msgid "It's a marshmallow world in the winter."
msgstr "Kışın dünya bir marşmelov dünyasıdır."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_TAMALES
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_TAMALES"
msgid "Spice up your holiday spread."
msgstr "Şölen sofrana baharat kat."

#. STRINGS.RECIPE_DESC.WINTERCOOKING_TOURTIERE
msgctxt "STRINGS.RECIPE_DESC.WINTERCOOKING_TOURTIERE"
msgid "A savory seasonal pie."
msgstr "Tuzlu bir mevsim turtası."

#. STRINGS.RECIPE_DESC.WINTERHAT
msgctxt "STRINGS.RECIPE_DESC.WINTERHAT"
msgid "Keeps yer noggin warm."
msgstr "Kafanı sıcak tutar."

#. STRINGS.RECIPE_DESC.WINTEROMETER
msgctxt "STRINGS.RECIPE_DESC.WINTEROMETER"
msgid "Measure ambient air temperature."
msgstr "Ortamın hava sıcaklığını ölç."

#. STRINGS.RECIPE_DESC.WINTERSFEASTOVEN
msgctxt "STRINGS.RECIPE_DESC.WINTERSFEASTOVEN"
msgid "It's all fired up for the holidays."
msgstr "Şölen için tamamen ateşlendi."

#. STRINGS.RECIPE_DESC.WINTER_ORNAMENT_BOSS_HERMITHOUSE
msgctxt "STRINGS.RECIPE_DESC.WINTER_ORNAMENT_BOSS_HERMITHOUSE"
msgid "A keepsake for your Winter's Feast Tree."
msgstr "Kış Şöleni Ağacın için bir hatıra."

#. STRINGS.RECIPE_DESC.WINTER_ORNAMENT_BOSS_PEARL
msgctxt "STRINGS.RECIPE_DESC.WINTER_ORNAMENT_BOSS_PEARL"
msgid "A keepsake for your Winter's Feast Tree."
msgstr "Kış Şöleni Ağacın için bir hatıra."

#. STRINGS.RECIPE_DESC.WINTER_TREESTAND
msgctxt "STRINGS.RECIPE_DESC.WINTER_TREESTAND"
msgid "Plant and decorate a Winter's Feast tree!"
msgstr "Bir Kış Şöleni ağacı dik ve süsle!"

#. STRINGS.RECIPE_DESC.WOBY_TREAT
msgctxt "STRINGS.RECIPE_DESC.WOBY_TREAT"
msgid "Non-perishable Monster Meat biscuits made special for Woby."
msgstr "Woby için özel yapılmış bozulmaz Canavar Eti bisküvileri."

#. STRINGS.RECIPE_DESC.WOLFGANG_WHISTLE
msgctxt "STRINGS.RECIPE_DESC.WOLFGANG_WHISTLE"
msgid "Let out your inner coach!"
msgstr "İçindeki antrenörü serbest bırak!"

#. STRINGS.RECIPE_DESC.WOODCARVEDHAT
msgctxt "STRINGS.RECIPE_DESC.WOODCARVEDHAT"
msgid "Your head will stay nice and safe (knock on wood)."
msgstr "Kafan güzelce güvende kalacak (tahtaya vur)."

#. STRINGS.RECIPE_DESC.WOOD_CHAIR
msgctxt "STRINGS.RECIPE_DESC.WOOD_CHAIR"
msgid "A wooden chair to sit on."
msgstr "Üzerine oturmak için tahta bir sandalye."

#. STRINGS.RECIPE_DESC.WOOD_STOOL
msgctxt "STRINGS.RECIPE_DESC.WOOD_STOOL"
msgid "A wooden stool to sit on."
msgstr "Üzerine oturmak için tahta bir tabure."

#. STRINGS.RECIPE_DESC.WOOD_TABLE_ROUND
msgctxt "STRINGS.RECIPE_DESC.WOOD_TABLE_ROUND"
msgid "A round wooden table to put things on."
msgstr "Üzerine eşya koymak için yuvarlak tahta bir masa."

#. STRINGS.RECIPE_DESC.WOOD_TABLE_SQUARE
msgctxt "STRINGS.RECIPE_DESC.WOOD_TABLE_SQUARE"
msgid "A square wooden table to put things on."
msgstr "Üzerine eşya koymak için kare tahta bir masa."

#. STRINGS.RECIPE_DESC.WORMWOOD_BERRYBUSH
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_BERRYBUSH"
msgid "It's hand-made!"
msgstr "El yapımı!"

#. STRINGS.RECIPE_DESC.WORMWOOD_BERRYBUSH2
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_BERRYBUSH2"
msgid "As many berries as your arm can carry."
msgstr "Kolun ne kadar taşıyabilirse o kadar meyve."

#. STRINGS.RECIPE_DESC.WORMWOOD_CARRAT
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_CARRAT"
msgid "Transform a plain old Carrot into a helpful Carrat!"
msgstr "Sıradan eski bir Havucu, yardımsever bir Havufareye dönüştür!"

#. STRINGS.RECIPE_DESC.WORMWOOD_FRUITDRAGON
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_FRUITDRAGON"
msgid "Transform a dreary Dragon Fruit into a fierce Saladmander!"
msgstr "Iç sıkıcı bir Ejder Meyvesini, vahşi bir Salatamender'a dönüştür!"

#. STRINGS.RECIPE_DESC.WORMWOOD_JUICYBERRYBUSH
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_JUICYBERRYBUSH"
msgid "Arm-fresh produce."
msgstr "Kol-taze ürün."

#. STRINGS.RECIPE_DESC.WORMWOOD_LIGHTFLIER
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_LIGHTFLIER"
msgid "Transform an ordinary Light Bulb into a loyal Bulbous Lightbug!"
msgstr "Sıradan bir Ampulü, sadık bir Ampul Işıkböceği'ne dönüştür!"

#. STRINGS.RECIPE_DESC.WORMWOOD_LUREPLANTBULB
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_LUREPLANTBULB"
msgid "Costs an arm, but not a leg."
msgstr "Kola mal olur ama bacağa olmaz."

#. STRINGS.RECIPE_DESC.WORMWOOD_REEDS
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_REEDS"
msgid "Knowing how to reed comes in handy."
msgstr "Sazo okumayı bilmek işe yarar."

#. STRINGS.RECIPE_DESC.WORMWOOD_SAPLING
msgctxt "STRINGS.RECIPE_DESC.WORMWOOD_SAPLING"
msgid "Grow out on a limb."
msgstr "Kolundan dışarı büyü."

#. STRINGS.RECIPE_DESC.WORTOX_NABBAG
msgctxt "STRINGS.RECIPE_DESC.WORTOX_NABBAG"
msgid "Stuff it and swing it!"
msgstr "Doldur ve savur!"

#. STRINGS.RECIPE_DESC.WORTOX_REVIVER
msgctxt "STRINGS.RECIPE_DESC.WORTOX_REVIVER"
msgid "Soul revival of a single ghostly friend. May bring others closer."
msgstr "Tek bir hayalet dostu ruhsal diriliş. Diğerlerini de yaklaştırabilir."

#. STRINGS.RECIPE_DESC.WORTOX_SOULJAR
msgctxt "STRINGS.RECIPE_DESC.WORTOX_SOULJAR"
msgid "Why let them be free when you can stuff them all into a jar?"
msgstr "Hepsini bir kavanoza doldurabilecekken neden serbest bırakasın?"

#. STRINGS.RECIPE_DESC.WURT_SWAMPITEM_LUNAR
msgctxt "STRINGS.RECIPE_DESC.WURT_SWAMPITEM_LUNAR"
msgid "Transform the battlefield and your fearless followers with a mind-altering, mutating bang!"
msgstr "Savaş meydanını ve korkusuz takipçilerini akıl bozucu, mutasyon gibi büyük bir patlamayla dönüştür!"

#. STRINGS.RECIPE_DESC.WURT_SWAMPITEM_SHADOW
msgctxt "STRINGS.RECIPE_DESC.WURT_SWAMPITEM_SHADOW"
msgid "Bring home turf advantage to any fight, along with some writhing reinforcements."
msgstr "Her dövüşe iç saha avantajı ve kıvranan takviyeler getir."

#. STRINGS.RECIPE_DESC.WX78MODULE_BEE
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_BEE"
msgid "Get your brain and body buzzing with powerful potential!"
msgstr "BEYNİNİ VE BEDENİNİ GÜÇLÜ POTANSİYELLE VIZILDAT!"

#. STRINGS.RECIPE_DESC.WX78MODULE_COLD
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_COLD"
msgid "Turn your chassis into a portable freezer."
msgstr "ŞASİNİ TAŞINABİLİR BİR DONDURUCUYA ÇEVİR."

#. STRINGS.RECIPE_DESC.WX78MODULE_DIGESTION
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_DIGESTION"
msgid "Give spoiled food a second chance!"
msgstr "BOZUK YİYECEĞE İKİNCİ BİR ŞANS VER!"

#. STRINGS.RECIPE_DESC.WX78MODULE_HEAT
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_HEAT"
msgid "Things are about to get heated."
msgstr "İŞLER ISINMAK ÜZERE."

#. STRINGS.RECIPE_DESC.WX78MODULE_LIGHT
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_LIGHT"
msgid "Light up a room with your presence."
msgstr "VARLIĞINLA BİR ODAYI AYDINLAT."

#. STRINGS.RECIPE_DESC.WX78MODULE_LIGHT2
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_LIGHT2"
msgid "Let them see the light... you."
msgstr "BIRAK IŞIĞI GÖRSÜNLER... SENİ."

#. STRINGS.RECIPE_DESC.WX78MODULE_MAXHEALTH
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MAXHEALTH"
msgid "Make your robotic body a bit more robust."
msgstr "ROBOTİK BEDENİNİ BİRAZ DAHA SAĞLAM YAP."

#. STRINGS.RECIPE_DESC.WX78MODULE_MAXHEALTH2
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MAXHEALTH2"
msgid "Make your robotic body much more robust."
msgstr "ROBOTİK BEDENİNİ ÇOK DAHA SAĞLAM YAP."

#. STRINGS.RECIPE_DESC.WX78MODULE_MAXHUNGER
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MAXHUNGER"
msgid "Capable of containing even the most insatiable automaton's appetite."
msgstr "EN DOYMAZ OTOMATONUN İŞTAHINI BİLE BARINDIRABİLİR."

#. STRINGS.RECIPE_DESC.WX78MODULE_MAXHUNGER1
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MAXHUNGER1"
msgid "Add a bit of room to your fuel tank."
msgstr "YAKIT DEPONA BİRAZ YER EKLE."

#. STRINGS.RECIPE_DESC.WX78MODULE_MAXSANITY
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MAXSANITY"
msgid "A big boost of processing power will really get those gears turning."
msgstr "İŞLEM GÜCÜNDE BÜYÜK BİR ARTIŞ ŞU ÇARKLARI ÇEVİRİR."

#. STRINGS.RECIPE_DESC.WX78MODULE_MAXSANITY1
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MAXSANITY1"
msgid "A little extra processing power helps to ease the mechanical mind."
msgstr "BİRAZ EKSTRA İŞLEM GÜCÜ MEKANİK ZİHNİ RAHATLATIR."

#. STRINGS.RECIPE_DESC.WX78MODULE_MOVESPEED
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MOVESPEED"
msgid "A hastily designed speed booster. It could use some improvement."
msgstr "ACELEYLE TASARLANMIŞ HIZ ARTIRICI. BİRAZ GELİŞTİRİLEBİLİR."

#. STRINGS.RECIPE_DESC.WX78MODULE_MOVESPEED2
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MOVESPEED2"
msgid "A perfected speed booster to kick your engine into high gear."
msgstr "MOTORUNU YÜKSEK VİTESE GEÇİREN MÜKEMMELLEŞTİRİLMİŞ HIZ ARTIRICI."

#. STRINGS.RECIPE_DESC.WX78MODULE_MUSIC
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_MUSIC"
msgid "Every machine needs a tune-up now and then."
msgstr "HER MAKİNENİN ARA SIRA AKORT AYARI GEREKİR."

#. STRINGS.RECIPE_DESC.WX78MODULE_NIGHTVISION
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_NIGHTVISION"
msgid "Recalibrate your optic sensors for night vision."
msgstr "OPTİK SENSÖRLERİNİ GECE GÖRÜŞÜ İÇİN YENİDEN AYARLA."

#. STRINGS.RECIPE_DESC.WX78MODULE_RADAR
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_RADAR"
msgid "Expand your horizons."
msgstr "UFKUNU GENİŞLET."

#. STRINGS.RECIPE_DESC.WX78MODULE_SCREECH
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_SCREECH"
msgid "Unleash the fearsome battlecry of the soulless automaton!"
msgstr "RUHSUZ OTOMATONUN KORKUNÇ SAVAŞ ÇIĞLIĞINI SAL!"

#. STRINGS.RECIPE_DESC.WX78MODULE_SHIELDING
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_SHIELDING"
msgid "Defend yourself!"
msgstr "KENDİNİ SAVUN!"

#. STRINGS.RECIPE_DESC.WX78MODULE_SPIN
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_SPIN"
msgid "Chop or smash your way around, and around, and around..."
msgstr "DÖNE DÖNE BALTALA YA DA EZ, DÖNE DÖNE, DÖNE DÖNE..."

#. STRINGS.RECIPE_DESC.WX78MODULE_STACKSIZE
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_STACKSIZE"
msgid "Infinite storage. Finite space. Don't overthink it."
msgstr "SONSUZ DEPO. SINIRLI ALAN. FAZLA DÜŞÜNME."

#. STRINGS.RECIPE_DESC.WX78MODULE_TASER
msgctxt "STRINGS.RECIPE_DESC.WX78MODULE_TASER"
msgid "Anyone who messes with you will be in for a shock."
msgstr "SENINLE UĞRAŞAN HERKES ŞOKA UĞRAR."

#. STRINGS.RECIPE_DESC.WX78_BACKUPBODY
msgctxt "STRINGS.RECIPE_DESC.WX78_BACKUPBODY"
msgid "It never hurts to have spare hardware. Although data transfer is always a pain."
msgstr "YEDEK DONANIM ASLA ZARAR VERMEZ. GERÇİ VERİ AKTARIMI HEP CAN SIKICIDIR."

