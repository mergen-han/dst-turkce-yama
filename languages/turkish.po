msgstr "Seni görmek güzel, %s!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.WOLFGANG.GHOST
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.WOLFGANG.GHOST"
msgid "I told you you couldn't deadlift that boulder. The numbers were all wrong."
msgstr "O kayayı ölü kaldıramayacağını söylemiştim. Sayılar hiç tutmuyordu."

