msgstr "Köpeksiz bir köpek ve midilli gösterisi, Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYBILL_THE_VAULT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYBILL_THE_VAULT"
msgid "Looks like a classic!"
msgstr "Bir klasik gibi görünüyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYBILL_THE_VEIL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYBILL_THE_VEIL"
msgid "Oooh, this looks spooky."
msgstr "Oooo, bu ürkütücü görünüyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.ATTACKER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.ATTACKER"
msgid "%s doesn't seem trustworthy..."
msgstr "%s güvenilir görünmüyor..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.FIRESTARTER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.FIRESTARTER"
msgid "That's not how you build a campfire, %s!"
msgstr "Kamp ateşi böyle yapılmaz, %s!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.GENERIC"
msgid "Hello, %s!"
msgstr "Merhaba, %s!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.GHOST
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.GHOST"
msgid "Don't worry %s, I have a badge in first aid!"
msgstr "Merak etme %s, ilk yardım rozetim var!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.MURDERER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.MURDERER"
msgid "You're not going to get away with this, %s!"
msgstr "Bu yanına kalmayacak, %s!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.REVIVER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER.REVIVER"
msgid "%s is definitely Pinetree Pioneer material."
msgstr "%s kesinlikle Çamağacı Öncüsü malzemesi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER_HOSTED.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER_HOSTED.GENERIC"
msgid "Don't you recognize me?"
msgstr "Beni tanımadın mı?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER_HOSTED.ME
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYER_HOSTED.ME"
msgid "Dead me walking! Ha... ha?"
msgstr "Ölü ben yürüyor! Ha... ha?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYING_CARD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.PLAYING_CARD"
msgid "Is THIS your card, Wobes?"
msgstr "Senin kartın BU mu, Wobes?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.POCKETWATCH_DISMANTLER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.POCKETWATCH_DISMANTLER"
msgid "Making clocks looks pretty complicated."
msgstr "Saat yapmak epey karmaşık görünüyor."

