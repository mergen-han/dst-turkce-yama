#. STRINGS.UI.ACHIEVEMENTS.LAVAARENA.ACHIEVEMENT.laq_battlecry.DESC
msgctxt "STRINGS.UI.ACHIEVEMENTS.LAVAARENA.ACHIEVEMENT.laq_battlecry.DESC"
msgid "Trigger the Battle Cry buff on at least 3 friends, 10 times in a single match"
msgstr "Tek bir maçta en az 3 dosta Savaş Çığlığı buff'ını 10 kez tetikle"

#. STRINGS.UI.ACHIEVEMENTS.LAVAARENA.ACHIEVEMENT.laq_battlecry.TITLE
msgctxt "STRINGS.UI.ACHIEVEMENTS.LAVAARENA.ACHIEVEMENT.laq_battlecry.TITLE"
msgid "Standing Ovation"
msgstr "Ayakta Alkış"

#. STRINGS.UI.ACHIEVEMENTS.LAVAARENA.ACHIEVEMENT.laq_battlestandards.DESC
msgctxt "STRINGS.UI.ACHIEVEMENTS.LAVAARENA.ACHIEVEMENT.laq_battlestandards.DESC"
