msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_CANT_ESCAPE_CURSE"
msgid "Huh... maybe I don't want to drop it after all."
msgstr "Hmm... belki sonuçta onu bırakmak istemiyorum."

#. STRINGS.CHARACTERS.WALTER.ANNOUNCE_CARRAT_ERROR_FELL_ASLEEP
msgctxt "STRINGS.CHARACTERS.WALTER.ANNOUNCE_CARRAT_ERROR_FELL_ASLEEP"
