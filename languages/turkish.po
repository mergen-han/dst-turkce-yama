#. STRINGS.SKIN_DESCRIPTIONS.monkeyhatsmall_beads
msgctxt "STRINGS.SKIN_DESCRIPTIONS.monkeyhatsmall_beads"
msgid "You probably should have tried putting the necklace on before the bandana."
msgstr "Muhtemelen kolyeyi banadanadan önce takmayı denemeliydin."

#. STRINGS.SKIN_DESCRIPTIONS.monkeyhatsmall_belt
msgctxt "STRINGS.SKIN_DESCRIPTIONS.monkeyhatsmall_belt"
msgid "A look that says \"I ripped my pants, but didn't want to see them go to waste\"."
msgstr "\"Pantolonumu yırttım ama ziyan olduğunu görmek istemedim\" diyen bir görünüş."

#. STRINGS.SKIN_DESCRIPTIONS.moondial_an
msgctxt "STRINGS.SKIN_DESCRIPTIONS.moondial_an"
