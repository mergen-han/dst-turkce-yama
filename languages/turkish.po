msgstr "Hmm, sence granola yerler mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_FOREST
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_FOREST"
