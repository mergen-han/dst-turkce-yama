msgstr "Bu sembollerin hiçbirini tanımıyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_1
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_1"
