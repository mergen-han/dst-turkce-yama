msgctxt "STRINGS.SKIN_DESCRIPTIONS.spear_ragged"
msgid "This spear has seen more than its fair share of battles."
msgstr "Bu mızrak hak ettiğinden çok daha fazla savaş gördü."

#. STRINGS.SKIN_DESCRIPTIONS.spear_rose
msgctxt "STRINGS.SKIN_DESCRIPTIONS.spear_rose"
msgid "No sharper than any other spear, though much lovelier."
msgstr "Başka bir mızraktan daha keskin değil, ama çok daha güzel."

#. STRINGS.SKIN_DESCRIPTIONS.spear_rw_swamp
msgctxt "STRINGS.SKIN_DESCRIPTIONS.spear_rw_swamp"
