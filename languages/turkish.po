msgstr "Sanırım bir süre kuşkonmaz yiyeceğiz..."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ASPARAGUS_SEEDS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ASPARAGUS_SEEDS"
msgid "It's some seeds."
msgstr "Birkaç tohum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_GATE.CHARGING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_GATE.CHARGING"
