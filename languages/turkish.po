msgstr "Bu savaşçı en acımasız kışlarla bile savaşmaya hazırdır."

#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_improvedhat_flower
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_improvedhat_flower"
