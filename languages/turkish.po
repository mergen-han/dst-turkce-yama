msgstr "Bir şey ona güç vermeli."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_LIGHT.ON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_LIGHT.ON"
