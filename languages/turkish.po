msgid "It does so much, badly."
msgstr "O kadar çok şeyi, o kadar kötü yapıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MERM_TOOLSHED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MERM_TOOLSHED"
msgid "I don't think I'll find anything scientific in there."
msgstr "Orada bilimsel bir şey bulacağımı sanmıyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MERM_TOOLSHED_UPGRADED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MERM_TOOLSHED_UPGRADED"
msgid "I don't think I'll find anything scientific in there."
msgstr "Orada bilimsel bir şey bulacağımı sanmıyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MERM_TOOL_UPGRADED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MERM_TOOL_UPGRADED"
msgid "This tool looks a little fishy."
msgstr "Bu alet biraz balıksı görünüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MESSAGEBOTTLE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MESSAGEBOTTLE"
msgid "I wonder if it's for me!"
msgstr "Bana mı acaba!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MESSAGEBOTTLEEMPTY
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MESSAGEBOTTLEEMPTY"
msgid "It's full of nothing."
msgstr "Hiçbir şeyle dolu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MIGHTY_GYM.BURNT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MIGHTY_GYM.BURNT"
msgid "It won't pull any muscles now."
msgstr "Artık hiçbir kas çekmeyecek."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MIGHTY_GYM.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MIGHTY_GYM.GENERIC"
msgid "I think I pulled a muscle just looking at it..."
msgstr "Sırf ona bakarken kasımı çektim sanırım..."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MILKYWHITES
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MILKYWHITES"
msgid "...Ew."
msgstr "...İğrenç."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINERHAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINERHAT"
msgid "A hands-free way to brighten your day."
msgstr "Gününü aydınlatmanın eli boş bir yolu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINIBOATLANTERN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINIBOATLANTERN"
msgid "How illuminating!"
msgstr "Ne aydınlatıcı!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINIFAN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINIFAN"
msgid "Somehow the breeze comes out the back twice as fast."
msgstr "Esinti her nasılsa arkadan iki kat hızlı çıkıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINIFLARE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINIFLARE"
msgid "I can light it to let everyone know I'm here."
msgstr "Burada olduğumu herkese bildirmek için yakabilirim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINISIGN.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINISIGN.GENERIC"
msgid "I could draw better than that!"
msgstr "Bundan daha iyi resim çizerdim!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINISIGN.UNDRAWN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINISIGN.UNDRAWN"
msgid "We should draw something on there."
msgstr "Üstüne bir şey çizmeliyiz."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINISIGN_ITEM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINISIGN_ITEM"
msgid "It's not much use like this. We should place it."
msgstr "Bu hâliyle pek faydası yok. Yerleştirmeliyiz."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINOTAUR
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINOTAUR"
msgid "That thing doesn't look happy."
msgstr "O şey mutlu görünmüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINOTAURCHEST
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINOTAURCHEST"
msgid "It may contain a bigger something fantastic! Or horrible."
msgstr "İçinde daha büyük harika bir şey olabilir! Ya da korkunç."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINOTAURHORN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MINOTAURHORN"
msgid "Wow! I'm glad that didn't gore me!"
msgstr "Vay! Beni şişlemediğine sevindim!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLE.ABOVEGROUND
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLE.ABOVEGROUND"
msgid "I'd sure like to whack that mole... thing."
msgstr "O köstebeğe... şeye bir vurmak isterdim doğrusu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLE.HELD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLE.HELD"
msgid "Nowhere left to dig, my friend."
msgstr "Kazacak yer kalmadı dostum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLE.UNDERGROUND
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLE.UNDERGROUND"
msgid "Something's under there, searching for minerals."
msgstr "Aşağıda bir şey var, mineral arıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLEBAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLEBAT"
msgid "A regular Noseferatu."
msgstr "Düpedüz bir Burunferatu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLEBATHILL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLEBATHILL"
msgid "I wonder what might be stuck in that rat's nest."
msgstr "O fare yuvasında ne sıkışmış olabilir acaba."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLEHAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLEHAT"
msgid "A wretched stench, but excellent visibility."
msgstr "Berbat bir koku ama mükemmel bir görüş."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLEHILL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOLEHILL"
msgid "What a nice, homey hole in the ground!"
msgstr "Yerde ne hoş, ev sıcaklığında bir delik!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEY
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEY"
msgid "Curious little guy."
msgstr "Meraklı küçük dost."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYBARREL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYBARREL"
msgid "Did that just move?"
msgstr "Az önce kıpırdadı mı o?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYHUT.BURNT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYHUT.BURNT"
msgid "Like I said!"
msgstr "Ben demiştim!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYHUT.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYHUT.GENERIC"
msgid "Treehouses are terribly flammable places to conduct experiments."
msgstr "Ağaç evler deney yapmak için fena hâlde yanıcı yerlerdir."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYISLAND_PORTAL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYISLAND_PORTAL"
msgid "Nothing can get in, but it keeps spitting things out."
msgstr "Hiçbir şey giremiyor ama bir şeyler tükürüp duruyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYISLAND_PORTAL_DEBRIS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYISLAND_PORTAL_DEBRIS"
msgid "This machinery looks oddly familiar..."
msgstr "Bu makine tuhaf bir şekilde tanıdık görünüyor..."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYPILLAR
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYPILLAR"
msgid "A real pillar of the community."
msgstr "Topluluğun gerçek bir direği."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYQUEEN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYQUEEN"
msgid "She looks like the top banana around here."
msgstr "Buralarda baş muz gibi görünüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYTAIL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEYTAIL"
msgid "I wonder if they're edible? Maybe an experiment is in order."
msgstr "Yenir mi acaba? Belki bir deney sırada."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEY_MEDIUMHAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEY_MEDIUMHAT"
msgid "I think it makes me look very dashing and captain-like."
msgstr "Bence bana çok şık ve kaptanvari bir görünüm veriyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEY_SMALLHAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONKEY_SMALLHAT"
msgid "At least it will keep my hair dry."
msgstr "En azından saçımı kuru tutacak."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONSTERLASAGNA
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONSTERLASAGNA"
msgid "It's an affront to science."
msgstr "Bilime hakaret bu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONSTERMEAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONSTERMEAT"
msgid "Ugh. I don't think I should eat that."
msgstr "Of. Bunu yememeliyim sanırım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONSTERMEAT_DRIED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONSTERMEAT_DRIED"
msgid "Strange-smelling jerky."
msgstr "Tuhaf kokulu pastırma."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONSTERTARTARE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MONSTERTARTARE"
msgid "There's got to be something else to eat around here."
msgstr "Buralarda yenecek başka bir şey olmalı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.BROKEN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.BROKEN"
msgid "It's all smashed up."
msgstr "Hepsi paramparça olmuş."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.GENERIC"
msgid "There's a hole in the middle for something to go in."
msgstr "Ortasında bir şeyin gireceği bir delik var."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.MOONSTAFF
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.MOONSTAFF"
msgid "The stone lit it up somehow."
msgstr "Taş onu her nasılsa aydınlattı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.STAFFED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.STAFFED"
msgid "Now what?"
msgstr "Şimdi ne?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.WRONGSTAFF
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBASE.WRONGSTAFF"
msgid "I have a distinct feeling this isn't right."
msgstr "Bunun doğru olmadığına dair açık bir his var bende."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBUTTERFLY.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBUTTERFLY.GENERIC"
msgid "My vast scientific knowledge tells me it's... a moon butterfly."
msgstr "Engin bilimsel bilgim bana söylüyor ki bu... bir ay kelebeği."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBUTTERFLY.HELD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBUTTERFLY.HELD"
msgid "I've got you now."
msgstr "Şimdi yakaladım seni."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBUTTERFLYWINGS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBUTTERFLYWINGS"
msgid "We're really winging it now."
msgstr "Şimdi gerçekten kanat çırpıyoruz."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBUTTERFLY_SAPLING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONBUTTERFLY_SAPLING"
msgid "A moth turned into a tree? Lunacy!"
msgstr "Bir güve ağaca mı dönüştü? Ay-cinneti!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.CAVE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.CAVE"
msgid "There's no moon down here to measure."
msgstr "Burada ölçecek bir ay yok."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.GENERIC"
msgid "Water amplifies the science, allowing us to measure the moon."
msgstr "Su bilimi güçlendirir, ayı ölçmemize olanak tanır."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.GLASSED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.GLASSED"
msgid "I have the strangest feeling I'm being watched."
msgstr "İzlendiğime dair son derece tuhaf bir his var bende."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.NIGHT_FULL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.NIGHT_FULL"
msgid "It's a full moon."
msgstr "Dolunay var."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.NIGHT_NEW
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.NIGHT_NEW"
msgid "It's a new moon."
msgstr "Yeniay var."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.NIGHT_WANE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.NIGHT_WANE"
msgid "The moon is waning."
msgstr "Ay küçülüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.NIGHT_WAX
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.NIGHT_WAX"
msgid "The moon is waxing."
msgstr "Ay büyüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.WEREBEAVER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONDIAL.WEREBEAVER"
msgid "only_used_by_woodie"
msgstr "only_used_by_woodie"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASS"
msgid "It's very sharp."
msgstr "Çok keskin."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASSAXE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASSAXE"
msgid "I've made it extra effective."
msgstr "Onu fazladan etkili yaptım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASS_CHARGED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASS_CHARGED"
msgid "I should put this to scientific use before the energy fades!"
msgstr "Enerjisi solmadan bunu bilimsel kullanıma sokmalıyım!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASS_ROCK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASS_ROCK"
msgid "I can practically see my reflection in it."
msgstr "İçinde yansımamı neredeyse görebiliyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASS_WOBSTER_DEN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONGLASS_WOBSTER_DEN"
msgid "It's a chunk of moonglass with Lunar Wobsters in it."
msgstr "İçinde Ay Vobsterları olan bir ay camı parçası."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCKCRATER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCKCRATER"
msgid "I should stick something shiny in it. For research."
msgstr "İçine parlak bir şey sokmalıyım. Araştırma için."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCKIDOL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCKIDOL"
msgid "I only worship science."
msgstr "Ben yalnızca bilime tapınırım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCKNUGGET
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCKNUGGET"
msgid "That rock came from the moon."
msgstr "O taş aydan geldi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCKSEED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCKSEED"
msgid "There's science inside!"
msgstr "İçinde bilim var!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCK_PIECES
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONROCK_PIECES"
msgid "I could probably break that."
msgstr "Onu kırabilirim muhtemelen."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSPIDERDEN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSPIDERDEN"
msgid "That's not a normal spider den."
msgstr "Bu normal bir örümcek ini değil."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_GLASS.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_GLASS.GENERIC"
msgid "It's glassy."
msgstr "Camsı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_GLASS.INFUSED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_GLASS.INFUSED"
msgid "It's glowing with unearthly energy."
msgstr "Dünya dışı bir enerjiyle parlıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_GOGGLESHAT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_GOGGLESHAT"
msgid "Of course! Combining moon energy with potato energy, why didn't I think of that?"
msgstr "Tabii ki! Ay enerjisini patates enerjisiyle birleştirmek, ben niye düşünmedim ki?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_SPARK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_SPARK"
msgid "I think I'll call it the \"Higgsbury Particle.\""
msgstr "Sanırım buna \"Higgsbury Parçacığı\" diyeceğim."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_STATIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_STATIC"
msgid "A new discovery, how electrifying!"
msgstr "Yeni bir keşif, ne elektrikleyici!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_STATIC_CATCHER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_STATIC_CATCHER"
msgid "There's nothing inside."
msgstr "İçinde hiçbir şey yok."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_STATIC_ITEM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_STATIC_ITEM"
msgid "It makes my hair do crazy things."
msgstr "Saçıma çılgın şeyler yaptırıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_STATIC_ROAMER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOONSTORM_STATIC_ROAMER"
msgid "It seems lost in transmission."
msgstr "İletimde kaybolmuş gibi görünüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR.GENERIC"
msgid "Hm? What did you say?"
msgstr "Hı? Ne dedin?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR.MOON_ALTAR_WIP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR.MOON_ALTAR_WIP"
msgid "It wants to be finished."
msgstr "Tamamlanmak istiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ASTRAL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ASTRAL"
msgid "It seems to be part of a larger mechanism."
msgstr "Daha büyük bir mekanizmanın parçası gibi görünüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_COSMIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_COSMIC"
msgid "It feels like it's waiting for something."
msgstr "Bir şey bekliyormuş gibi geliyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_CROWN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_CROWN"
msgid "I fished it up, now to find a fissure!"
msgstr "Onu balıkla çıkardım, şimdi bir çatlak bulmalıyım!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_GLASS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_GLASS"
msgid "It doesn't want to be on the ground."
msgstr "Yerde olmak istemiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ICON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ICON"
msgid "I think I know just where you belong."
msgstr "Tam olarak nereye ait olduğunu biliyorum sanırım."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_IDOL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_IDOL"
msgid "I feel compelled to carry it somewhere."
msgstr "Onu bir yere taşımak için zorlanma hissediyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_LINK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_LINK"
msgid "It must be building up to something."
msgstr "Bir şeye doğru yapılanıyor olmalı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ROCK_GLASS
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ROCK_GLASS"
msgid "There's something trapped inside."
msgstr "İçinde bir şey kapalı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ROCK_IDOL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ROCK_IDOL"
msgid "There's something trapped inside."
msgstr "İçinde bir şey kapalı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ROCK_SEED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_ROCK_SEED"
msgid "There's something trapped inside."
msgstr "İçinde bir şey kapalı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_SEED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_SEED"
msgid "It wants me to give it a home."
msgstr "Ona bir yuva vermemi istiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_WARD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_ALTAR_WARD"
msgid "It wants to be with the others."
msgstr "Diğerleriyle birlikte olmak istiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_CAP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_CAP"
msgid "It doesn't look particularly appetizing."
msgstr "Pek de iştah açıcı görünmüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_CAP_COOKED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_CAP_COOKED"
msgid "The things I do in the name of science..."
msgstr "Bilim adına neler yapmıyorum ki..."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_DEVICE.CONSTRUCTION1
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_DEVICE.CONSTRUCTION1"
msgid "The science has only just started."
msgstr "Bilim daha yeni başladı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_DEVICE.CONSTRUCTION2
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_DEVICE.CONSTRUCTION2"
msgid "That's looking much more science-y already!"
msgstr "Şimdiden çok daha bilim-vari görünüyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_DEVICE.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_DEVICE.GENERIC"
msgid "It's containing the energy! I knew what it was for all along, of course."
msgstr "Enerjiyi tutuyor! Tabii ki ne için olduğunu en başından beri biliyordum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_FISSURE.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_FISSURE.GENERIC"
msgid "My brain pulses with peace and terror."
msgstr "Beynim huzur ve dehşetle atıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_FISSURE.NOLIGHT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_FISSURE.NOLIGHT"
msgid "The cracks in this place are starting to show."
msgstr "Bu yerin çatlakları belirmeye başlıyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_FISSURE_PLUGGED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_FISSURE_PLUGGED"
msgid "It's not very scientific... but pretty effective."
msgstr "Pek bilimsel değil... ama oldukça etkili."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE.BURNING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE.BURNING"
msgid "The tree is burning!"
msgstr "Ağaç yanıyor!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE.BURNT
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE.BURNT"
msgid "The tree burned down."
msgstr "Ağaç yanıp kül oldu."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE.CHOPPED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE.CHOPPED"
msgid "That was a pretty thick tree."
msgstr "Oldukça kalın bir ağaçtı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE.GENERIC"
msgid "I didn't know trees grew on the moon."
msgstr "Ayda ağaç yetiştiğini bilmiyordum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE_BLOSSOM
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE_BLOSSOM"
msgid "It fell from the moon tree."
msgstr "Ay ağacından düşmüş."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE_BLOSSOM_DRIED
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOON_TREE_BLOSSOM_DRIED"
msgid "Nice dry."
msgstr "Hoş ve kuru."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOOSE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOOSE"
msgid "I don't exactly know what that thing is."
msgstr "O şeyin tam olarak ne olduğunu bilmiyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOOSEEGG
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOOSEEGG"
msgid "The babies are like excited electrons trying to escape."
msgstr "Yavrular kaçmaya çalışan uyarılmış elektronlar gibi."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOOSE_NESTING_GROUND
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOOSE_NESTING_GROUND"
msgid "It puts its babies there."
msgstr "Yavrularını oraya koyuyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOQUECA
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOQUECA"
msgid "He's as talented a chef as I am a scientist."
msgstr "O da benim bir bilim adamı oluşum kadar yetenekli bir aşçı."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITO.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITO.GENERIC"
msgid "Disgusting little bloodsucker."
msgstr "İğrenç küçük kan emici."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITO.HELD
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITO.HELD"
msgid "Hey, is that my blood?"
msgstr "Hey, o benim kanım mı?"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITOBOMB
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITOBOMB"
msgid "I'm just itching to throw it."
msgstr "Onu fırlatmak için kaşınıp duruyorum."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITOFERTILIZER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITOFERTILIZER"
msgid "Apparently plants like it."
msgstr "Görünüşe göre bitkiler seviyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITOMERMSALVE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOSQUITOMERMSALVE"
