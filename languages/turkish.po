#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIERESIDUE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIERESIDUE"
msgid "only_used_by_winona"
msgstr "only_used_by_winona"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIEROSE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIEROSE"
msgid "only_used_by_winona"
msgstr "only_used_by_winona"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIE_HAND
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIE_HAND"
msgid "It wants something dreadful."
msgstr "Korkunç bir şey istiyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIE_HECKLER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIE_HECKLER"
msgid "They're just here to stir up drama."
msgstr "Sadece dram çıkarmak için buradalar."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIE_LECTURN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHARLIE_LECTURN"
