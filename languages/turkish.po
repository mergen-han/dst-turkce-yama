msgstr "İnsanlar derilerini değiştiriyor. Altta farklı görünüyorlar."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_5
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_RUBBLE.LINE_5"
msgid "It shows a massive, technologically advanced city."
msgstr "Devasa, teknolojik açıdan ileri bir şehri gösteriyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_STATUE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_STATUE"
msgid "It doesn't seem fully real."
msgstr "Tamamen gerçek görünmüyor."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.AXE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.AXE"
