msgstr "İçinde dışarı çıkmak için bekleyen bir ağaç var!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIVINGTREE_SAPLING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIVINGTREE_SAPLING"
