msgstr "Woby, sanırım o bitki perili!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LUNARTHRALL_PLANT_VINE_END
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LUNARTHRALL_PLANT_VINE_END"
