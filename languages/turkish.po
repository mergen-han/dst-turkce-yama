#. STRINGS.SKIN_DESCRIPTIONS.pickaxe_feathered
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pickaxe_feathered"
msgid "The pickaxe of the self-reliant adventurer."
msgstr "Kendine güvenen maceracının kazması."

#. STRINGS.SKIN_DESCRIPTIONS.pickaxe_invisible
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pickaxe_invisible"
msgid "Convey an incredibly convincing impression of a pickaxe."
msgstr "Bir kazmanın inanılmaz ikna edici bir izlenimini ver."

#. STRINGS.SKIN_DESCRIPTIONS.pickaxe_northern
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pickaxe_northern"
msgid "A rustic, sturdy pickaxe."
msgstr "Köyceyi, sağlam bir kazma."

#. STRINGS.SKIN_DESCRIPTIONS.pickaxe_reavershark
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pickaxe_reavershark"
msgid "Not many realize the sharpest part of the shark is actually its jawline."
msgstr "Çoğu kişi köpekbalığının en keskin yerinin aslında çene hattı olduğunu fark etmez."

#. STRINGS.SKIN_DESCRIPTIONS.pickaxe_scythe
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pickaxe_scythe"
msgid "A terrible scythe to behold."
msgstr "Bakması bile dehşet verici bir tırpan."

#. STRINGS.SKIN_DESCRIPTIONS.pickaxe_scythe_alt
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pickaxe_scythe_alt"
msgid "A terrible scythe to behold."
msgstr "Bakması bile dehşet verici bir tırpan."

#. STRINGS.SKIN_DESCRIPTIONS.pickaxe_victorian
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pickaxe_victorian"
msgid "An elegantly engraved silver pickaxe."
msgstr "Zarifçe oyulmuş gümüş bir kazma."

#. STRINGS.SKIN_DESCRIPTIONS.piggyback_elephant
msgctxt "STRINGS.SKIN_DESCRIPTIONS.piggyback_elephant"
msgid "It really puts the \"pack\" in pachyderm!"
msgstr "Pakide gerçekten \"paket\" anlam katıyor!"

#. STRINGS.SKIN_DESCRIPTIONS.piggyback_nose
msgctxt "STRINGS.SKIN_DESCRIPTIONS.piggyback_nose"
msgid "This little piggy will carry your things all the way home."
msgstr "Bu küçük domuzcuk eşyalarını ta evine kadar taşıyacak."

#. STRINGS.SKIN_DESCRIPTIONS.pighouse_cabin
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pighouse_cabin"
msgid "That pig will be snug as a bug in a rug."
msgstr "O domuz halıdaki böcek kadar kıvrılıp rahat edecek."

#. STRINGS.SKIN_DESCRIPTIONS.pighouse_gothic
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pighouse_gothic"
msgid "Despite years of neglect, this manor still maintains its imposing atmosphere."
msgstr "Yıllarca ihmal edilmesine rağmen, bu konak hâlâ heybetli atmosferini koruyor."

#. STRINGS.SKIN_DESCRIPTIONS.pighouse_logcabin
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pighouse_logcabin"
msgid "Perfect for weathering those cold winters up North."
msgstr "Kuzey'in soğuk kışlarına dayanmak için kusursuz."

#. STRINGS.SKIN_DESCRIPTIONS.pitchfork_invisible
msgctxt "STRINGS.SKIN_DESCRIPTIONS.pitchfork_invisible"
msgid "Convey an incredibly convincing impression of a pitchfork."
msgstr "Bir dirgenin inanılmaz ikna edici bir izlenimini ver."

