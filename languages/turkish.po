msgstr "Hey küçük dostum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_MARSH
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_MARSH"
msgid "I wonder if there's a badge for kitten wrangling..."
msgstr "Acaba yavru kedi yakalamanın bir rozeti var mı..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_MOON
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_MOON"
msgid "Hmm, do you think they'd eat granola?"
msgstr "Hmm, sence granola yerler mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_NAMETAG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_NAMETAG"
msgid "It looks almost like yours, Woby!"
msgstr "Neredeyse seninkine benziyor Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_ROCKY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_ROCKY"
msgid "Hey little guy!"
msgstr "Hey küçük dostum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_SAVANNA
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_SAVANNA"
msgid "Aww, they're so cute even Woby likes them!"
msgstr "Aaaa, o kadar tatlılar ki Woby bile onları seviyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_YOT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KITCOON_YOT"
msgid "Hmm, do you think they'd eat granola?"
msgstr "Hmm, sence granola yerler mi?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KLAUS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KLAUS"
msgid "Woah! Who are you?"
msgstr "Vay! Kimsin sen?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KLAUSSACKKEY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KLAUSSACKKEY"
msgid "There's something weird about this antler."
msgstr "Bu boynuzda garip bir şey var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KLAUS_SACK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KLAUS_SACK"
msgid "Hey, he brought presents!"
msgstr "Hey, hediyeler getirmiş!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT"
msgid "Just horsing around..."
msgstr "Sadece atıyor..."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT_NIGHTMARE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT_NIGHTMARE"
msgid "Heh, spooky!"
msgstr "Hehe, ürkütücü!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT_YOTH.FOLLOWING
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT_YOTH.FOLLOWING"
msgid "Woby, look! We're friends!"
msgstr "Woby, bak! Arkadaşız!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT_YOTH.FOLLOWING_OTHER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT_YOTH.FOLLOWING_OTHER"
msgid "Ooh, they follow the princess!"
msgstr "Ooo, prensesi takip ediyorlar!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT_YOTH.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KNIGHT_YOTH.GENERIC"
msgid "Whoa, fella!"
msgstr "Vay, dostum!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KOALEFANT_CARCASS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KOALEFANT_CARCASS"
msgid "Should we say a few words, Woby?"
msgstr "Birkaç kelime etsek mi Woby?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KOALEFANT_SUMMER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KOALEFANT_SUMMER"
msgid "The trail led us right to it."
msgstr "İz bizi doğrudan ona götürdü."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KOALEFANT_WINTER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KOALEFANT_WINTER"
msgid "So you're the one who left those tracks!"
msgstr "Demek o izleri bırakan sensin!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KOALEFIG_TRUNK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KOALEFIG_TRUNK"
msgid "How many figs are in there?!"
msgstr "İçinde kaç tane incir var?!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KRAMPUS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KRAMPUS"
msgid "Hey! Did you rifle through my supplies?"
msgstr "Hey! Erzaklarımı sen mi karıştırdın?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.KRAMPUS_SACK
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.KRAMPUS_SACK"
msgid "It smells... goat-y."
msgstr "Şey kokuyor... keçi gibi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LANTERN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LANTERN"
msgid "Light the way, lantern."
msgstr "Yolu aydınlat, fener."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LATKES
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LATKES"
msgid "I've never tried potatoes cooked like this before."
msgstr "Daha önce böyle pişirilmiş patates denememiştim."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMOREXTRAHEAVY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMOREXTRAHEAVY"
msgid "This armor has been petrified for maximum protection."
msgstr "Bu zırh maksimum koruma için taşlaştırılmış."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORHEAVY
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORHEAVY"
msgid "That's as good as it gets."
msgstr "Bundan daha iyisi olamaz."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORLIGHT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORLIGHT"
msgid "Light, but not very durable."
msgstr "Hafif ama pek dayanıklı değil."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORLIGHTSPEED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORLIGHTSPEED"
msgid "Lightweight and designed for mobility."
msgstr "Hafif ve hareketlilik için tasarlanmış."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORMEDIUM
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORMEDIUM"
msgid "It offers a decent amount of protection."
msgstr "İyi bir koruma sağlıyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORMEDIUMDAMAGER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORMEDIUMDAMAGER"
msgid "That could help me hit a little harder."
msgstr "Bu biraz daha sert vurmama yardımcı olabilir."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORMEDIUMRECHARGER
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMORMEDIUMRECHARGER"
msgid "I'd have energy for a few more stunts wearing that."
msgstr "Onu giyersem birkaç gösteri daha yapacak enerjim olur."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMOR_HP
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ARMOR_HP"
msgid "That should keep me safe."
msgstr "Bu beni güvende tutmalı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_BATTLESTANDARD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_BATTLESTANDARD"
msgid "Everyone, break the Battle Standard!"
msgstr "Herkes, Savaş Sancağını kırın!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_BERNIE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_BERNIE"
msgid "He might make a good distraction for us."
msgstr "İyi bir dikkat dağıtıcı olabilir bizim için."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_BOARLORD
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_BOARLORD"
msgid "That's the guy in charge here."
msgstr "Burada işin başındaki adam o."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_CROWNDAMAGERHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_CROWNDAMAGERHAT"
msgid "That could cause some major destruction."
msgstr "Büyük bir yıkıma sebep olabilir."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ELEMENTAL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_ELEMENTAL"
msgid "It's a rock monster!"
msgstr "Bu bir kaya canavarı!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_EYECIRCLETHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_EYECIRCLETHAT"
msgid "It has a gaze full of science."
msgstr "Bilim dolu bir bakışı var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_FEATHERCROWNHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_FEATHERCROWNHAT"
msgid "Those fluffy feathers make me want to run!"
msgstr "O kabarık tüyler içimden koşmak geliyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_FIREBOMB
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_FIREBOMB"
msgid "It smells like brimstone."
msgstr "Kükürt gibi kokuyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_HEALINGFLOWERHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_HEALINGFLOWERHAT"
msgid "The blossom interacts well with healing magic."
msgstr "Çiçek iyileştirici sihirle iyi etkileşiyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_HEALINGGARLANDHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_HEALINGGARLANDHAT"
msgid "This garland will restore a bit of my vitality."
msgstr "Bu çelenk dirimimi biraz geri kazandıracak."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_HEAVYBLADE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_HEAVYBLADE"
msgid "A sharp looking instrument."
msgstr "Keskin görünüşlü bir alet."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_KEYHOLE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_KEYHOLE"
msgid "It needs a key."
msgstr "Bir anahtara ihtiyacı var."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_KEYHOLE_FULL
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_KEYHOLE_FULL"
msgid "That should do it."
msgstr "Bu yeterli olmalı."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_LIGHTDAMAGERHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_LIGHTDAMAGERHAT"
