msgstr "Temel bileşenler hâlâ sağlam."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_GATE.ON
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_GATE.ON"
msgid "Back in working order."
msgstr "Yeniden çalışır durumda."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_KEY
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.ATRIUM_KEY"
