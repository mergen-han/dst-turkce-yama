msgstr "Şu keçiye yıldırım mı çarptı?!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNINGGOAT.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNINGGOAT.GENERIC"
msgid "That's a weird looking mountain goat."
msgstr "Garip görünüşlü bir dağ keçisi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNINGGOATHORN
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNINGGOATHORN"
msgid "The goat gave me a souvenir."
msgstr "Keçi bana hatıra verdi."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNING_ROD.CHARGED
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNING_ROD.CHARGED"
msgid "It's crackling with energy!"
msgstr "Enerjiyle çatırdıyor!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNING_ROD.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIGHTNING_ROD.GENERIC"
msgid "That's where we keep the lightning."
msgstr "Yıldırımı orada saklarız."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LITTLE_WALRUS
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LITTLE_WALRUS"
