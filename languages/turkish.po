msgstr "Bu heykel oldukça etlibütlü."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BEEQUEEN
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BEEQUEEN"
msgid "Very statuesque."
msgstr "Çok heykelvari."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BISHOP.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BISHOP.GENERIC"
msgid "It's a stone bishop."
msgstr "Bir taş piskopos."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BISHOP.STRUGGLE
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.CHESSPIECE_BISHOP.STRUGGLE"
