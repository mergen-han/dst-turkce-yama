#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.OFFERING_POT_UPGRADED.LOTS_OF_KELP
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.OFFERING_POT_UPGRADED.LOTS_OF_KELP"
