msgstr "Eski güve yemiş Tam o' Shanter şapkanı yeni güve yemiş bir Tam o' Shanter ile değiştir!"

#. STRINGS.SKIN_DESCRIPTIONS.walrushat_cawnival
msgctxt "STRINGS.SKIN_DESCRIPTIONS.walrushat_cawnival"
