msgid "Great job countin'.\nYou completed 1 egg for a total of {score} points!"
msgstr "Saymayı iyi yaptın.\n1 yumurta tamamladın, toplam {score} puan!"

#. STRINGS.UI.TRADESCREEN.REDBIRD_GAME.GAME_OVER_POPUP_TITLE
msgctxt "STRINGS.UI.TRADESCREEN.REDBIRD_GAME.GAME_OVER_POPUP_TITLE"
