msgstr "Bu eğlence düşkünü Ragnarok'u karşılamaya hazır."

#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_nature
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_nature"
