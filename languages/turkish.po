msgstr "Daha önce gerçek bir mors yakından görmemiştim!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIVINGLOG
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIVINGLOG"
msgid "Yep, this log's definitely haunted."
msgstr "Aha, bu kütük kesinlikle perili."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIVINGTREE
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIVINGTREE"
msgid "Can you talk? What's it like being a tree?"
msgstr "Konuşabilir misin? Ağaç olmak nasıl bir şey?"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LIVINGTREE_ROOT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LIVINGTREE_ROOT"
