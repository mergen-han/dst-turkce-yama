msgstr "Aydınlanmış bir zihin, ilham veren bir lider yapar."

#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_improvedhat_valkyrie
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_improvedhat_valkyrie"
msgid "A commander should always keep their head held high."
msgstr "Bir komutan başını her zaman dik tutmalıdır."

#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_improvedhat_western
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_improvedhat_western"
