msgstr "Aaah! Kesinlikle bir elektron değilsin!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOUND.DUG
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOUND.DUG"
msgid "He probably deserved it."
msgstr "Muhtemelen hak etmiştir."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOUND.GENERIC
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MOUND.GENERIC"
msgid "I bet there's all sorts of good stuff down there!"
msgstr "Bahse girerim aşağıda her türlü iyi şey vardır!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MULLEDDRINK
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MULLEDDRINK"
msgid "This punch has a kick to it."
msgstr "Bu meyve suyunun bir tekmesi var."

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.MULTIPLAYER_PORTAL
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.MULTIPLAYER_PORTAL"
