msgstr "O düşmanlar buradan geliyor."

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_STRONGDAMAGERHAT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LAVAARENA_STRONGDAMAGERHAT"
