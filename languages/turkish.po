msgstr "Awwww. Ne tatlı!"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.BABYBEEFALO.SLEEPING
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.BABYBEEFALO.SLEEPING"
