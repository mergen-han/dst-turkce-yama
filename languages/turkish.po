msgstr "Bir şey yapalım Woby!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.LUNAR_FORGE_KIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.LUNAR_FORGE_KIT"
