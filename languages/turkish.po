msgstr "Mermeer'in başyapıtı."

#. STRINGS.SKIN_DESCRIPTIONS.decor_portraitframe_western
msgctxt "STRINGS.SKIN_DESCRIPTIONS.decor_portraitframe_western"
msgid "It was no fairy tale ending."
msgstr "Peri masalı sonu değildi."

#. STRINGS.SKIN_DESCRIPTIONS.deserthat_fedora
msgctxt "STRINGS.SKIN_DESCRIPTIONS.deserthat_fedora"
msgid "Detective work is hard enough without sand in your eyes."
msgstr "Dedektiflik zaten zor, bir de gözüne kum kaçmasın."

#. STRINGS.SKIN_DESCRIPTIONS.dock_woodposts_carved
