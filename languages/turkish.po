msgstr "Hadi Woby, çok eğlenceli olacak!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.POCKETWATCH_PORTAL_EXIT
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.POCKETWATCH_PORTAL_EXIT"
msgid "Time travel sure is amazing!"
msgstr "Zamanda yolculuk gerçekten muhteşem!"

#. STRINGS.CHARACTERS.WALTER.DESCRIBE.POCKETWATCH_RECALL.GENERIC
msgctxt "STRINGS.CHARACTERS.WALTER.DESCRIBE.POCKETWATCH_RECALL.GENERIC"
msgid "Ms. Wanda sure has a lot of clocks!"
msgstr "Bayan Wanda'nın gerçekten çok saati var!"

