#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_deerclops_p
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_deerclops_p"
msgid "Wigfrid chose to be one of her favorite foes to battle for Hallowed Nights."
msgstr "Wigfrid Cadılar Gecesi için en sevdiği düşmanlardan biri olmayı seçti."

#. STRINGS.SKIN_DESCRIPTIONS.wathgrithr_formal
msgctxt "STRINGS.SKIN_DESCRIPTIONS.wathgrithr_formal"
